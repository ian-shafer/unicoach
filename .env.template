PORT=8080

POSTGRES_USER=postgres
POSTGRES_DB=unicoach
POSTGRES_HOST_AUTH_METHOD=trust
# Absolute shared path: dev, test, AND every git worktree use the SAME cluster
# (one postgres on POSTGRES_PORT). Isolation is per-database, never per-data-dir.
POSTGRES_DATA_DIR=$HOME/var/unicoach/postgres
POSTGRES_ADMIN_DB=postgres
PGHOST=localhost
POSTGRES_PORT=5432

# --- Application Configuration ---
DATABASE_USER=unicoach
DATABASE_PASSWORD=password
DATABASE_MAXIMUM_POOL_SIZE=10

# Single source of the deploy host. The server derives session.cookieDomain from
# it (rest-server.conf), and bin/build-ios derives the iOS backend URL
# (http://$APP_DOMAIN:${SERVER_PORT:-8080}) from the same value. Override once for
# on-device use (a DNS hostname; a bare IP is rejected at build). See
# ios-app/DEPLOY.md.
APP_DOMAIN=localhost

# Server-side client-key gate (rest-server.conf clientKeyGate.keys, overridden by
# ${?UNICOACH_CLIENT_KEYS}): a comma-separated set of valid client keys. Blank
# locally, which disables the gate (it fails open on an empty set). In deployment
# it is supplied from the task environment / Secrets Manager; distinct keys (iOS
# app, control tooling) are comma-joined and each is independently revocable.
# Never commit a real value.
UNICOACH_CLIENT_KEYS=

# iOS build-time client key: the single key bin/build-ios bakes into the app
# bundle (Info.plist UnicoachClientKey), which the app sends as the
# X-Unicoach-Client-Key header. Blank locally (no header sent). For a gated
# deployment, set it to one of the server's UNICOACH_CLIENT_KEYS, supplied from
# the environment / Secrets Manager. Never commit a real value. See
# ios-app/DEPLOY.md.
UNICOACH_CLIENT_KEY=
