PORT=8080

POSTGRES_USER=postgres
POSTGRES_DB=unicoach-test
POSTGRES_HOST_AUTH_METHOD=trust
# POSTGRES_DATA_DIR should be identical across dev and test to avoid docker-compose container restarts/contention
POSTGRES_DATA_DIR=./var/postgres
POSTGRES_ADMIN_DB=postgres

# --- Application Configuration ---
DATABASE_URL=jdbc:postgresql://localhost:5432/unicoach-test
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_POOL_SIZE=2
JWT_SECRET=test_secret
JWT_ISSUER=http://test/
