# Test delta layered AFTER .env (bin/common sources .env first, then this file).
# It carries ONLY the keys whose values differ from .env; everything else
# (the Postgres-cluster block, DATABASE_PASSWORD, APP_DOMAIN) is inherited.

# Tests must never depend on a hardcoded port being free. The harness
# (bin/scripts-tests) exports a free PORT before sourcing this file; 8081 is only
# a fallback for tooling that sources .env.test without first picking a port.
PORT="${PORT:-8081}"

# Per-worktree test DB so concurrent `bin/test` runs across worktrees never collide.
# PROJECT_ROOT is set by bin/common before this file is sourced; the value is
# exported and flows to the JVM via db.conf's ${POSTGRES_DB}.
POSTGRES_DB=unicoach-test-$(basename "$PROJECT_ROOT")

# --- Application Configuration (deltas vs .env) ---
DATABASE_USER=postgres
DATABASE_MAXIMUM_POOL_SIZE=2
# Re-derived after PORT (which the harness may have overridden above).
SERVER_PORT=$PORT

# Select the offline Google token verifier for tests: startServer boots the
# stub verifier (no JWKS network access, no required clientIds), and
# GoogleAuthRoutingTest drives sign-in via the documented stub-token format.
# Absent from .env, so it must be stated here.
GOOGLE_AUTH_PROVIDER=stub
