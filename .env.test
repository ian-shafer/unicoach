PORT=8081
UNICOACH_NETWORK=unicoach-test-network

POSTGRES_USER=postgres
# Per-worktree test DB so concurrent `bin/test` runs across worktrees never collide.
# PROJECT_ROOT is set by bin/common before this file is sourced; the value is
# exported and flows to the JVM via db.conf's ${POSTGRES_DB}.
POSTGRES_DB=unicoach-test-$(basename "$PROJECT_ROOT")
POSTGRES_HOST_AUTH_METHOD=trust
PGHOST=localhost
# Shared absolute path: all worktrees share one cluster (see .env).
POSTGRES_DATA_DIR=$HOME/var/unicoach/postgres
POSTGRES_ADMIN_DB=postgres
POSTGRES_PORT=5432

# --- Application Configuration ---
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_MAXIMUM_POOL_SIZE=2
JWT_SECRET=test_secret
JWT_ISSUER=http://test/
JWT_AUDIENCE=http://test/
SERVER_PORT=$PORT
