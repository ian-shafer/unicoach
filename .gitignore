.gradle/
.kotlin/
build/
var/
!gradle/wrapper/gradle-wrapper.jar
*.swp
ios-app/UnicoachiOS.xcodeproj/project.xcworkspace/xcuserdata/ian.xcuserdatad/UserInterfaceState.xcuserstate

# Transient RFC-pipeline output (RFC backups, diff artifacts, build/test logs).
# Non-anchored so .scratch/ under any subdirectory (e.g. ios-app/.scratch/) is ignored.
.scratch/

# Deno lockfile regenerated on every deno run/eval (OpenAPI spec validation)
/deno.lock

# Per-developer iOS env files (signing.env, local.env, future personal envs)
# carry personal hosts/credentials and are ignored by default. The shared
# simulator env and the *.env.example templates stay tracked.
ios-app/env/*.env
!ios-app/env/*.env.example
!ios-app/env/simulator.env
