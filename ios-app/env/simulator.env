# Shared simulator environment (checked in).
#
# Sourced by bin/build-ios for UNICOACH_DESTINATION only. A simulator build is
# selected because UNICOACH_DESTINATION contains the substring "Simulator".
# Simulator builds do not sign, so no signing.env / UNICOACH_DEVELOPMENT_TEAM is
# required — a contributor without an Apple account can still run a simulator
# compile check.
#
# The backend URL is NOT set here: bin/build-ios derives it from APP_DOMAIN /
# SERVER_PORT in the repo .env (default http://localhost:8080), so the simulator
# reaches a server on the same Mac with zero configuration.
UNICOACH_DESTINATION="platform=iOS Simulator,name=iPhone 17 Pro"

# A target MAY instead set UNICOACH_BACKEND_URL explicitly to skip derivation;
# bin/build-ios then forwards that URL verbatim (e.g. an externally-terminated
# HTTPS URL with no port). See ios-app/env/prod-simulator.env
# (https://api.unicoachapp.com) for a simulator target that does exactly this.

# UNICOACH_CONFIGURATION is optional; bin/build-ios defaults it to Debug.
# Override the pinned simulator name in your own env file if that device model
# is not installed locally (xcrun simctl list devices).
