# Production deploy target — simulator (checked in).
#
# Builds UnicoachiOS against the live AWS deployment at
# https://api.unicoachapp.com from the iOS Simulator. A simulator build does
# not sign, so any contributor can build a simulator app targeting the live
# deployment without an Apple account / signing.env.
#
# UNICOACH_BACKEND_URL is set explicitly here, so bin/build-ios HONORS it
# verbatim and skips the http://$APP_DOMAIN:$SERVER_PORT derivation — the
# derived form cannot express an externally-terminated HTTPS URL with no port.
# The backend URL is not a secret, so this target is shareable and checked in.

UNICOACH_DESTINATION="generic/platform=iOS Simulator"
UNICOACH_BACKEND_URL="https://api.unicoachapp.com"
