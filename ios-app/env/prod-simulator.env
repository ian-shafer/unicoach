# Production deploy target — simulator (checked in).
#
# Builds UnicoachiOS against the live AWS deployment from the iOS Simulator. A
# simulator build does not sign, so any contributor can build a simulator app
# targeting the live deployment without an Apple account / signing.env.
#
# UNICOACH_DEPLOY makes bin/build-ios source .env.prod (the single source of the
# prod domain) and DERIVE UNICOACH_BACKEND_URL=https://api.$APP_DOMAIN. The api
# host is therefore NOT restated here — change the domain once in .env.prod.

UNICOACH_DESTINATION="generic/platform=iOS Simulator"
UNICOACH_DEPLOY=1
