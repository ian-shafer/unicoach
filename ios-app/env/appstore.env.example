# App Store Connect API credentials (template).
#
# Copy to ios-app/env/appstore.env (gitignored) and fill in. appstore.env is
# sourced by bin/release-ios on the UPLOAD path only (the default; --no-upload
# does not need it) to authenticate the TestFlight upload with an App Store
# Connect API key — no Apple-ID password, no keychain prompt.
#
# This file is the ACTUALLY-SECRET bucket of the three-bucket configuration
# model (alongside UNICOACH_CLIENT_KEY); the API key it points at can publish
# builds, so it is gitignored and must never be committed. One appstore.env is
# shared across all targets.
#
# Create the key once in App Store Connect → Users and Access → Integrations →
# App Store Connect API → generate an API key with the "App Manager" role. The
# page shows the Issuer ID (a UUID, shared by all keys) and the Key ID, and lets
# you download AuthKey_<KeyID>.p8 EXACTLY ONCE. Store the .p8 somewhere stable
# (e.g. ~/.appstoreconnect/private_keys/) and point UNICOACH_ASC_KEY_PATH at it.

# Key ID — the short identifier shown next to the key (e.g. ABC123XYZ9). Passed
# to xcodebuild as -authenticationKeyID.
UNICOACH_ASC_KEY_ID=ABC123XYZ9

# Issuer ID — the UUID shown at the top of the App Store Connect API page,
# shared by every key in the team. Passed to xcodebuild as
# -authenticationKeyIssuerID.
UNICOACH_ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000

# Absolute path to the downloaded AuthKey_<KeyID>.p8. Passed to xcodebuild as
# -authenticationKeyPath. Keep the file outside the repo.
UNICOACH_ASC_KEY_PATH=/Users/you/.appstoreconnect/private_keys/AuthKey_ABC123XYZ9.p8
