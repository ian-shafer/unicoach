# Per-developer on-device dev environment (template).
#
# Copy to ios-app/env/local.env (gitignored) and fill in. `local` is the default
# env for both bin/build-ios and bin/install-ios, so on a fresh clone they fail
# fast until you create this file.
#
# This file carries the build destination. The backend host is derived, not set
# here: bin/build-ios derives UNICOACH_BACKEND_URL from APP_DOMAIN / SERVER_PORT
# in the repo .env (the single source the server also reads). Set the deploy host
# once via APP_DOMAIN in .env — see ios-app/DEPLOY.md.

# Generic device destination: xcodebuild selects the connected iPhone.
UNICOACH_DESTINATION="generic/platform=iOS"

# Optional; defaults to Debug.
# UNICOACH_CONFIGURATION="Debug"

# A target MAY set UNICOACH_BACKEND_URL explicitly to skip the derivation and
# have bin/build-ios forward that URL verbatim — required for an
# externally-terminated HTTPS URL (no port) the derived http://host:port form
# cannot express. See ios-app/env/prod.env (https://api.unicoachapp.com) for the
# canonical example. Leave it unset here to keep the derived local-dev URL.
# UNICOACH_BACKEND_URL="https://api.unicoachapp.com"
