# Production deploy target — device (checked in).
#
# Builds UnicoachiOS against the live AWS deployment (HTTPS, TLS terminated at
# the ALB, no explicit port). This is a DEVICE target, so bin/build-ios still
# requires ios-app/env/signing.env (UNICOACH_DEVELOPMENT_TEAM) to sign the build.
#
# UNICOACH_DEPLOY makes bin/build-ios source .env.prod (the single source of the
# prod domain) and DERIVE UNICOACH_BACKEND_URL=https://api.$APP_DOMAIN. The api
# host is therefore NOT restated here — change the domain once in .env.prod.

UNICOACH_DESTINATION="generic/platform=iOS"
UNICOACH_DEPLOY=1
