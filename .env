PORT=8080
UNICOACH_NETWORK=unicoach-network

POSTGRES_USER=postgres
POSTGRES_DB=unicoach
POSTGRES_HOST_AUTH_METHOD=trust
# Shared absolute path so every git worktree uses the SAME cluster (one postgres
# on POSTGRES_PORT); isolation is per-database. Do NOT use a $PROJECT_ROOT path.
POSTGRES_DATA_DIR=$HOME/var/unicoach/postgres
POSTGRES_ADMIN_DB=postgres
PGHOST=localhost
POSTGRES_PORT=5432

# --- Application Configuration ---
DATABASE_USER=unicoach
DATABASE_PASSWORD=password
DATABASE_MAXIMUM_POOL_SIZE=10
JWT_SECRET=super_secret
JWT_ISSUER=http://0.0.0.0:8080/
SERVER_PORT=$PORT

# Single source of the deploy host. The server derives session.cookieDomain from
# it (rest-server.conf), and bin/build-ios derives the iOS backend URL
# (http://$APP_DOMAIN:${SERVER_PORT:-8080}) from the same value. Override once for
# on-device use (a DNS hostname; a bare IP is rejected at build). See
# ios-app/DEPLOY.md.
APP_DOMAIN=localhost
