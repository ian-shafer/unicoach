#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
docker-daemon-check <service-name> [options]

Verifies daemon health utilizing strict Docker label filtering.

Options:
  -h, --help: Help
EOF
  exit "$exit_code"
}

SERVICE_NAME=""

while [[ $# -gt 0 ]]; do
  case "$1" in
  -h|--help) help ;;
  *)
      if [[ "$1" == -* ]]; then
    fatal "Unknown option: $1"
      elif [ -z "$SERVICE_NAME" ]; then
    SERVICE_NAME="$1"
    shift
      else
    fatal "Unexpected argument: $1"
      fi
      ;;
  esac
done

if [ -z "$SERVICE_NAME" ]; then
  help "Missing required <service-name> argument."
fi

DOCKER_ARGS=("-f" "label=com.docker.compose.service=${SERVICE_NAME}" "-f" "status=running")

# Execute the filter. If matches are found, it returns a 
# newline-separated list of container IDs (e.g., '1a2b3c4d5e\nf6e5d4c3b2').
CONTAINERS=$(docker ps -q "${DOCKER_ARGS[@]}")

if [ -z "$CONTAINERS" ]; then
  log-info "Service [$SERVICE_NAME] is currently offline."
  exit 1
fi

# Check if the underlying container defines a native healthcheck
HAS_HEALTH=0
for id in $CONTAINERS; do
  if [ "$(docker inspect --format='{{if .State.Health}}true{{else}}false{{end}}' "$id")" = "true" ]; then
  HAS_HEALTH=1
  break
  fi
done

if [ "$HAS_HEALTH" -eq 1 ]; then
  # Augment evaluation to strictly require readiness
  CONTAINERS=$(docker ps -q "${DOCKER_ARGS[@]}" "-f" "health=healthy")
  if [ -z "$CONTAINERS" ]; then
    log-info "Service [$SERVICE_NAME] is running but currently reporting unhealthy."
    exit 1
  fi
fi

log-info "Service [$SERVICE_NAME] is running and healthy."
exit 0
