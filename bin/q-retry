#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
q-retry <job-id>

Resets a DEAD_LETTERED job back to SCHEDULED with scheduled_at = NOW().
Rejects jobs that are not in DEAD_LETTERED status.
EOF
}

while getopts ":h" opt; do
  case "$opt" in
  h) help; exit 0 ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -lt 1 ]; then
  fatal -s "$EXIT_MISSING_REQUIRED_ARG" "q-retry requires a <job-id> argument"
fi
if [ "$#" -gt 1 ]; then
  fatal -s "$EXIT_UNEXPECTED_ARG" "q-retry accepts exactly one <job-id>; received: $*"
fi

job_id="$1"

status=$(echo "SELECT status FROM jobs WHERE id = '$job_id';" | "$PROJECT_ROOT/bin/db-query" -r) || exit 2

if [ -z "$status" ]; then
  fatal "Job [$job_id] not found"
fi

if [ "$status" != "DEAD_LETTERED" ]; then
  fatal "Job [$job_id] is not in DEAD_LETTERED status (current: [$status])"
fi

echo "UPDATE jobs SET status = 'SCHEDULED', scheduled_at = NOW() WHERE id = '$job_id';" | "$PROJECT_ROOT/bin/db-write" || exit 2
