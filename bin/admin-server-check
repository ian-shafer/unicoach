#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
admin-server-check [options]

Exits 0 if the admin-server is healthy (GET /healthz returns HTTP 200).
Exits non-zero if the server is not reachable or returns an error.

Exit codes:
  0: Healthy (HTTP 200).
  1: Not running (port free, nothing listening).
  2: The port is held by another process not responding as admin-server.

Options:
  -h: Help
EOF
  exit "$exit_code"
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) fatal "unknown option [-$OPTARG]" ;;
  :)  fatal "option -$OPTARG requires an argument" ;;
  esac
done
shift $((OPTIND-1))

exec "$PROJECT_ROOT/bin/daemon-http-check" admin-server "${ADMIN_SERVER_PORT:-8081}" "http://localhost:${ADMIN_SERVER_PORT:-8081}/healthz"
