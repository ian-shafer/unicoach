#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
file-lock [options] <lock-dir> <max-lock-duration>

Options:
  -h: Help
  -o OP        Operation name written to <lock-dir>/op
  -t TIMEOUT   Wait up to this duration to acquire the lock

Exit codes:
  0: Lock acquired.
  1: Lock held by another, non-matching operation.
  2: Lock metadata could not be read.
  3: Lock already held by a matching operation (-o matches the current holder).
EOF
  exit 0
}

OP=""
TIMEOUT=""

while getopts ":ho:t:" opt; do
  case "$opt" in
  h) help ;;
  o) OP="$OPTARG" ;;
  t) TIMEOUT="$OPTARG" ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -ne 2 ]; then
  fatal -s "$EXIT_MISSING_REQUIRED_ARG" "Invalid number of arguments. Expected 2 (<lock-dir> and <max-lock-duration>), but received $#."
fi

LOCK_DIR="$1"
MAX_DURATION_STR="$2"

MAX_DURATION=$(parse-duration-to-seconds "$MAX_DURATION_STR" || echo "")
if [ -z "$MAX_DURATION" ]; then
  fatal -s "$EXIT_INVALID_ARG_VALUE" "Invalid max-lock-duration format [$MAX_DURATION_STR]. Expected a number optionally followed by s, m, h, or d."
fi

if [ -n "$TIMEOUT" ]; then
  # Fast fail explicitly matching operations before entering polling wait sequence
  if [ -r "$LOCK_DIR/op" ]; then
  CURRENT_OP=$(read-file-or-die "$LOCK_DIR/op" 2)
  if [ -n "$OP" ] && [ "$CURRENT_OP" = "$OP" ]; then
      exit 3
  fi
  fi
  # Delegate to wait-for. The omission of -t ensures the delegated process only tries once
  ARGS=("$0")
  if [ -n "$OP" ]; then
  ARGS+=("-o" "$OP")
  fi
  ARGS+=("$LOCK_DIR" "$MAX_DURATION_STR")
  "$PROJECT_ROOT/bin/wait-for" "$TIMEOUT" "${ARGS[@]}"
  exit "$?"
fi

NOW=$(date +%s)
EXPIRES=$((NOW + MAX_DURATION))

# Ensure the parent directory exists so atomic mkdir does not fail due to a missing parent path
mkdir -p "$(dirname "$LOCK_DIR")"

while true; do
  if mkdir "$LOCK_DIR" 2>/dev/null; then
  if [ -n "$OP" ]; then
      echo "$OP" > "$LOCK_DIR/op"
  fi
  echo "$EXPIRES" > "$LOCK_DIR/expires-at"
  break
  fi

  # Lock already exists
  CURRENT_EXPIRES=$(read-file-or-die "$LOCK_DIR/expires-at" 2)

  if [ "$NOW" -ge "$CURRENT_EXPIRES" ]; then
  log-warning "Lock at $LOCK_DIR is stale (expired at $CURRENT_EXPIRES). Breaking lock."
  mv "$LOCK_DIR" "${LOCK_DIR}.stale.$$" 2>/dev/null || true
  continue
  fi

  # Active, non-stale lock exists. Validate operation match.
  if [ -r "$LOCK_DIR/op" ]; then
  CURRENT_OP=$(read-file-or-die "$LOCK_DIR/op" 2)
  if [ -n "$OP" ] && [ "$CURRENT_OP" = "$OP" ]; then
      exit 3
  fi
  fi

  exit 1
done

exit 0
