#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
docker-daemon-restart [options] <service-name>

Sequentially invokes docker-daemon-stop then docker-daemon-start for a seamless restart.

Options:
  --nonce                   Passed to start command
  -h, --help: Help
  -d, --docker-down         Passed to stop command
  --wipe-data               Passed to stop command
EOF
  exit "$exit_code"
}

SERVICE_NAME=""
STOP_ARGS=()
START_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
  -h|--help) help ;;
  --nonce) START_ARGS+=("--nonce"); shift ;;
  -d|--docker-down) STOP_ARGS+=("-d"); shift ;;
  --wipe-data) STOP_ARGS+=("--wipe-data"); shift ;;
  -*) fatal "Unknown option: $1" ;;
  *) break ;;
  esac
done

if [ "$#" -lt 1 ]; then
  help "Missing required <service-name> argument."
fi
SERVICE_NAME="$1"
shift

if [ "$#" -gt 0 ]; then
  fatal "Unexpected arguments: $*"
fi

if [ ${#STOP_ARGS[@]} -gt 0 ]; then
  "$PROJECT_ROOT/bin/docker-daemon-stop" "$SERVICE_NAME" "${STOP_ARGS[@]}"
else
  "$PROJECT_ROOT/bin/docker-daemon-stop" "$SERVICE_NAME"
fi
if [ ${#START_ARGS[@]} -gt 0 ]; then
  "$PROJECT_ROOT/bin/docker-daemon-start" "${START_ARGS[@]}" "$SERVICE_NAME"
else
  "$PROJECT_ROOT/bin/docker-daemon-start" "$SERVICE_NAME"
fi
