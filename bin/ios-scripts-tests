#!/usr/bin/env bash
# ios-scripts-tests exercises bin/is-nix, bin/build-ios, bin/install-ios, and
# bin/release-ios WITHOUT any real Xcode build or hardware. xcodebuild and xcrun
# are shimmed onto
# PATH via a temp dir; the shims record their argv to a file the assertions
# inspect. The ios-app/env/<env>.env files are pointed at a temp fixture dir via
# UNICOACH_ENV_DIR, and the repo .env (the APP_DOMAIN/SERVER_PORT source) is
# pointed at a temp fixture file via UNICOACH_DOTENV, so the assertions drive the
# DERIVED UNICOACH_BACKEND_URL without touching the real .env.
#
# Sources ONLY bin/functions and bin/tests-common — no bin/common, no Postgres,
# no Nix dev shell (these scripts run under system Xcode, not the dev shell).
set -euo pipefail

# Make happy-path cases deterministic even when this harness is itself launched
# via `nix develop -c`: clear the inside-Nix marker. "Inside Nix" is simulated
# per-invocation by prefixing a script call with IN_NIX_SHELL=impure (an
# external-command assignment, so it scopes to that child only).
unset IN_NIX_SHELL

THIS_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$THIS_DIR/.." && pwd)"
source "$THIS_DIR/functions"
source "$THIS_DIR/tests-common"

TMP_BASE="${TMPDIR:-/tmp}"
mkdir -p "$TMP_BASE"
WORK="$(mktemp -d "$TMP_BASE/unicoach-ios-scripts-tests.XXXXXX")"
trap 'rm -rf "$WORK" >/dev/null 2>&1 || true' EXIT INT TERM

SHIM_DIR="$WORK/shims"
ENV_DIR="$WORK/env"
PRODUCTS_DIR="$WORK/products"
ARGV_LOG="$WORK/argv.log"
DOTENV="$WORK/dotenv"
mkdir -p "$SHIM_DIR" "$ENV_DIR" "$PRODUCTS_DIR"

# --- Shims -------------------------------------------------------------------
# xcodebuild: record every arg (one per line) prefixed with "xcodebuild", succeed.
cat > "$SHIM_DIR/xcodebuild" <<EOF
#!/usr/bin/env bash
{ echo "xcodebuild"; for a in "\$@"; do echo "\$a"; done; } >> "$ARGV_LOG"
exit 0
EOF

# xcrun: record argv, succeed. For "devicectl list devices" it prints whatever
# the per-test DEVICECTL_LIST_OUTPUT fixture file holds, so device auto-detect
# can be driven to 0/1/2 devices without hardware.
cat > "$SHIM_DIR/xcrun" <<EOF
#!/usr/bin/env bash
{ echo "xcrun"; for a in "\$@"; do echo "\$a"; done; } >> "$ARGV_LOG"
if [ "\${1:-}" = "devicectl" ] && [ "\${2:-}" = "list" ] && [ "\${3:-}" = "devices" ]; then
  if [ -n "\${DEVICECTL_LIST_OUTPUT:-}" ] && [ -f "\${DEVICECTL_LIST_OUTPUT}" ]; then
    cat "\${DEVICECTL_LIST_OUTPUT}"
  fi
fi
exit 0
EOF
chmod +x "$SHIM_DIR/xcodebuild" "$SHIM_DIR/xcrun"

# --- Fixtures ----------------------------------------------------------------
# Env files now carry ONLY the destination; the backend URL is derived from the
# .env fixture's APP_DOMAIN/SERVER_PORT.
cat > "$ENV_DIR/simulator.env" <<'EOF'
UNICOACH_DESTINATION="platform=iOS Simulator,name=iPhone 17 Pro"
EOF

cat > "$ENV_DIR/device.env" <<'EOF'
UNICOACH_DESTINATION="generic/platform=iOS"
EOF

# Target fixtures that set an EXPLICIT UNICOACH_BACKEND_URL (honor path). The
# canonical no-path HTTPS deploy URL on a simulator destination (no signing) and
# on a device destination (requires signing.env).
cat > "$ENV_DIR/explicit-simulator.env" <<'EOF'
UNICOACH_DESTINATION="generic/platform=iOS Simulator"
UNICOACH_BACKEND_URL="https://api.uni.coach"
EOF

cat > "$ENV_DIR/explicit-device.env" <<'EOF'
UNICOACH_DESTINATION="generic/platform=iOS"
UNICOACH_BACKEND_URL="https://api.uni.coach"
EOF

# A target whose explicit URL carries a trailing-slash path and no port, to
# prove byte-for-byte passthrough of an arbitrary URL shape.
cat > "$ENV_DIR/explicit-trailing-slash.env" <<'EOF'
UNICOACH_DESTINATION="generic/platform=iOS Simulator"
UNICOACH_BACKEND_URL="https://api.uni.coach/"
EOF

# A device target that ALSO sets UNICOACH_CONFIGURATION=Debug, to prove
# release-ios ignores it and forces Release.
cat > "$ENV_DIR/debug-config-device.env" <<'EOF'
UNICOACH_DESTINATION="generic/platform=iOS"
UNICOACH_CONFIGURATION="Debug"
UNICOACH_BACKEND_URL="https://api.uni.coach"
EOF

# Deploy targets: UNICOACH_DEPLOY=1 and NO explicit UNICOACH_BACKEND_URL, so
# bin/build-ios DERIVES https://api.$APP_DOMAIN from the dotenv (the committed
# prod / prod-simulator targets work this way). The dotenv is the per-test
# UNICOACH_DOTENV fixture, so write_dotenv "<apex>" drives the derivation.
cat > "$ENV_DIR/deploy-simulator.env" <<'EOF'
UNICOACH_DESTINATION="generic/platform=iOS Simulator"
UNICOACH_DEPLOY=1
EOF

cat > "$ENV_DIR/deploy-device.env" <<'EOF'
UNICOACH_DESTINATION="generic/platform=iOS"
UNICOACH_DEPLOY=1
EOF

# Write the repo-.env fixture that bin/build-ios sources (via UNICOACH_DOTENV).
# Args: APP_DOMAIN value (empty => omit the line), optional SERVER_PORT value.
write_dotenv() {
  : > "$DOTENV"
  if [ -n "${1:-}" ]; then
    echo "APP_DOMAIN=$1" >> "$DOTENV"
  fi
  if [ -n "${2:-}" ]; then
    echo "SERVER_PORT=$2" >> "$DOTENV"
  fi
}

FIXTURE_TEAM="TEAMFIXTURE9"
write_signing_env() {
  cat > "$ENV_DIR/signing.env" <<EOF
UNICOACH_DEVELOPMENT_TEAM=$FIXTURE_TEAM
EOF
}
write_signing_env_with_device() {
  cat > "$ENV_DIR/signing.env" <<EOF
UNICOACH_DEVELOPMENT_TEAM=$FIXTURE_TEAM
UNICOACH_DEVICE=$1
EOF
}

# Stage a Debug-iphoneos UnicoachiOS.app so install-ios finds a built app.
stage_built_app() {
  mkdir -p "$PRODUCTS_DIR/Debug-iphoneos/UnicoachiOS.app"
}

# App Store Connect API credentials fixture for release-ios upload tests, plus
# the .p8 key file release-ios checks for existence.
ASC_KEY_ID="KEYID123"
ASC_ISSUER_ID="11111111-2222-3333-4444-555555555555"
ASC_KEY_PATH="$ENV_DIR/AuthKey_$ASC_KEY_ID.p8"
write_appstore_env() {
  cat > "$ENV_DIR/appstore.env" <<EOF
UNICOACH_ASC_KEY_ID=$ASC_KEY_ID
UNICOACH_ASC_ISSUER_ID=$ASC_ISSUER_ID
UNICOACH_ASC_KEY_PATH=$ASC_KEY_PATH
EOF
  : > "$ASC_KEY_PATH"
}

# Where release-ios writes its archive/export artifacts in tests (redirected out
# of the real repo via UNICOACH_BUILD_DIR).
RELEASE_BUILD_DIR="$WORK/iosbuild"
EXPORT_OPTIONS_PLIST="$RELEASE_BUILD_DIR/export/ExportOptions.plist"

# Two-device devicectl output fixture for the ambiguous-device case.
TWO_DEVICES="$WORK/two-devices.txt"
cat > "$TWO_DEVICES" <<'EOF'
Devices:
iPhone A (model)  00000000-1111111111111111  available
iPhone B (model)  22222222-3333333333333333  available
EOF

reset_log() { : > "$ARGV_LOG"; }

# Run a bin script with the shims first on PATH and env/products overrides set.
# IN_NIX is honoured to simulate the dev shell for the guard cases: when set, it
# is exported into the child as IN_NIX_SHELL ONLY for that invocation.
# nix_prefix emits the `env`-style argument that simulates the dev shell for a
# single child: `IN_NIX_SHELL=<IN_NIX>` when IN_NIX is set, nothing otherwise.
# `env -u` cannot be used unconditionally because the harness already unset the
# var; the empty expansion simply contributes no argument.
run_build() {
  reset_log
  env PATH="$SHIM_DIR:$PATH" \
    UNICOACH_ENV_DIR="$ENV_DIR" \
    UNICOACH_DOTENV="$DOTENV" \
    ${IN_NIX:+IN_NIX_SHELL="$IN_NIX"} \
    "$PROJECT_ROOT/bin/build-ios" "$@"
}
run_install() {
  reset_log
  env PATH="$SHIM_DIR:$PATH" \
    UNICOACH_ENV_DIR="$ENV_DIR" \
    UNICOACH_PRODUCTS_DIR="$PRODUCTS_DIR" \
    DEVICECTL_LIST_OUTPUT="${DEVICECTL_LIST_OUTPUT:-}" \
    ${IN_NIX:+IN_NIX_SHELL="$IN_NIX"} \
    "$PROJECT_ROOT/bin/install-ios" "$@"
}
# Run release-ios with the shims first on PATH, artifacts redirected into a temp
# build dir, and the build number pinned (so the assertion does not depend on
# the repo's real commit count). RELEASE_BUILD_NUMBER may be set to the empty
# string by a caller to exercise the git-derived path instead.
run_release() {
  reset_log
  env PATH="$SHIM_DIR:$PATH" \
    UNICOACH_ENV_DIR="$ENV_DIR" \
    UNICOACH_DOTENV="$DOTENV" \
    UNICOACH_BUILD_DIR="$RELEASE_BUILD_DIR" \
    UNICOACH_BUILD_NUMBER="${RELEASE_BUILD_NUMBER-7}" \
    ${IN_NIX:+IN_NIX_SHELL="$IN_NIX"} \
    "$PROJECT_ROOT/bin/release-ios" "$@"
}

# Run bin/is-nix directly, honouring IN_NIX as the simulated marker.
run_is_nix() {
  env ${IN_NIX:+IN_NIX_SHELL="$IN_NIX"} "$PROJECT_ROOT/bin/is-nix" "$@"
}

# Assert a literal line is present in the recorded argv log. `--` guards patterns
# that begin with a dash (e.g. -allowProvisioningUpdates) from being parsed as
# grep flags.
log_has() { grep -Fxq -e "$1" "$ARGV_LOG"; }
# Assert a literal line is ABSENT from the recorded argv log.
log_lacks() { ! grep -Fxq -e "$1" "$ARGV_LOG"; }
# Assert the argv log records NO invocation of the named tool (its prefix line).
log_no_tool() { ! grep -Fxq -e "$1" "$ARGV_LOG"; }

# Assert a literal substring is present in the generated ExportOptions.plist
# (release-ios writes it to a known path under the temp build dir).
export_option_has() { grep -Fq -e "$1" "$EXPORT_OPTIONS_PLIST"; }

# ============================== is-nix tests =================================

test_isnix_quiet_inside() {
  local out
  out="$(IN_NIX=impure run_is_nix -q 2>&1)" && local rc=0 || local rc=$?
  [ "$rc" -eq 0 ] || return 1
  [ -z "$out" ] || return 1
  return 0
}

test_isnix_quiet_outside() {
  local out rc
  out="$(run_is_nix -q 2>&1)" && rc=0 || rc=$?
  [ "$rc" -eq 1 ] || return 1
  [ -z "$out" ] || return 1
  return 0
}

test_isnix_default_inside() {
  local out rc
  out="$(IN_NIX=impure run_is_nix 2>&1)" && rc=0 || rc=$?
  [ "$rc" -eq 0 ] || return 1
  echo "$out" | grep -q "nix enabled"
}

test_isnix_default_outside() {
  local out rc
  out="$(run_is_nix 2>&1)" && rc=0 || rc=$?
  [ "$rc" -eq 1 ] || return 1
  echo "$out" | grep -q "nix NOT enabled"
}

test_isnix_verbose_lists_packages() {
  local out rc
  out="$(IN_NIX_SHELL=impure nativeBuildInputs="/nix/store/abc123-foo-1.0 /nix/store/def456-bar-2.0" \
    "$PROJECT_ROOT/bin/is-nix" -v 2>&1)" && rc=0 || rc=$?
  [ "$rc" -eq 0 ] || return 1
  echo "$out" | grep -qx "foo-1.0" || return 1
  echo "$out" | grep -qx "bar-2.0" || return 1
  return 0
}

test_isnix_bogus_option() {
  local out rc
  out="$("$PROJECT_ROOT/bin/is-nix" --bogus 2>&1)" && rc=0 || rc=$?
  [ "$rc" -ne 0 ] || return 1
  echo "$out" | grep -qi "unknown option"
}

# ========================== dev-shell guard tests ============================

test_build_guard_simulator() {
  write_dotenv ""   # localhost default
  local out rc
  out="$(IN_NIX=impure run_build simulator 2>&1)" && rc=0 || rc=$?
  [ "$rc" -ne 0 ] || return 1
  echo "$out" | grep -q "build-ios" || return 1
  echo "$out" | grep -qi "system Xcode" || return 1
  # Guard fires before any tool: no xcodebuild line recorded.
  log_no_tool "xcodebuild"
}

test_build_guard_precedence_over_missing_env() {
  # Even with a nonexistent env (which would normally be the failure), the guard
  # message must win because it precedes env resolution.
  local out rc
  out="$(IN_NIX=impure run_build nonexistent-env 2>&1)" && rc=0 || rc=$?
  [ "$rc" -ne 0 ] || return 1
  echo "$out" | grep -qi "system Xcode" || return 1
  # Must NOT be the missing-env message.
  if echo "$out" | grep -q "nonexistent-env.env"; then return 1; fi
  log_no_tool "xcodebuild"
}

test_install_guard_device() {
  write_signing_env
  stage_built_app
  local out rc
  out="$(IN_NIX=impure run_install device 2>&1)" && rc=0 || rc=$?
  [ "$rc" -ne 0 ] || return 1
  echo "$out" | grep -q "install-ios" || return 1
  echo "$out" | grep -qi "system Xcode" || return 1
  log_no_tool "xcrun"
}

# ============================ build-ios tests ================================

test_build_missing_env_file() {
  write_dotenv ""
  local out
  if out="$(run_build nonexistent-env 2>&1)"; then return 1; fi
  echo "$out" | grep -q "nonexistent-env.env"
}

test_build_device_env_absent_signing() {
  write_dotenv "mymac.example.ts.net"
  rm -f "$ENV_DIR/signing.env"
  local out
  if out="$(run_build device 2>&1)"; then return 1; fi
  echo "$out" | grep -q "signing.env"
}

test_build_device_env_absent_team() {
  write_dotenv "mymac.example.ts.net"
  # signing.env present but with no team.
  cat > "$ENV_DIR/signing.env" <<'EOF'
UNICOACH_DEVELOPMENT_TEAM=
EOF
  local out
  if out="$(run_build device 2>&1)"; then return 1; fi
  echo "$out" | grep -q "UNICOACH_DEVELOPMENT_TEAM"
}

test_build_simulator_no_signing() {
  write_dotenv ""   # unset APP_DOMAIN => localhost default
  rm -f "$ENV_DIR/signing.env"
  run_build simulator >/dev/null 2>&1 || return 1
  log_has "platform=iOS Simulator,name=iPhone 17 Pro" || return 1
  # Backend URL is DERIVED from the .env fixture (localhost default).
  log_has "UNICOACH_BACKEND_URL=http://localhost:8080" || return 1
  # Signing must NOT be forwarded for a simulator build.
  log_lacks "CODE_SIGN_STYLE=Automatic" || return 1
  log_lacks "-allowProvisioningUpdates" || return 1
  if grep -q "^DEVELOPMENT_TEAM=" "$ARGV_LOG"; then return 1; fi
  return 0
}

test_build_device_forwards_signing() {
  write_dotenv "mymac.example.ts.net"
  write_signing_env
  run_build device >/dev/null 2>&1 || return 1
  log_has "generic/platform=iOS" || return 1
  log_has "DEVELOPMENT_TEAM=$FIXTURE_TEAM" || return 1
  log_has "CODE_SIGN_STYLE=Automatic" || return 1
  log_has "-allowProvisioningUpdates" || return 1
  # Backend URL is DERIVED from APP_DOMAIN in the .env fixture.
  log_has "UNICOACH_BACKEND_URL=http://mymac.example.ts.net:8080" || return 1
  return 0
}

test_build_derives_port_from_server_port() {
  write_dotenv "mymac.example.ts.net" "9090"
  write_signing_env
  run_build device >/dev/null 2>&1 || return 1
  log_has "UNICOACH_BACKEND_URL=http://mymac.example.ts.net:9090" || return 1
  return 0
}

test_build_bare_ip_rejected() {
  write_dotenv "192.168.1.42"
  write_signing_env
  local out
  if out="$(run_build device 2>&1)"; then return 1; fi
  echo "$out" | grep -qi "DNS hostname" || return 1
  # Rejected before any build.
  log_no_tool "xcodebuild"
}

# Honor path: an explicit UNICOACH_BACKEND_URL in the target file is forwarded
# verbatim and BEATS derivation. The .env fixture sets a different APP_DOMAIN
# that the derive path WOULD have used.
test_build_honors_explicit_backend_url() {
  write_dotenv "mymac.example.ts.net"
  rm -f "$ENV_DIR/signing.env"
  run_build explicit-simulator >/dev/null 2>&1 || return 1
  # Explicit HTTPS URL (no port) forwarded verbatim.
  log_has "UNICOACH_BACKEND_URL=https://api.uni.coach" || return 1
  # The derived http://host:port form was NOT used.
  log_lacks "UNICOACH_BACKEND_URL=http://mymac.example.ts.net:8080" || return 1
  return 0
}

# Honor path forwards an arbitrary URL shape byte-for-byte: a trailing-slash
# path and no port survive unchanged.
test_build_honors_explicit_url_passthrough_fidelity() {
  write_dotenv "mymac.example.ts.net"
  rm -f "$ENV_DIR/signing.env"
  run_build explicit-trailing-slash >/dev/null 2>&1 || return 1
  log_has "UNICOACH_BACKEND_URL=https://api.uni.coach/" || return 1
  return 0
}

# Honor path short-circuits the derive-only bare-IP check: a bare-IP APP_DOMAIN
# in .env (which the derive path rejects) does NOT break an explicit-URL build.
test_build_explicit_url_skips_bare_ip_check() {
  write_dotenv "192.168.1.42"
  rm -f "$ENV_DIR/signing.env"
  run_build explicit-simulator >/dev/null 2>&1 || return 1
  log_has "UNICOACH_BACKEND_URL=https://api.uni.coach" || return 1
  return 0
}

# Honor path works on the device path: an explicit URL is honored AND the
# signing args are still forwarded.
test_build_explicit_url_device_forwards_signing() {
  write_dotenv "mymac.example.ts.net"
  write_signing_env
  run_build explicit-device >/dev/null 2>&1 || return 1
  log_has "UNICOACH_BACKEND_URL=https://api.uni.coach" || return 1
  log_has "DEVELOPMENT_TEAM=$FIXTURE_TEAM" || return 1
  log_has "CODE_SIGN_STYLE=Automatic" || return 1
  log_has "-allowProvisioningUpdates" || return 1
  return 0
}

# Regression: with UNICOACH_BACKEND_URL unset in the target file, the build
# takes the DERIVE path and composes http://$APP_DOMAIN:$SERVER_PORT from .env.
test_build_derives_when_url_unset() {
  write_dotenv "mymac.example.ts.net"
  rm -f "$ENV_DIR/signing.env"
  run_build simulator >/dev/null 2>&1 || return 1
  # device.env / simulator.env set no UNICOACH_BACKEND_URL, so derivation runs.
  log_has "UNICOACH_BACKEND_URL=http://mymac.example.ts.net:8080" || return 1
  log_lacks "UNICOACH_BACKEND_URL=https://api.uni.coach" || return 1
  return 0
}

# The committed deploy targets (the REAL ios-app/env/prod*.env, not fixtures)
# are well-formed: each sets UNICOACH_DEPLOY (so the backend URL DERIVES from
# .env.prod) and does NOT hardcode UNICOACH_BACKEND_URL; prod is a device
# destination and prod-simulator a simulator destination; neither sets a client
# key. The api host must live in exactly one place (.env.prod), never restated
# in a target file.
test_prod_targets_committed_and_wellformed() {
  local prod="$PROJECT_ROOT/ios-app/env/prod.env"
  local prod_sim="$PROJECT_ROOT/ios-app/env/prod-simulator.env"
  [ -f "$prod" ] || return 1
  [ -f "$prod_sim" ] || return 1

  local deploy url dest key
  deploy="$(set -a; source "$prod"; set +a; printf '%s' "${UNICOACH_DEPLOY:-}")"
  [ -n "$deploy" ] || return 1
  url="$(set -a; source "$prod"; set +a; printf '%s' "${UNICOACH_BACKEND_URL:-}")"
  [ -z "$url" ] || return 1
  dest="$(set -a; source "$prod"; set +a; printf '%s' "${UNICOACH_DESTINATION:-}")"
  case "$dest" in *Simulator*) return 1 ;; esac
  key="$(set -a; source "$prod"; set +a; printf '%s' "${UNICOACH_CLIENT_KEY:-}")"
  [ -z "$key" ] || return 1

  deploy="$(set -a; source "$prod_sim"; set +a; printf '%s' "${UNICOACH_DEPLOY:-}")"
  [ -n "$deploy" ] || return 1
  url="$(set -a; source "$prod_sim"; set +a; printf '%s' "${UNICOACH_BACKEND_URL:-}")"
  [ -z "$url" ] || return 1
  dest="$(set -a; source "$prod_sim"; set +a; printf '%s' "${UNICOACH_DESTINATION:-}")"
  case "$dest" in *Simulator*) ;; *) return 1 ;; esac
  key="$(set -a; source "$prod_sim"; set +a; printf '%s' "${UNICOACH_CLIENT_KEY:-}")"
  [ -z "$key" ] || return 1

  return 0
}

# .env.prod is the single source of the prod domain: it defines a non-empty,
# non-bare-IP APP_DOMAIN apex from which every consumer derives.
test_env_prod_is_single_domain_source() {
  local envprod="$PROJECT_ROOT/.env.prod"
  [ -f "$envprod" ] || return 1
  local domain
  domain="$(set -a; source "$envprod"; set +a; printf '%s' "${APP_DOMAIN:-}")"
  [ -n "$domain" ] || return 1
  # Apex must be a DNS name, not a bare IPv4/IPv6 literal (invalid cookie Domain).
  if [[ "$domain" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]] || [[ "$domain" == *:* ]]; then
    return 1
  fi
  return 0
}

# Deploy derivation (simulator): UNICOACH_DEPLOY with no explicit URL bakes
# https://api.$APP_DOMAIN — HTTPS, api. subdomain, no port — from the dotenv.
test_build_deploy_derives_https() {
  write_dotenv "uni.coach"
  rm -f "$ENV_DIR/signing.env"
  run_build deploy-simulator >/dev/null 2>&1 || return 1
  log_has "UNICOACH_BACKEND_URL=https://api.uni.coach" || return 1
  # The local http://host:port form was NOT used.
  log_lacks "UNICOACH_BACKEND_URL=http://uni.coach:8080" || return 1
  return 0
}

# Deploy derivation (device): same HTTPS derivation, and signing is still
# forwarded for a device destination.
test_build_deploy_derives_https_device() {
  write_dotenv "uni.coach"
  write_signing_env
  run_build deploy-device >/dev/null 2>&1 || return 1
  log_has "UNICOACH_BACKEND_URL=https://api.uni.coach" || return 1
  log_has "DEVELOPMENT_TEAM=$FIXTURE_TEAM" || return 1
  return 0
}

# The deploy derivation tracks APP_DOMAIN: a different apex yields a different
# api host, proving the domain is not hardcoded in the deploy path.
test_build_deploy_tracks_app_domain() {
  write_dotenv "example.test"
  rm -f "$ENV_DIR/signing.env"
  run_build deploy-simulator >/dev/null 2>&1 || return 1
  log_has "UNICOACH_BACKEND_URL=https://api.example.test" || return 1
  return 0
}

# The deploy path still rejects a bare-IP apex (an invalid cookie Domain).
test_build_deploy_bare_ip_rejected() {
  write_dotenv "10.0.0.5"
  rm -f "$ENV_DIR/signing.env"
  local out
  if out="$(run_build deploy-simulator 2>&1)"; then return 1; fi
  echo "$out" | grep -qi "DNS hostname" || return 1
  log_no_tool "xcodebuild"
}

# The gitignore allowlist tracks the committed prod targets while a control
# throwaway target stays ignored.
test_prod_targets_not_gitignored() {
  git -C "$PROJECT_ROOT" check-ignore -q ios-app/env/prod.env && return 1
  git -C "$PROJECT_ROOT" check-ignore -q ios-app/env/prod-simulator.env && return 1
  git -C "$PROJECT_ROOT" check-ignore -q ios-app/env/throwaway.env || return 1
  return 0
}

# ============================ install-ios tests =============================

test_install_no_built_app() {
  write_signing_env
  rm -rf "$PRODUCTS_DIR/Debug-iphoneos"
  local out
  if out="$(run_install device 2>&1)"; then return 1; fi
  echo "$out" | grep -q "build-ios"
}

test_install_simulator_env_rejected() {
  write_signing_env
  stage_built_app
  local out
  if out="$(run_install simulator 2>&1)"; then return 1; fi
  echo "$out" | grep -qi "simulator"
}

test_install_device_absent_signing() {
  stage_built_app
  rm -f "$ENV_DIR/signing.env"
  local out
  if out="$(run_install device 2>&1)"; then return 1; fi
  echo "$out" | grep -q "signing.env"
}

test_install_with_device_set() {
  local udid="DEADBEEF-0000111122223333"
  write_signing_env_with_device "$udid"
  stage_built_app
  run_install device >/dev/null 2>&1 || return 1
  log_has "install" || return 1
  log_has "app" || return 1
  log_has "--device" || return 1
  log_has "$udid" || return 1
  log_has "$PRODUCTS_DIR/Debug-iphoneos/UnicoachiOS.app" || return 1
  # No -l passed, so no process-launch invocation recorded.
  if grep -Fxq "launch" "$ARGV_LOG" && grep -Fxq "coach.uni.UnicoachiOS" "$ARGV_LOG"; then
    return 1
  fi
  return 0
}

test_install_with_launch() {
  local udid="DEADBEEF-0000111122223333"
  write_signing_env_with_device "$udid"
  stage_built_app
  run_install -l device >/dev/null 2>&1 || return 1
  log_has "install" || return 1
  log_has "process" || return 1
  log_has "launch" || return 1
  log_has "coach.uni.UnicoachiOS" || return 1
  return 0
}

test_install_ambiguous_device() {
  write_signing_env   # no UNICOACH_DEVICE -> auto-detect
  stage_built_app
  local out
  if out="$(DEVICECTL_LIST_OUTPUT="$TWO_DEVICES" run_install device 2>&1)"; then return 1; fi
  echo "$out" | grep -qi "multiple"
}

# ============================ release-ios tests ============================

test_release_guard_device() {
  write_signing_env
  write_appstore_env
  local out rc
  out="$(IN_NIX=impure run_release explicit-device 2>&1)" && rc=0 || rc=$?
  [ "$rc" -ne 0 ] || return 1
  echo "$out" | grep -q "release-ios" || return 1
  echo "$out" | grep -qi "system Xcode" || return 1
  # Guard fires before any tool: no xcodebuild line recorded.
  log_no_tool "xcodebuild"
}

test_release_missing_env_file() {
  local out
  if out="$(run_release nonexistent-env 2>&1)"; then return 1; fi
  echo "$out" | grep -q "nonexistent-env.env" || return 1
  log_no_tool "xcodebuild"
}

test_release_simulator_rejected() {
  write_signing_env
  write_appstore_env
  local out
  # explicit-simulator has UNICOACH_DESTINATION containing "Simulator".
  if out="$(run_release explicit-simulator 2>&1)"; then return 1; fi
  echo "$out" | grep -qi "simulator" || return 1
  log_no_tool "xcodebuild"
}

test_release_absent_signing() {
  rm -f "$ENV_DIR/signing.env"
  write_appstore_env
  local out
  if out="$(run_release explicit-device 2>&1)"; then return 1; fi
  echo "$out" | grep -q "signing.env" || return 1
  log_no_tool "xcodebuild"
}

# -n (no-upload): archives Release for a generic device, signs, injects the build
# number and honored backend URL, exports a local .ipa, and needs NO appstore.env
# and NO upload auth flags.
test_release_no_upload_archives_and_exports() {
  write_signing_env
  rm -f "$ENV_DIR/appstore.env"   # not required on the -n path
  run_release -n explicit-device >/dev/null 2>&1 || return 1
  log_has "archive" || return 1
  log_has "-exportArchive" || return 1
  log_has "-configuration" || return 1
  log_has "Release" || return 1
  log_has "generic/platform=iOS" || return 1
  log_has "DEVELOPMENT_TEAM=$FIXTURE_TEAM" || return 1
  log_has "CODE_SIGN_STYLE=Automatic" || return 1
  log_has "-allowProvisioningUpdates" || return 1
  log_has "UNICOACH_BACKEND_URL=https://api.uni.coach" || return 1
  log_has "CURRENT_PROJECT_VERSION=7" || return 1
  # No upload auth, and the export options select local export.
  log_lacks "-authenticationKeyID" || return 1
  export_option_has "<string>export</string>" || return 1
  export_option_has "<string>app-store-connect</string>" || return 1
  return 0
}

# Default (upload) path requires appstore.env; its absence fails fast before any
# archive.
test_release_upload_requires_appstore() {
  write_signing_env
  rm -f "$ENV_DIR/appstore.env"
  local out
  if out="$(run_release explicit-device 2>&1)"; then return 1; fi
  echo "$out" | grep -q "appstore.env" || return 1
  log_no_tool "xcodebuild"
}

# Default (upload) path forwards the App Store Connect API key as xcodebuild
# -authenticationKey* flags and selects the upload destination.
test_release_upload_forwards_api_key() {
  write_signing_env
  write_appstore_env
  run_release explicit-device >/dev/null 2>&1 || return 1
  log_has "-authenticationKeyID" || return 1
  log_has "$ASC_KEY_ID" || return 1
  log_has "-authenticationKeyIssuerID" || return 1
  log_has "$ASC_ISSUER_ID" || return 1
  log_has "-authenticationKeyPath" || return 1
  log_has "$ASC_KEY_PATH" || return 1
  export_option_has "<string>upload</string>" || return 1
  return 0
}

# A missing .p8 at UNICOACH_ASC_KEY_PATH fails fast, before any archive.
test_release_upload_missing_key_file() {
  write_signing_env
  write_appstore_env
  rm -f "$ASC_KEY_PATH"
  local out
  if out="$(run_release explicit-device 2>&1)"; then return 1; fi
  echo "$out" | grep -q "$ASC_KEY_PATH" || return 1
  log_no_tool "xcodebuild"
}

# The target's UNICOACH_CONFIGURATION=Debug is ignored: a release is always
# archived Release.
test_release_forces_release_config() {
  write_signing_env
  write_appstore_env
  run_release debug-config-device >/dev/null 2>&1 || return 1
  log_has "Release" || return 1
  log_lacks "Debug" || return 1
  return 0
}

# With no pinned build number, release-ios derives one from the repo's HEAD
# commit count and forwards it as CURRENT_PROJECT_VERSION=<digits>.
test_release_derives_build_number_from_git() {
  write_signing_env
  write_appstore_env
  RELEASE_BUILD_NUMBER="" run_release explicit-device >/dev/null 2>&1 || return 1
  grep -Eq "^CURRENT_PROJECT_VERSION=[0-9]+$" "$ARGV_LOG"
}

# A DEPLOY target (UNICOACH_DEPLOY, no explicit URL — the real prod target) makes
# release-ios derive https://api.$APP_DOMAIN from .env.prod, exactly like
# build-ios. Regression guard: release-ios must NOT fall back to the localhost
# derive path for a deploy target.
test_release_deploy_derives_https() {
  write_dotenv "uni.coach"
  write_signing_env
  rm -f "$ENV_DIR/appstore.env"   # -n path needs no upload auth
  run_release -n deploy-device >/dev/null 2>&1 || return 1
  log_has "UNICOACH_BACKEND_URL=https://api.uni.coach" || return 1
  log_lacks "UNICOACH_BACKEND_URL=http://localhost:8080" || return 1
  return 0
}

# Note: run_install/run_build wrappers reset the argv log; export the
# DEVICECTL_LIST_OUTPUT / IN_NIX through the env of the wrapper call above.

