assert_success "build-ios: derives backend port from SERVER_PORT" test_build_derives_port_from_server_port
assert_success "build-ios: bare-IP APP_DOMAIN rejected before any build" test_build_bare_ip_rejected
assert_success "build-ios: explicit UNICOACH_BACKEND_URL honored, beats derive" test_build_honors_explicit_backend_url
assert_success "build-ios: explicit URL forwarded byte-for-byte (trailing slash, no port)" test_build_honors_explicit_url_passthrough_fidelity
assert_success "build-ios: explicit URL skips the derive-only bare-IP check" test_build_explicit_url_skips_bare_ip_check
