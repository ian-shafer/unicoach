#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
wait-for [-p|--period duration] <timeout> <command...>

Arguments:
  <timeout>              Timeout limit indicating maximum wait time (e.g. 30, 30s, 2m, 1h, 1d).
  <command...>           Command to execute sequentially until success (0 exit status).

Options:
  -h, --help: Help
  -p, --period duration  Time to sleep between polling attempts. Supports standard sleep formats (e.g., 1, 1s, 2m, 1h, 1d). Defaults to 1s.
EOF
  exit "$exit_code"
}

PERIOD="1s"

while [[ "${1:-}" == -* ]]; do
  case "${1:-}" in
    -h|--help) help ;;
    -p|--period) PERIOD="${2:-}"; shift 2 ;;
    *) help "Unknown option: ${1:-}" ;;
  esac
done

if [ "$#" -lt 2 ]; then
  help "Error: missing parameters."
fi

TIMEOUT_STR="$1"
TIMEOUT_SECONDS=$(parse-duration-to-seconds "$TIMEOUT_STR" || echo "")
if [ -z "$TIMEOUT_SECONDS" ]; then
  help "Invalid timeout format [$TIMEOUT_STR]. Expected a number optionally followed by s, m, h, or d (e.g., 30, 30s, 2m)."
fi
shift
COMMAND=("$@")

LAST_STATUS=0

# First attempt: run the command immediately with no dot.
# Dots appear only when the command takes longer than one poll period.
"${COMMAND[@]}" && exit 0 || LAST_STATUS=$?

# Subsequent attempts: sleep, then dot, then retry.
DOT_PRINTED=false
while [ "$SECONDS" -lt "$TIMEOUT_SECONDS" ]; do
  sleep "$PERIOD"
  printf '.' >&2
  DOT_PRINTED=true
  "${COMMAND[@]}" && { printf '\n' >&2; exit 0; } || LAST_STATUS=$?
done

if $DOT_PRINTED; then
  printf '\n' >&2
fi

log-info "Timed out after ${TIMEOUT_STR} waiting for: ${COMMAND[*]}"
exit $LAST_STATUS
