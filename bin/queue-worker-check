#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
queue-worker-check [options]

Exits 0 if the queue-worker process is alive (PID file present and live).
Exits non-zero if it is not running.

Options:
  -h: Help
EOF
  exit 0
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -gt 0 ]; then
  fatal -s "$EXIT_UNEXPECTED_ARG" "queue-worker-check accepts no arguments: $*"
fi

if "$PROJECT_ROOT/bin/daemon-check" queue-worker > /dev/null 2>&1; then
  log-info "queue-worker is running"
else
  log-info "queue-worker is NOT running"
  exit 1
fi
