#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
db-init [options]

Initializes the database by starting it and creating required migrations tables.

Options:
  -h, --help: Help
EOF
  exit "$exit_code"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
  -h|--help) help ;;
  *) break ;;
  esac
done

if [ "$#" -gt 0 ]; then
  help "db-init does not accept positional arguments: $*"
fi

"$PROJECT_ROOT/bin/postgres-start"

if ! echo "SELECT 1 FROM pg_database WHERE datname = '$POSTGRES_DB'" | "$PROJECT_ROOT/bin/db-query" -d "${POSTGRES_ADMIN_DB:-postgres}" -tA | grep -q 1; then
  echo "CREATE DATABASE \"$POSTGRES_DB\";" | "$PROJECT_ROOT/bin/db-update" -d "${POSTGRES_ADMIN_DB:-postgres}"
fi

echo "CREATE TABLE IF NOT EXISTS schema_migrations (version_id VARCHAR(4) PRIMARY KEY, filename VARCHAR(255) NOT NULL, applied_at TIMESTAMP WITH TIME ZONE DEFAULT NOW());" | "$PROJECT_ROOT/bin/db-update"
log-info "Database successfully initialized."
