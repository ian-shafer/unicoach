#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
queue-worker-up [options]

Boots the queue-worker daemon from a pre-built installDist binary.
Ensures postgres is running first, then waits briefly to confirm the worker
process launched successfully.

The binary MUST be pre-built via `bin/build-queue-worker` before invoking
this script. If the binary is absent, this script exits non-zero immediately
without invoking Gradle.

Options:
  -h: Help
EOF
  exit 0
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -gt 0 ]; then
  fatal -s "$EXIT_UNEXPECTED_ARG" "queue-worker-up does not accept positional arguments: $*"
fi

BINARY="$PROJECT_ROOT/queue-worker/build/install/queue-worker/bin/queue-worker"

if [ ! -x "$BINARY" ]; then
  fatal "queue-worker binary not found at [$BINARY]. Run 'bin/build-queue-worker' first."
fi

"$PROJECT_ROOT/bin/daemon-up" queue-worker -- "$BINARY"

"$PROJECT_ROOT/bin/queue-worker-wait-for-health"
