#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
build-admin-server [options]

Produces a self-contained installDist distribution for :admin-server via
Gradle. The resulting launch script is located at:
  admin-server/build/install/admin-server/bin/admin-server

Options:
  -h, --help: Help
EOF
  exit "$exit_code"
}

while [[ "${1:-}" == -* ]]; do
  case "$1" in
  -h|--help) help ;;
  -*) fatal "Unknown option: $1" ;;
  *) break ;;
  esac
done

if [ "$#" -gt 0 ]; then
  help "build-admin-server does not accept positional arguments: $*"
fi

exec "$PROJECT_ROOT/gradlew" :admin-server:installDist
