#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
rest-server-check [options]

Exits 0 if the rest-server is healthy (GET /healthz returns HTTP 200).
Exits non-zero if the server is not reachable or returns an error.

Exit codes:
  0: Healthy (HTTP 200).
  1: Not running (port free, nothing listening).
  2: The port is held by another process not responding as rest-server.

Options:
  -h: Help
EOF
  exit 0
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -gt 0 ]; then
  fatal -s "$EXIT_UNEXPECTED_ARG" "rest-server-check accepts no arguments: $*"
fi

"$PROJECT_ROOT/bin/daemon-http-check" rest-server "${PORT:-8080}" "http://localhost:${PORT:-8080}/healthz"
