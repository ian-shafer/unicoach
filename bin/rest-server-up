#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
rest-server-up [options]

Boots the rest-server daemon from a pre-built installDist binary and waits
for it to respond to HTTP requests.

The binary MUST be pre-built via `bin/build-rest-server` before invoking
this script. If the binary is absent, this script exits non-zero immediately
without invoking Gradle.

Options:
  -h: Help
EOF
  exit 0
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -gt 0 ]; then
  fatal -s "$EXIT_UNEXPECTED_ARG" "rest-server-up does not accept positional arguments: $*"
fi

BINARY="$PROJECT_ROOT/rest-server/build/install/rest-server/bin/rest-server"

if [ ! -x "$BINARY" ]; then
  fatal "rest-server binary not found at [$BINARY]. Run 'bin/build-rest-server' first."
fi

"$PROJECT_ROOT/bin/daemon-up" -p "${PORT:-8080}" rest-server -- "$BINARY"

"$PROJECT_ROOT/bin/rest-server-wait-for-health"
