#!/usr/bin/env bash
# db-scripts-tests runs against its OWN private, throwaway PostgreSQL cluster
# (private data dir + unique port), NOT the shared cluster. This harness
# deliberately exercises cluster lifecycle — postgres-down, db-drop,
# re-provisioning — so it must never stop or wipe the cluster that other
# worktrees share. The private cluster is torn down and deleted on exit.
set -euo pipefail

THIS_DIR="$(cd "$(dirname "$0")" && pwd)"

# Private env: throwaway data dir, a PID-derived port (dynamic/private range) to
# avoid colliding with the shared cluster or a concurrent run, and a dedicated DB.
# mktemp only creates the final XXXXXX component, so the base must already exist —
# ensure it does (nix sets TMPDIR to a per-shell path that is not always present).
TMP_BASE="${TMPDIR:-/tmp}"
mkdir -p "$TMP_BASE"
PRIVATE_ROOT="$(mktemp -d "$TMP_BASE/unicoach-db-scripts-tests.XXXXXX")"
PRIVATE_ENV="$PRIVATE_ROOT/env"
cat > "$PRIVATE_ENV" <<EOF
POSTGRES_USER=postgres
POSTGRES_DB=unicoach-db-scripts-test
POSTGRES_HOST_AUTH_METHOD=trust
PGHOST=localhost
POSTGRES_DATA_DIR=$PRIVATE_ROOT/pg
POSTGRES_ADMIN_DB=postgres
POSTGRES_PORT=$(( 49152 + ($$ % 16000) ))
DATABASE_USER=unicoach
DATABASE_PASSWORD=password
EOF

export ENV_FILE="$PRIVATE_ENV"
source "$THIS_DIR/common"
source "$THIS_DIR/tests-common"

# Tear down the PRIVATE cluster and delete its data on exit. Safe — it is ours
# alone (private port + data dir), unrelated to the shared cluster.
trap 'bin/postgres-down >/dev/null 2>&1 || true; rm -rf "$PRIVATE_ROOT" >/dev/null 2>&1 || true' EXIT INT TERM

wait_for_postgres() {
  for i in {1..15}; do
    if psql -U postgres -d "$POSTGRES_DB" -c '\q' >/dev/null 2>&1; then return 0; fi
    sleep 1
  done
  echo "Fail: Timed out waiting for database '$POSTGRES_DB' runtime to become queryable organically."
  exit 1
}

# Bootstrap the private cluster (initdb + role) and provision its database.
bin/db-bootstrap >/dev/null
bin/db-create >/dev/null

# Set up testing table
bin/db-run rw "CREATE TABLE db_scripts_test (id INT PRIMARY KEY, val TEXT);" >/dev/null

test_db_run_ro_blocks_mutation() {
  if bin/db-run ro "INSERT INTO db_scripts_test (id, val) VALUES (1, 'ro');" >/dev/null 2>&1; then
    return 1
  fi
  return 0
}

test_db_run_rw_allows_mutation() {
  bin/db-run rw "INSERT INTO db_scripts_test (id, val) VALUES (2, 'rw');" >/dev/null
}

test_db_query_via_stdin() {
  echo "SELECT * FROM db_scripts_test WHERE id = 2;" | bin/db-query | grep "rw" >/dev/null
}

test_db_query_via_positional() {
  bin/db-query "SELECT * FROM db_scripts_test WHERE id = 2;" | grep "rw" >/dev/null
}

test_db_write_via_stdin() {
  echo "INSERT INTO db_scripts_test (id, val) VALUES (3, 'stdin');" | bin/db-write >/dev/null
  bin/db-query "SELECT val FROM db_scripts_test WHERE id = 3;" | grep "stdin" >/dev/null
}

test_db_write_via_positional() {
  bin/db-write "INSERT INTO db_scripts_test (id, val) VALUES (4, 'positional');" >/dev/null
  bin/db-query "SELECT val FROM db_scripts_test WHERE id = 4;" | grep "positional" >/dev/null
}

test_db_repl_interactive_shell() {
  echo "\q" | bin/db-repl >/dev/null
}

test_psql_error_propagation() {
  bin/db-query "SELECT * FROM non_existent_table;" >/dev/null 2>&1
  local status=$?
  if [ "$status" -eq 0 ] || [ "$status" -eq 2 ]; then
    return 1
  fi
  return 0
}

test_psql_stderr_output() {
  local out
  out=$(bin/db-query "SELECT * FROM non_existent_table;" 2>&1 >/dev/null)
  echo "$out" | grep "relation \"non_existent_table\" does not exist" >/dev/null
}

echo "==== Testing Core Execution & Queries ===="

assert_success "db-run ro blocks mutation" test_db_run_ro_blocks_mutation
assert_success "db-run rw allows mutation" test_db_run_rw_allows_mutation
assert_success "db-query via stdin" test_db_query_via_stdin
assert_success "db-query via positional" test_db_query_via_positional
assert_success "db-write via stdin" test_db_write_via_stdin
assert_success "db-write via positional" test_db_write_via_positional
assert_success "db-repl interactive shell" test_db_repl_interactive_shell
assert_success "psql error propagation" test_psql_error_propagation
assert_success "psql stderr output" test_psql_stderr_output

echo "==== Testing Error Handling Validation ===="

test_container_unreachable_exits_2() {
  bin/postgres-down >/dev/null
  bin/db-query "SELECT 1;" >/dev/null 2>&1
  local status=$?
  if [ "$status" -ne 2 ]; then
    return 1
  fi
  return 0
}
assert_success "container unreachable exits 2" test_container_unreachable_exits_2

echo "==== Testing Database Lifecycle ===="
test_db_lifecycle_wipes_data() {
  # Restart postgres after the unreachable test above
  bin/postgres-up >/dev/null
  wait_for_postgres
  bin/db-create

  # Write dummy data and ensure we can read it
  bin/db-run rw "CREATE TABLE IF NOT EXISTS lifecycle_test (id INT);"
  bin/db-run rw "INSERT INTO lifecycle_test (id) VALUES (42);"

  if ! bin/db-query "SELECT * FROM lifecycle_test;" | grep -q "42"; then
    fail_test "lifecycle_test read failed"
    return 1
  fi

  # Drop the database
  bin/db-drop --yes-i-really-want-to-do-this

  # Ensure the dropped database is gone / data destroyed
  if bin/db-query "SELECT * FROM lifecycle_test;" 2>/dev/null; then
    fail_test "db-query erroneously succeeded after db-drop"
    return 1
  fi

  # Recreate it
  bin/db-create

  if bin/db-query "SELECT * FROM schema_migrations limit 1;" 2>&1 | grep -q "relation.*schema_migrations.*does not exist"; then
    fail_test "db-create failed to recreate schema_migrations table"
    return 1
  fi
  pass_test "db-drop and db-create completed successfully"
}
test_db_lifecycle_wipes_data

test_db_provisioning_idempotent() {
  bin/db-drop --yes-i-really-want-to-do-this
  bin/db-create

  # Re-running bootstrap and create must both exit 0 with no errors.
  if ! out=$(bin/db-bootstrap 2>&1); then
    fail_test "db-bootstrap failed on re-run: $out"
    return 1
  fi
  if ! out=$(bin/db-create 2>&1); then
    fail_test "db-create failed on re-run: $out"
    return 1
  fi
  pass_test "db-bootstrap and db-create are idempotent"
}
test_db_provisioning_idempotent

test_db_status_formats() {
  bin/db-drop --yes-i-really-want-to-do-this
  bin/db-create

  export DB_SCHEMA_DIR="/tmp/test_migrations_status_$$"
  mkdir -p "$DB_SCHEMA_DIR"
  echo "CREATE TABLE s1 (id INT);" > "$DB_SCHEMA_DIR/0001.s1.sql"

  # Forward migration (applies 0001.s1.sql)
  bin/db-migrate

  # Creates another schema file
  echo "CREATE TABLE s2 (id INT);" > "$DB_SCHEMA_DIR/0002.s2.sql"

  # Test that --format applied-only only outputs a single, correct line
  applied_out=$(bin/db-status --format applied-only)
  if [ "$applied_out" != "0001.s1.sql" ]; then
    fail_test "db-status --format applied-only did not output expected single line. Got: $applied_out"
    return 1
  fi

  # Test that --format unapplied-only only outputs a single, correct line
  unapplied_out=$(bin/db-status --format unapplied-only)
  if [ "$unapplied_out" != "0002.s2.sql" ]; then
    fail_test "db-status --format unapplied-only did not output expected single line. Got: $unapplied_out"
    return 1
  fi

  pass_test "db-status format option correctly filters migration states"
  rm -rf "$DB_SCHEMA_DIR"
  unset DB_SCHEMA_DIR
}
test_db_status_formats

echo "==== Testing Migration Engine ===="
setup_migration_test() {
  bin/db-drop --yes-i-really-want-to-do-this >/dev/null 2>&1 || true
  bin/db-create
  export DB_SCHEMA_DIR="/tmp/test_migrations_$$"
  mkdir -p "$DB_SCHEMA_DIR"
}

teardown_migration_test() {
  rm -rf "$DB_SCHEMA_DIR"
  unset DB_SCHEMA_DIR
}

test_db_migrate_forward() {
  setup_migration_test

  echo "CREATE TABLE m1 (id INT);" > "$DB_SCHEMA_DIR/0001.m1.sql"
  echo "CREATE TABLE m2 (id INT);" > "$DB_SCHEMA_DIR/0002.m2.sql"

  status_out=$(bin/db-status)
  if ! echo "$status_out" | grep -q "\[PENDING\] 0001.m1.sql"; then
    fail_test "db-status did not detect pending migration 0001.m1.sql"
    teardown_migration_test
    return 1
  fi
  if ! echo "$status_out" | grep -q "\[PENDING\] 0002.m2.sql"; then
    fail_test "db-status did not detect pending migration 0002.m2.sql"
    teardown_migration_test
    return 1
  fi

  bin/db-migrate

  if ! echo "SELECT * FROM m1;" | bin/db-query >/dev/null 2>&1; then
    fail_test "migration 1 was not physically applied"
    teardown_migration_test
    return 1
  fi
  if ! echo "SELECT * FROM m2;" | bin/db-query >/dev/null 2>&1; then
    fail_test "migration 2 was not physically applied"
    teardown_migration_test
    return 1
  fi

  applied_count=$(echo "SELECT count(*) FROM schema_migrations;" | bin/db-query -tA)
  if [ "$applied_count" != "2" ]; then
    fail_test "schema_migrations did not track completions. Expected 2, got: '$applied_count'"
    teardown_migration_test
    return 1
  fi

  teardown_migration_test
  return 0
}

test_db_migrate_idempotent() {
  setup_migration_test

  echo "CREATE TABLE m1 (id INT);" > "$DB_SCHEMA_DIR/0001.m1.sql"
  echo "CREATE TABLE m2 (id INT);" > "$DB_SCHEMA_DIR/0002.m2.sql"
  bin/db-migrate

  if ! bin/db-migrate >/dev/null 2>&1; then
    fail_test "db-migrate was not idempotent (did not exit 0)"
    teardown_migration_test
    return 1
  fi

  applied_count=$(echo "SELECT count(*) FROM schema_migrations;" | bin/db-query -tA)
  if [ "$applied_count" != "2" ]; then
    fail_test "schema counts broke during idempotent migrate"
    teardown_migration_test
    return 1
  fi

  teardown_migration_test
  return 0
}

test_db_migrate_transaction_rollback() {
  setup_migration_test

  # 0001.m1.sql contains valid then invalid SQL
  echo "CREATE TABLE good_table (id INT);" > "$DB_SCHEMA_DIR/0001.m1.sql"
  echo "GARBAGE SQL;" >> "$DB_SCHEMA_DIR/0001.m1.sql"

  if bin/db-migrate >/dev/null 2>&1; then
    fail_test "db-migrate did not fail on broken transaction"
    teardown_migration_test
    return 1
  fi

  # Ensure the good SQL was rolled back
  if echo "SELECT * FROM good_table;" | bin/db-query >/dev/null 2>&1; then
    fail_test "transaction was not rolled back; good_table exists"
    teardown_migration_test
    return 1
  fi

  applied_count=$(echo "SELECT count(*) FROM schema_migrations;" | bin/db-query -tA)
  if [ "$applied_count" != "0" ]; then
    fail_test "schema_migrations erroneously tracked failed transaction"
    teardown_migration_test
    return 1
  fi

  teardown_migration_test
  return 0
}

test_db_migrate_halts_on_error() {
  setup_migration_test

  echo "CREATE TABLE m1 (id INT);" > "$DB_SCHEMA_DIR/0001.m1.sql"
  echo "CREATE TABLE m2 (id INT);" > "$DB_SCHEMA_DIR/0002.m2.sql"
  bin/db-migrate

  echo "GARBAGE SQL SYNTAX;" > "$DB_SCHEMA_DIR/0003.bad.sql"
  echo "CREATE TABLE m4 (id INT);" > "$DB_SCHEMA_DIR/0004.m4.sql"

  if bin/db-migrate >/dev/null 2>&1; then
    fail_test "db-migrate did not fail on broken SQL"
    teardown_migration_test
    return 1
  fi

  if echo "SELECT * FROM m4;" | bin/db-query >/dev/null 2>&1; then
    fail_test "db-migrate did not halt; execution continued past broken SQL"
    teardown_migration_test
    return 1
  fi

  applied_count=$(echo "SELECT count(*) FROM schema_migrations;" | bin/db-query -tA)
  if [ "$applied_count" != "2" ]; then
    fail_test "schema_migrations erroneously tracked failed migration"
    teardown_migration_test
    return 1
  fi

  teardown_migration_test
  return 0
}

assert_success "migration engine forward migration" test_db_migrate_forward
assert_success "migration engine restricts idempotency" test_db_migrate_idempotent
assert_success "migration engine rolls back failed transactions" test_db_migrate_transaction_rollback
assert_success "migration engine halts on error" test_db_migrate_halts_on_error

end_tests
