#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
q-truncate [job-types...]

Deletes all jobs (and their attempts via CASCADE) for the specified job types.
If no types are given, deletes all jobs.

Options:
  -y: Bypass safety prompt
EOF
}

skip_prompt=false
types=()
# Options (-y/-h) and positional job-types may be intermixed in any order.
# getopts alone stops at the first non-option, so wrap it in an outer loop that
# consumes one non-option (a job-type) per round, resetting OPTIND=1 before each
# inner getopts run (OPTIND is not auto-reset within one shell).
while [ "$#" -gt 0 ]; do
  OPTIND=1
  while getopts ":hy" opt; do
    case "$opt" in
    h) help; exit 0 ;;
    y) skip_prompt=true ;;
    \?) fatal "Unknown option [-$OPTARG]" ;;
    :)  fatal "option -$OPTARG requires an argument" ;;
    esac
  done
  shift $((OPTIND-1))
  if [ "$#" -gt 0 ]; then
    types+=("$1")
    shift
  fi
done

if [ ${#types[@]} -eq 0 ]; then
  desc="delete all jobs and their attempt history"
  query="DELETE FROM jobs"
else
  desc="delete all jobs and their attempt history for types: ${types[*]}"
  in_clause=$(printf "'%s'," "${types[@]}" | sed 's/,$//')
  query="DELETE FROM jobs WHERE job_type IN ($in_clause)"
fi

if [ "$skip_prompt" = false ]; then
  require_dangerous_confirmation "$desc" || exit $?
fi

echo "$query;" | "$PROJECT_ROOT/bin/db-write" || exit 2
