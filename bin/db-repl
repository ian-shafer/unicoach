#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
db-repl [-h]

Options:
  -h: Help
EOF
  exit 0
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -gt 0 ]; then
  fatal -s "$EXIT_UNEXPECTED_ARG" "db-repl accepts no arguments: $*"
fi

# Suppress health check failure logs to keep the interactive startup display clean
if ! "$PROJECT_ROOT/bin/postgres-check" >/dev/null 2>&1; then
  log-info "PostgreSQL is offline [host=${PGHOST:-localhost} port=${PGPORT:-5432}]"
  exit 2
fi

psql -U "$POSTGRES_USER" -d "$POSTGRES_DB"
