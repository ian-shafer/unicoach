#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
db-repl [options]

Options:
  -h: Help
EOF
  exit "$exit_code"
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) fatal "unknown option [-$OPTARG]" ;;
  :)  fatal "option -$OPTARG requires an argument" ;;
  esac
done
shift $((OPTIND-1))

# Suppress health check failure logs to keep the interactive startup display clean
if ! "$PROJECT_ROOT/bin/postgres-check" >/dev/null 2>&1; then
  log-info "PostgreSQL is offline"
  exit 2
fi

exec psql -U "$POSTGRES_USER" -d "$POSTGRES_DB" "$@"
