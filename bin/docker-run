#!/usr/bin/env bash

source "$(dirname "$0")/common" ""

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
docker-run [options] IMAGE COMMAND...

Executes a command inside an ephemeral docker container with user/volume bindings.

Options:
  -h, --help: Help
EOF
  exit "$exit_code"
}

if [ "$#" -eq 0 ]; then
  help "Error: Target Docker image argument is missing."
fi

while [[ "${1:-}" == -* ]]; do
  case "$1" in
  -h|--help) help ;;
  *)
      help "Unknown option: $1"
      ;;
  esac
done

IMAGE="$1"
# Command payload evaluates to whatever exists from the second positional arg onwards
COMMAND_PAYLOAD=("${@:2}")

DOCKER_ARGS=(
  "--rm"
  "--user" "$(id -u):$(id -g)"
  "-v" "$PROJECT_ROOT:/workspace"
  "-w" "/workspace"
  "-e" "GRADLE_USER_HOME=/workspace/var/gradle"
  "-e" "HOME=/workspace/var/gradle"
)

if [ -f "$PROJECT_ROOT/.env" ]; then
  DOCKER_ARGS+=("--env-file" "$PROJECT_ROOT/.env")
fi

docker run "${DOCKER_ARGS[@]}" "$IMAGE" "${COMMAND_PAYLOAD[@]}"
