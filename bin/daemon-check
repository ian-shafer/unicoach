#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
daemon-check [options] <service-name>

Exits 0 if the service is running (PID file exists and process is alive).
Exits 1 if the service is stopped (no PID file or process is dead).

When -p is supplied and our recorded process is absent/dead while the port
is held by another process, exits 2 (conflict). Without -p the result is
only 0 or 1, exactly as before.

Arguments:
  service-name: Logical service identifier (e.g. postgres, rest-server).

Options:
  -h:        Help
  -p <port>: TCP port the service binds; enables the conflict tri-state.

Exit codes:
  0: Running (our PID is alive).
  1: Stopped (no PID file, empty PID file, or our process is dead).
  2: Conflict — our PID is absent/dead but <port> is held by another process.
EOF
  exit "$exit_code"
}

PORT=""
PORT_SET=false

# getopts parses only the leading options and halts at the first non-option
# (<service-name>). The two error arms route to different sinks (preserved
# verbatim): a missing -p value -> help, an unknown option -> fatal.
while getopts ":hp:" opt; do
  case "$opt" in
  h) help ;;
  p) PORT="$OPTARG"; PORT_SET=true ;;
  \?) fatal "unknown option [-$OPTARG]" ;;
  :)  help "option -$OPTARG requires an argument" ;;
  esac
done
shift $((OPTIND-1))

# An explicit -p with an empty value is a usage error (never a silent portless
# degrade); -p must carry a valid 1..65535 port.
if [ "$PORT_SET" = true ] && ! validate_port "$PORT"; then
  help "Invalid -p value [$PORT]. Expected an integer in 1..65535."
fi

if [ "$#" -ne 1 ]; then
  help "Missing required <service-name> argument."
fi

SERVICE_NAME="$1"
shift

PID_FILE="$PROJECT_ROOT/var/run/${SERVICE_NAME}.pid"

# Decide running/stopped from our own tracking file first. Only once we conclude
# we are not running do we consult the port (when -p is given) to distinguish
# a plain "stopped" from a "conflict" — the port is held by some other process.
stopped() {
  if [ -z "$PORT" ]; then
    exit 1
  fi
  local port_status=0
  "$PROJECT_ROOT/bin/check-port" "$PORT" || port_status=$?
  case "$port_status" in
  0)
    log-info "Service [$SERVICE_NAME] is stopped, but port [127.0.0.1:$PORT] is held by another process."
    exit 2
    ;;
  1)
    exit 1
    ;;
  *)
    fatal "check-port rejected port [$PORT] (exit [$port_status]) while checking [$SERVICE_NAME]."
    ;;
  esac
}

if [ ! -f "$PID_FILE" ]; then
  log-info "Service [$SERVICE_NAME] is stopped (no PID file)."
  stopped
fi

existing_pid="$(cat "$PID_FILE" 2>/dev/null || true)"

if [ -z "$existing_pid" ]; then
  log-info "Service [$SERVICE_NAME] PID file is empty."
  stopped
fi

if "$PROJECT_ROOT/bin/check-pid" "$existing_pid" 2>/dev/null; then
  log-info "Service [$SERVICE_NAME] is running (PID $existing_pid)."
  exit 0
else
  log-info "Service [$SERVICE_NAME] process (PID $existing_pid) is dead."
  stopped
fi
