#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
ingest-colleges <institution.csv> <fields.csv>

Loads a version-pinned College Scorecard CSV pair into the `colleges` and
`college_programs` reference tables via the :college ingester (RFC 67). Upserts
on the natural keys, so re-running re-applies the same snapshot with no
duplicates. Malformed rows are logged and skipped.

Run inside the nix dev shell (the JVM lives there):
  nix develop -c bin/ingest-colleges <institution.csv> <fields.csv>

Options:
  -h: Help
EOF
  exit 0
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -ne 2 ]; then
  fatal -s "$EXIT_MISSING_REQUIRED_ARG" "ingest-colleges requires exactly two arguments: <institution.csv> <fields.csv>"
fi

# Absolutize the CSV paths: the :college:run task executes with the module
# directory as its working directory, so a path relative to the caller's CWD
# would not resolve. realpath fails loudly if a file is missing.
INSTITUTION_CSV="$(realpath "$1")" || fatal "institution CSV not found: [$1]"
FIELDS_CSV="$(realpath "$2")" || fatal "fields CSV not found: [$2]"

# Gradle word-splits the --args value on whitespace using its own shell-like
# parser, so each CSV path is single-quoted to survive a path containing spaces:
# each path then arrives at IngestApplication as exactly one argument.
"$PROJECT_ROOT/gradlew" :college:run --args="'$INSTITUTION_CSV' '$FIELDS_CSV'"
