#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
postgres-wait-for-health [options]

Polls postgres-check at 1-second intervals until it reports healthy or the
timeout elapses. Exits 0 on success, non-zero on timeout.

Options:
  -h: Help
EOF
  exit 0
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -gt 0 ]; then
  fatal -s "$EXIT_UNEXPECTED_ARG" "postgres-wait-for-health accepts no arguments: $*"
fi

TIMEOUT=4s
log-info "Waiting for postgres health check..."
if ! "$PROJECT_ROOT/bin/wait-for" "$TIMEOUT" "$PROJECT_ROOT/bin/postgres-check"; then
  fatal "postgres did not become healthy within $TIMEOUT. Check var/log/postgres.log."
fi
log-info "postgres is healthy"
