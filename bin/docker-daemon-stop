#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
docker-daemon-stop <service-name> [options]

Safely terminates a running daemon.

Options:
  -h, --help: Help
  -d, --docker-down         Tear down network/containers but leave volumes intact
  --wipe-data               Destructively remove all containers, networks, AND volumes
  --lock-timeout SECONDS    Wait up to this duration to acquire lock (default 16)
EOF
  exit "$exit_code"
}

DOCKER_COMMAND="stop"
WIPE_DATA=false
LOCK_TIMEOUT="16"

SERVICE_NAME=""

while [[ $# -gt 0 ]]; do
  case "$1" in
  -h|--help) help ;;
  -d|--docker-down) DOCKER_COMMAND="down"; shift ;;
  --wipe-data) DOCKER_COMMAND="down"; WIPE_DATA=true; shift ;;
  --lock-timeout) LOCK_TIMEOUT="${2:-}"; shift 2 ;;
  *)
      if [[ "$1" == -* ]]; then
    fatal "Unknown option: $1"
      elif [ -z "$SERVICE_NAME" ]; then
    SERVICE_NAME="$1"
    shift
      else
    fatal "Unexpected argument: $1"
      fi
      ;;
  esac
done

if [ -z "$SERVICE_NAME" ]; then
  help "Missing required <service-name> argument."
fi

COMPOSE_FILE="$PROJECT_ROOT/docker/${SERVICE_NAME}-compose.yaml"
if [ ! -f "$COMPOSE_FILE" ]; then
  fatal "Docker compose file not found [$COMPOSE_FILE]"
fi

# Stop is inherently idempotent because Docker Compose gracefully handles stops on already-stopped resources.
# However, to prevent stepping on concurrent boots, we must acquire the lock.
LOCK_DIR="$PROJECT_ROOT/var/run/${SERVICE_NAME}.daemon.lock"

if ! "$PROJECT_ROOT/bin/file-lock" -o stop -t "$LOCK_TIMEOUT" "$LOCK_DIR" 60; then
  # Inherently code 10 isn't generated for stop matches natively since stop deletes its lock quickly, 
  # but if it did, we still fail. We just fail cleanly natively.
  fatal "Failed to acquire lock for $SERVICE_NAME."
fi

trap 'rm -rf "$LOCK_DIR"' EXIT INT TERM

COMPOSE_ARGS=("-f" "$COMPOSE_FILE")
COMPOSE_ARGS+=("$DOCKER_COMMAND")

if [ "$DOCKER_COMMAND" = "down" ]; then
  if [ "$WIPE_DATA" = true ]; then
  COMPOSE_ARGS+=("-v")
  fi
  COMPOSE_ARGS+=("--remove-orphans")
fi

"$PROJECT_ROOT/bin/docker-compose" "${COMPOSE_ARGS[@]}" || exit $?
