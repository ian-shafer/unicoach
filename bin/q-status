#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
q-status [job-types...]

Displays job counts grouped by status. If job types are provided, filters to those types.
EOF
}

while getopts ":h" opt; do
  case "$opt" in
  h) help; exit 0 ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

types=("$@")
query="SELECT job_type AS \"Job Type\",
       COUNT(CASE WHEN status = 'SCHEDULED' THEN 1 END) AS \"SCHEDULED\",
       COUNT(CASE WHEN status = 'RUNNING' THEN 1 END) AS \"RUNNING\",
       COUNT(CASE WHEN status = 'COMPLETED' THEN 1 END) AS \"COMPLETED\",
       COUNT(CASE WHEN status = 'DEAD_LETTERED' THEN 1 END) AS \"DEAD_LETTERED\"
FROM jobs"

if [ ${#types[@]} -gt 0 ]; then
  in_clause=$(printf "'%s'," "${types[@]}" | sed 's/,$//')
  query="$query WHERE job_type IN ($in_clause)"
fi

query="$query GROUP BY job_type;"

echo "$query" | "$PROJECT_ROOT/bin/db-query" || exit 2
