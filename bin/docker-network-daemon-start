#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
docker-network-daemon-start <network-name> [options]

Initializes the requested docker network bridging layer safely natively.

Options:
  -h, --help: Help
EOF
  exit "$exit_code"
}

NETWORK_NAME=""

while [[ $# -gt 0 ]]; do
  case "$1" in
  -h|--help) help ;;
  -*) fatal "Unknown option: $1" ;;
  *) break ;;
  esac
done

if [ "$#" -lt 1 ]; then
  help "Missing required <network-name> argument."
fi
NETWORK_NAME="$1"
shift

if [ "$#" -gt 0 ]; then
  fatal "Unexpected arguments: $*"
fi

LOCK_DIR="$PROJECT_ROOT/var/run/${NETWORK_NAME}.network-daemon.lock"

if ! "$PROJECT_ROOT/bin/file-lock" -o start -t 16 "$LOCK_DIR" 60; then
  LAST_STATUS=$?
  if [ $LAST_STATUS -eq 10 ]; then
    log-info "Another start instance is actively establishing $NETWORK_NAME. Exiting gracefully."
    exit 0
  fi
  if [ -r "$LOCK_DIR/op" ] && [ "$(cat "$LOCK_DIR/op" 2>/dev/null)" = "start" ]; then
    log-info "Lock is active for start. Gracefully bouncing."
    exit 0
  fi
  fatal "Failed to acquire lock for $NETWORK_NAME. Lock may be held by a conflicting operation."
fi

trap 'rm -rf "$LOCK_DIR"' EXIT INT TERM

if "$PROJECT_ROOT/bin/docker-network-daemon-check" "$NETWORK_NAME"; then
  log-info "Network $NETWORK_NAME is already active."
  exit 0
fi

if ! docker network create "$NETWORK_NAME" >/dev/null 2>&1; then
  fatal "Failed to natively instantiate docker network bridging for $NETWORK_NAME."
fi

exit 0
