#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
queue-worker-wait-for-health [options]

Polls queue-worker-check at 1-second intervals until the process is confirmed
alive or the timeout elapses. Exits 0 on success, non-zero on timeout.

The queue-worker has no network port to probe. Process liveness (via the PID
file written by daemon-up) is the best available health signal.

Options:
  -h: Help
EOF
  exit 0
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -gt 0 ]; then
  fatal -s "$EXIT_UNEXPECTED_ARG" "queue-worker-wait-for-health accepts no arguments: $*"
fi

TIMEOUT=4s
log-info "Waiting for queue-worker health check..."
if ! "$PROJECT_ROOT/bin/wait-for" "$TIMEOUT" "$PROJECT_ROOT/bin/queue-worker-check"; then
  fatal "queue-worker did not become healthy within $TIMEOUT. Check var/log/queue-worker.log."
fi
log-info "queue-worker is healthy"
