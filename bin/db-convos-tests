}
assert_success "convos: leading/trailing-whitespace name rejected (trimmed check)" test_convos_name_untrimmed

test_convos_name_valid() {
  local out
  out=$(run_test_sql << EOF
    INSERT INTO convos (student_id, name) VALUES ('$STUDENT_ID', 'My College Plan');
EOF
  )
  echo "$out" | grep -q 'ERROR' && { echo "output was: $out"; return 1; }
  return 0
}
assert_success "convos: valid name accepted" test_convos_name_valid

test_convos_update_name_bumps_timestamps() {
  local out
  out=$(run_test_sql_ta << EOF
    INSERT INTO convos (id, student_id, name, created_at, updated_at, row_updated_at)
    VALUES (uuidv7(), '$STUDENT_ID', 'Original',
            '2020-01-01T00:00:00Z'::timestamptz,
            '2020-01-01T00:00:00Z'::timestamptz,
            '2020-01-01T00:00:00Z'::timestamptz)
    RETURNING id \\gset
    UPDATE convos SET name = 'Renamed' WHERE id = :'id';
    SELECT (updated_at > '2020-01-01T00:00:00Z'::timestamptz)
      || '|' || (row_updated_at > '2020-01-01T00:00:00Z'::timestamptz)
    FROM convos WHERE id = :'id';
EOF
  )
  echo "$out" | grep -q '^true|true$' || { echo "output was: $out"; return 1; }
}
assert_success "convos: UPDATE name advances updated_at and row_updated_at" test_convos_update_name_bumps_timestamps

test_convos_immutable_id() {
  local out
  out=$(run_test_sql << EOF
    INSERT INTO convos (id, student_id, name) VALUES (uuidv7(), '$STUDENT_ID', 'Immutable id') RETURNING id \\gset
    UPDATE convos SET id = uuidv7() WHERE id = :'id';
EOF
  )
  echo "$out" | grep -q 'The id field is immutable' || { echo "output was: $out"; return 1; }
}
assert_success "convos: UPDATE of id rejected (prevent_immutable_updates)" test_convos_immutable_id

test_convos_immutable_created_at() {
  local out
  out=$(run_test_sql << EOF
    INSERT INTO convos (id, student_id, name) VALUES (uuidv7(), '$STUDENT_ID', 'Immutable created_at') RETURNING id \\gset
    UPDATE convos SET created_at = '2020-01-01T00:00:00Z'::timestamptz WHERE id = :'id';
EOF
  )
  echo "$out" | grep -q 'The created_at field is immutable' || { echo "output was: $out"; return 1; }
}
assert_success "convos: UPDATE of created_at rejected (prevent_immutable_updates)" test_convos_immutable_created_at

test_convos_immutable_row_created_at() {
  local out
  out=$(run_test_sql << EOF
    INSERT INTO convos (id, student_id, name) VALUES (uuidv7(), '$STUDENT_ID', 'Immutable row_created_at') RETURNING id \\gset
    UPDATE convos SET row_created_at = '2020-01-01T00:00:00Z'::timestamptz WHERE id = :'id';
EOF
  )
  echo "$out" | grep -q 'The row_created_at field is immutable' || { echo "output was: $out"; return 1; }
}
assert_success "convos: UPDATE of row_created_at rejected (prevent_immutable_updates)" test_convos_immutable_row_created_at

test_convos_physical_delete_blocked() {
  local out
  out=$(run_test_sql << EOF
    INSERT INTO convos (id, student_id, name) VALUES (uuidv7(), '$STUDENT_ID', 'Delete blocked') RETURNING id \\gset
    DELETE FROM convos WHERE id = :'id';
EOF
  )
  echo "$out" | grep -q 'Physical deletions are strictly blocked' || { echo "output was: $out"; return 1; }
}
assert_success "convos: physical DELETE rejected (prevent_physical_delete)" test_convos_physical_delete_blocked

test_convos_soft_delete_excluded_by_partial_index() {
  local out
  out=$(run_test_sql_ta << EOF
    INSERT INTO convos (id, student_id, name) VALUES (uuidv7(), '$STUDENT_ID', 'Soft delete') RETURNING id \\gset
    UPDATE convos SET deleted_at = NOW() WHERE id = :'id';
    SELECT count(*) FROM convos WHERE id = :'id' AND deleted_at IS NULL;
EOF
  )
  echo "$out" | grep -q '^0$' || { echo "output was: $out"; return 1; }
}
assert_success "convos: soft-deleted row excluded by active predicate" test_convos_soft_delete_excluded_by_partial_index

test_convos_timestamp_bypass() {
  local out
  out=$(run_test_sql_ta << EOF
    INSERT INTO convos (id, student_id, name, created_at, updated_at, row_updated_at)
    VALUES (uuidv7(), '$STUDENT_ID', 'Bypass',
            '2020-01-01T00:00:00Z'::timestamptz,
            '2020-01-01T00:00:00Z'::timestamptz,
            '2020-01-01T00:00:00Z'::timestamptz)
    RETURNING id \\gset
    SET LOCAL unicoach.bypass_logical_timestamp = 'true';
    UPDATE convos SET name = 'Bypassed' WHERE id = :'id';
    SELECT (updated_at = '2020-01-01T00:00:00Z'::timestamptz)
      || '|' || (row_updated_at > '2020-01-01T00:00:00Z'::timestamptz)
    FROM convos WHERE id = :'id';
EOF
  )
  echo "$out" | grep -q '^true|true$' || { echo "output was: $out"; return 1; }
}
assert_success "convos: bypass keeps updated_at but advances row_updated_at" test_convos_timestamp_bypass

# ==========================================================================
echo "==== convo_requests (log) ===="
# ==========================================================================

test_convo_requests_monotonic_ids() {
  local out
  out=$(run_test_sql_ta << EOF
    INSERT INTO convo_requests (convo_id, provider, model_requested, system_prompt_version, content)
    VALUES ('$CONVO_ID', 'anthropic', 'claude-opus-4-8', 'v1', '{}'::jsonb) RETURNING id AS id_a \\gset
    INSERT INTO convo_requests (convo_id, provider, model_requested, system_prompt_version, content)
    VALUES ('$CONVO_ID', 'anthropic', 'claude-opus-4-8', 'v1', '{}'::jsonb) RETURNING id AS id_b \\gset
    SELECT (:id_b > :id_a);
EOF
  )
  echo "$out" | grep -q '^t$' || { echo "output was: $out"; return 1; }
}
assert_success "convo_requests: ids monotonically increase" test_convo_requests_monotonic_ids

