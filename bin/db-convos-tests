# ==========================================================================
echo "==== Cascade topology (declared but inert) ===="
# ==========================================================================

test_cascade_delete_rules() {
  # All five FKs in the erasure chain must report CASCADE.
  local out
  out=$(echo "
    SELECT tc.constraint_name || ':' || rc.delete_rule
    FROM information_schema.referential_constraints rc
    JOIN information_schema.table_constraints tc
      ON tc.constraint_name = rc.constraint_name
     AND tc.constraint_schema = rc.constraint_schema
    WHERE tc.table_name IN ('convos','convo_requests','convo_responses','convo_responses_raw')
    ORDER BY 1;" | bin/db-query -tA 2>&1)
  # Every reported FK on these tables must be CASCADE; none may be NO ACTION/RESTRICT.
  if echo "$out" | grep -qv ':CASCADE$'; then
    echo "output was: $out"; return 1
  fi
  # Confirm at least five rows (the five chain FKs).
  local n
  n=$(echo "$out" | grep -c ':CASCADE$')
  [ "$n" -ge 5 ] || { echo "expected >=5 CASCADE FKs, got $n: $out"; return 1; }
}
assert_success "cascade: all chain FKs report delete_rule = CASCADE" test_cascade_delete_rules

test_cascade_inert_on_convos_delete() {
  # A physical DELETE over a full request/response/raw subtree is rejected by the
  # BEFORE DELETE guard, which aborts the would-be cascade before any child is
  # removed. The reject and the survival check run in SEPARATE connections:
  # ON_ERROR_STOP aborts the raising statement's whole psql script, so a single
  # transaction cannot both raise and then read back. The committed fixture
  # subtree (CASCADE_*) survives the rolled-back delete attempt.
  local reject_out survive_out
  reject_out=$(run_test_sql << EOF
    DELETE FROM convos WHERE id = '$CASCADE_CONVO_ID';
EOF
  )
  echo "$reject_out" | grep -q 'Physical deletions are strictly blocked' || { echo "output was: $reject_out"; return 1; }

  survive_out=$(echo "
    SELECT (SELECT count(*) FROM convos WHERE id = '$CASCADE_CONVO_ID')::text || '|' ||
           (SELECT count(*) FROM convo_requests WHERE id = $CASCADE_REQUEST_ID)::text || '|' ||
           (SELECT count(*) FROM convo_responses WHERE id = $CASCADE_RESPONSE_ID)::text || '|' ||
           (SELECT count(*) FROM convo_responses_raw WHERE response_id = $CASCADE_RESPONSE_ID)::text;" \
    | bin/db-query -tA 2>&1)
  echo "$survive_out" | grep -q '^1|1|1|1$' || { echo "output was: $survive_out"; return 1; }
}
assert_success "cascade: physical DELETE FROM convos rejected, subtree intact (inert)" test_cascade_inert_on_convos_delete

end_tests
