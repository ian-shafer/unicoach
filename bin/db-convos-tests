test_convo_requests_content_any_json_shape() {
  local out
  out=$(run_test_sql << EOF
    INSERT INTO convo_requests (convo_id, provider, model_requested, system_prompt_version, content)
    VALUES ('$CONVO_ID', 'anthropic', 'claude-opus-4-8', 'v1', '[1,2,3]'::jsonb);
    INSERT INTO convo_requests (convo_id, provider, model_requested, system_prompt_version, content)
    VALUES ('$CONVO_ID', 'anthropic', 'claude-opus-4-8', 'v1', '42'::jsonb);
    INSERT INTO convo_requests (convo_id, provider, model_requested, system_prompt_version, content)
    VALUES ('$CONVO_ID', 'anthropic', 'claude-opus-4-8', 'v1', '{"k":"v"}'::jsonb);
EOF
  )
  echo "$out" | grep -q 'ERROR' && { echo "output was: $out"; return 1; }
  return 0
}
assert_success "convo_requests: content accepts object/array/scalar JSON" test_convo_requests_content_any_json_shape

