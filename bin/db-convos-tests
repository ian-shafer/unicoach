#!/usr/bin/env bash
# Schema-test harness for RFC 32 coaching conversations (convos,
# convo_requests, convo_responses, convo_responses_raw).
#
# Modeled on bin/db-users-tests, with ONE deliberate divergence: this harness
# OWNS NO POSTGRES LIFECYCLE. It sets no EXIT/INT/TERM trap and runs no
# postgres-up/postgres-down/rm -rf $POSTGRES_DATA_DIR/db-init/db-migrate. It
# assumes a live, already-migrated database supplied by the caller (bin/test or
# a developer who has run db-init/db-migrate). Copying db-users-tests's
# self-contained lifecycle (with its EXIT-trap postgres-down) would tear
# Postgres down before bin/test's Gradle phase.
export ENV_FILE="$(dirname "$0")/../.env.test"
source "$(dirname "$0")/common"
source "$(dirname "$0")/tests-common"

# --- helpers --------------------------------------------------------------

# Run SQL inside a BEGIN/ROLLBACK so per-assertion writes never persist.
run_test_sql() {
  (
    echo "BEGIN;"
    cat
    echo "ROLLBACK;"
  ) | bin/db-run rw 2>&1
}

# Same, but tuples-only / unaligned for clean machine-readable output.
run_test_sql_ta() {
  (
    echo "BEGIN;"
    cat
    echo "ROLLBACK;"
  ) | bin/db-run rw -tA 2>&1
}

# --- fixture --------------------------------------------------------------
# A committed users row, then a committed students row referencing it. The
# returned students.id is the student_id every convos case reuses. The fixture
# is committed (not rolled back) so the distinct psql processes spawned per
# assertion all observe it.

echo "==== Coaching Conversations: fixture setup ===="

# Insert the fixture user (committed), then read its id back.
echo "INSERT INTO users (email, name, password_hash)
      VALUES ('convos-fixture@example.com', 'Convos Fixture', 'hash');" \
  | bin/db-run rw >/dev/null

USER_ID=$(echo "SELECT id FROM users WHERE email = 'convos-fixture@example.com';" \
  | bin/db-query -tA | grep -E '^[0-9a-f-]{36}$')

STUDENT_ID=$(
  echo "INSERT INTO students (user_id, expected_high_school_graduation_year)
        VALUES ('$USER_ID', 2030)
        RETURNING id;" | bin/db-run rw -tA | grep -E '^[0-9a-f-]{36}$'
)

if [ -z "$STUDENT_ID" ]; then
  fail_test "fixture: could not create student row"
fi
pass_test "fixture user + student created (student_id=$STUDENT_ID)"

# A committed convo owned by the fixture student, reused by log cases that need
# a real convo_id. Likewise a committed request/response for response/raw cases.
CONVO_ID=$(
  echo "INSERT INTO convos (student_id, name) VALUES ('$STUDENT_ID', 'Fixture convo') RETURNING id;" \
    | bin/db-run rw -tA | grep -E '^[0-9a-f-]{36}$'
)
if [ -z "$CONVO_ID" ]; then
  fail_test "fixture: could not create convo row"
fi
pass_test "fixture convo created (convo_id=$CONVO_ID)"

REQUEST_ID=$(
  echo "INSERT INTO convo_requests (convo_id, provider, model_requested, system_prompt_version, content)
        VALUES ('$CONVO_ID', 'anthropic', 'claude-opus-4-8', 'v1', '{\"text\":\"hi\"}'::jsonb)
        RETURNING id;" | bin/db-run rw -tA | grep -E '^[0-9]+$'
)
if [ -z "$REQUEST_ID" ]; then
  fail_test "fixture: could not create convo_requests row"
fi
pass_test "fixture convo_request created (request_id=$REQUEST_ID)"

RESPONSE_ID=$(
  echo "INSERT INTO convo_responses (request_id, convo_id, content, model_resolved, stop_reason)
        VALUES ($REQUEST_ID, '$CONVO_ID', '{\"text\":\"hello\"}'::jsonb, 'claude-opus-4-8', 'end_turn')
        RETURNING id;" | bin/db-run rw -tA | grep -E '^[0-9]+$'
)
if [ -z "$RESPONSE_ID" ]; then
  fail_test "fixture: could not create convo_responses row"
fi
pass_test "fixture convo_response created (response_id=$RESPONSE_ID)"

# A second, committed, full convo->request->response->raw subtree used solely by
# the cascade-inert test. Committed (not rolled back) so the physical-delete
# attempt and the post-attempt survival check can run in separate connections —
# ON_ERROR_STOP aborts the raising statement's whole script, so the reject and
# the survival check cannot share one psql invocation.
CASCADE_CONVO_ID=$(
  echo "INSERT INTO convos (student_id, name) VALUES ('$STUDENT_ID', 'Cascade convo') RETURNING id;" \
    | bin/db-run rw -tA | grep -E '^[0-9a-f-]{36}$'
)
CASCADE_REQUEST_ID=$(
  echo "INSERT INTO convo_requests (convo_id, provider, model_requested, system_prompt_version, content)
        VALUES ('$CASCADE_CONVO_ID', 'anthropic', 'claude-opus-4-8', 'v1', '{}'::jsonb)
        RETURNING id;" | bin/db-run rw -tA | grep -E '^[0-9]+$'
)
CASCADE_RESPONSE_ID=$(
  echo "INSERT INTO convo_responses (request_id, convo_id, content, model_resolved, stop_reason)
        VALUES ($CASCADE_REQUEST_ID, '$CASCADE_CONVO_ID', '{}'::jsonb, 'claude-opus-4-8', 'end_turn')
        RETURNING id;" | bin/db-run rw -tA | grep -E '^[0-9]+$'
)
echo "INSERT INTO convo_responses_raw (response_id, payload) VALUES ($CASCADE_RESPONSE_ID, '{}'::jsonb);" \
  | bin/db-run rw >/dev/null
if [ -z "$CASCADE_CONVO_ID" ] || [ -z "$CASCADE_REQUEST_ID" ] || [ -z "$CASCADE_RESPONSE_ID" ]; then
  fail_test "fixture: could not create cascade subtree"
fi
pass_test "fixture cascade subtree created (convo_id=$CASCADE_CONVO_ID)"

# ==========================================================================
echo "==== convos (entity) ===="
# ==========================================================================

test_convos_minimal_insert_no_name_rejected() {
  local out
  out=$(run_test_sql << EOF
    INSERT INTO convos (student_id) VALUES ('$STUDENT_ID');
EOF
  )
  echo "$out" | grep -qi 'null value in column "name"' || { echo "output was: $out"; return 1; }
}
assert_success "convos: insert with only student_id (no name) rejected (NOT NULL, 23502)" test_convos_minimal_insert_no_name_rejected

test_convos_minimal_insert_with_name() {
  local out
  out=$(run_test_sql_ta << EOF
    INSERT INTO convos (student_id, name) VALUES ('$STUDENT_ID', 'Calc help')
    RETURNING (id IS NOT NULL)
      || '|' || (created_at IS NOT NULL)
      || '|' || (row_created_at IS NOT NULL)
      || '|' || (updated_at IS NOT NULL)
      || '|' || (row_updated_at IS NOT NULL)
      || '|' || (deleted_at IS NULL);
EOF
  )
  echo "$out" | grep -q '^true|true|true|true|true|true$' || { echo "output was: $out"; return 1; }
}
assert_success "convos: minimal insert with student_id + name takes defaults" test_convos_minimal_insert_with_name

test_convos_bad_student_fk() {
  local out
  out=$(run_test_sql << 'EOF'
    INSERT INTO convos (student_id, name) VALUES ('00000000-0000-0000-0000-000000000000', 'Orphan');
EOF
  )
  echo "$out" | grep -q 'violates foreign key constraint' || { echo "output was: $out"; return 1; }
}
assert_success "convos: non-existent student_id rejected (FK)" test_convos_bad_student_fk

test_convos_name_null_rejected() {
  local out
  out=$(run_test_sql << EOF
    INSERT INTO convos (student_id, name) VALUES ('$STUDENT_ID', NULL);
EOF
  )
  echo "$out" | grep -qi 'null value in column "name"' || { echo "output was: $out"; return 1; }
}
assert_success "convos: NULL name rejected (NOT NULL, 23502)" test_convos_name_null_rejected

test_convos_name_too_long() {
  local out
  out=$(run_test_sql << EOF
    INSERT INTO convos (student_id, name)
    VALUES ('$STUDENT_ID', repeat('a', 256));
EOF
  )
  echo "$out" | grep -q 'convos_name_length_check' || { echo "output was: $out"; return 1; }
}
assert_success "convos: 256-char name rejected (length check)" test_convos_name_too_long

test_convos_name_blank() {
  local out
  out=$(run_test_sql << EOF
    INSERT INTO convos (student_id, name) VALUES ('$STUDENT_ID', '   ');
EOF
  )
  echo "$out" | grep -q 'convos_name_not_empty_check' || { echo "output was: $out"; return 1; }
}
assert_success "convos: whitespace-only name rejected (not-empty check)" test_convos_name_blank

test_convos_name_untrimmed() {
  local out
  out=$(run_test_sql << EOF
    INSERT INTO convos (student_id, name) VALUES ('$STUDENT_ID', ' Calc ');
