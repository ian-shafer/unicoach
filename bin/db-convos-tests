assert_success "convo_requests: non-existent convo_id rejected (FK)" test_convo_requests_bad_convo_fk

test_convo_requests_update_rejected() {
  local out
  out=$(run_test_sql << EOF
    UPDATE convo_requests SET system_prompt_version = 'v2' WHERE id = $REQUEST_ID;
EOF
  )
  echo "$out" | grep -q 'Log rows are append-only and cannot be updated.' || { echo "output was: $out"; return 1; }
}
assert_success "convo_requests: UPDATE rejected (prevent_log_update)" test_convo_requests_update_rejected

test_convo_requests_delete_rejected() {
  local out
  out=$(run_test_sql << EOF
    DELETE FROM convo_requests WHERE id = $REQUEST_ID;
EOF
  )
  echo "$out" | grep -q 'Log rows cannot be deleted; prune by partition/retention.' || { echo "output was: $out"; return 1; }
}
assert_success "convo_requests: DELETE rejected (prevent_log_delete)" test_convo_requests_delete_rejected

# ==========================================================================
echo "==== convo_responses (log) ===="
# ==========================================================================

test_convo_responses_unique_request() {
  local out
  out=$(run_test_sql << EOF
    INSERT INTO convo_requests (convo_id, provider, model_requested, system_prompt_version, content)
    VALUES ('$CONVO_ID', 'anthropic', 'claude-opus-4-8', 'v1', '{}'::jsonb) RETURNING id AS rid \\gset
    INSERT INTO convo_responses (request_id, convo_id, content, model_resolved, stop_reason)
    VALUES (:rid, '$CONVO_ID', '{}'::jsonb, 'claude-opus-4-8', 'end_turn');
    INSERT INTO convo_responses (request_id, convo_id, content, model_resolved, stop_reason)
    VALUES (:rid, '$CONVO_ID', '{}'::jsonb, 'claude-opus-4-8', 'end_turn');
EOF
  )
  echo "$out" | grep -q 'duplicate key value violates unique constraint' || { echo "output was: $out"; return 1; }
}
assert_success "convo_responses: second response for a request_id rejected (UNIQUE 1:1)" test_convo_responses_unique_request

