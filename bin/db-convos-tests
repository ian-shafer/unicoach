test_convo_requests_content_oversized() {
  local out
  out=$(run_test_sql << EOF
    INSERT INTO convo_requests (convo_id, provider, model_requested, system_prompt_version, content)
    VALUES ('$CONVO_ID', 'anthropic', 'claude-opus-4-8', 'v1',
            jsonb_build_object('big', repeat('x', 1048577)));
EOF
  )
  echo "$out" | grep -q 'convo_requests_content_size_check' || { echo "output was: $out"; return 1; }
}
assert_success "convo_requests: content over 1 MiB rejected (size check)" test_convo_requests_content_oversized

