# ==========================================================================
echo "==== Ordered replay ===="
# ==========================================================================

test_replay_insertion_order() {
  local out
  out=$(run_test_sql_ta << EOF
    INSERT INTO convos (student_id, name) VALUES ('$STUDENT_ID', 'Replay order') RETURNING id AS cid \\gset
    INSERT INTO convo_requests (convo_id, provider, model_requested, system_prompt_version, content)
    VALUES (:'cid', 'anthropic', 'claude-opus-4-8', 'v1', '{"n":1}'::jsonb);
    INSERT INTO convo_requests (convo_id, provider, model_requested, system_prompt_version, content)
    VALUES (:'cid', 'anthropic', 'claude-opus-4-8', 'v1', '{"n":2}'::jsonb);
    INSERT INTO convo_requests (convo_id, provider, model_requested, system_prompt_version, content)
    VALUES (:'cid', 'anthropic', 'claude-opus-4-8', 'v1', '{"n":3}'::jsonb);
    SELECT string_agg(content->>'n', ',' ORDER BY created_at, id)
    FROM convo_requests WHERE convo_id = :'cid';
EOF
  )
  echo "$out" | grep -q '^1,2,3$' || { echo "output was: $out"; return 1; }
}
assert_success "replay: three separate-statement requests read back in insertion order" test_replay_insertion_order

test_replay_same_txn_tiebreaker() {
  # All three rows share an identical transaction-time created_at; the id
  # tiebreaker must yield a stable total order matching insertion order.
  local out
  out=$(run_test_sql_ta << EOF
    INSERT INTO convos (student_id, name) VALUES ('$STUDENT_ID', 'Replay tiebreaker') RETURNING id AS cid \\gset
    INSERT INTO convo_requests (convo_id, provider, model_requested, system_prompt_version, content)
    VALUES
      (:'cid', 'anthropic', 'claude-opus-4-8', 'v1', '{"n":1}'::jsonb),
      (:'cid', 'anthropic', 'claude-opus-4-8', 'v1', '{"n":2}'::jsonb);
    SELECT count(DISTINCT created_at)::text || '|' ||
           string_agg(content->>'n', ',' ORDER BY created_at, id)
    FROM convo_requests WHERE convo_id = :'cid';
EOF
  )
  echo "$out" | grep -q '^1|1,2$' || { echo "output was: $out"; return 1; }
}
assert_success "replay: same-transaction rows ordered by id tiebreaker" test_replay_same_txn_tiebreaker

test_replay_full_turn_join() {
  local out
  out=$(run_test_sql_ta << EOF
    INSERT INTO convos (student_id, name) VALUES ('$STUDENT_ID', 'Replay join') RETURNING id AS cid \\gset
    INSERT INTO convo_requests (convo_id, provider, model_requested, system_prompt_version, content)
    VALUES (:'cid', 'anthropic', 'claude-opus-4-8', 'v1', '{"q":"hi"}'::jsonb) RETURNING id AS rid \\gset
    INSERT INTO convo_responses (request_id, convo_id, content, model_resolved, stop_reason)
    VALUES (:rid, :'cid', '{"a":"yo"}'::jsonb, 'claude-opus-4-8', 'end_turn') RETURNING id AS resid \\gset
    INSERT INTO convo_responses_raw (response_id, payload) VALUES (:resid, '{"raw":"verbatim"}'::jsonb);
    SELECT (req.content->>'q') || '|' || (resp.content->>'a') || '|' || (raw.payload->>'raw')
    FROM convo_requests req
    JOIN convo_responses resp ON resp.request_id = req.id
    JOIN convo_responses_raw raw ON raw.response_id = resp.id
    WHERE req.id = :rid;
EOF
  )
  echo "$out" | grep -q '^hi|yo|verbatim$' || { echo "output was: $out"; return 1; }
}
assert_success "replay: request + response + raw join reconstructs full turn" test_replay_full_turn_join

