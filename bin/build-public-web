#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
build-public-web [options]

Produces a self-contained installDist distribution for :public-web via
Gradle. The resulting launch script is located at:
  public-web/build/install/public-web/bin/public-web

Options:
  -h: Help
EOF
  exit "$exit_code"
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) fatal "unknown option [-$OPTARG]" ;;
  :)  fatal "option -$OPTARG requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -gt 0 ]; then
  help "build-public-web does not accept positional arguments: $*"
fi

exec "$PROJECT_ROOT/gradlew" :public-web:installDist
