#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
db-query [-d <db>] [-r | -x] [sql]

Arguments:
  sql: Optional SQL statement; when omitted, psql reads stdin

Options:
  -d <db>: Override the target database
  -r:      Raw output      -> psql -t -A
  -x:      Expanded output -> psql -x -P border=0
  -h:      Help
EOF
  exit 0
}

DB_FLAGS=()
OUTPUT_FLAGS=()
RAW=
EXPANDED=

while getopts ":d:rxh" opt; do
  case "$opt" in
  d) DB_FLAGS=("-d" "$OPTARG") ;;
  r) RAW=1 ;;
  x) EXPANDED=1 ;;
  h) help ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ -n "$RAW" ] && [ -n "$EXPANDED" ]; then
  fatal -s "$EXIT_EXCLUSIVE_OPTIONS" "options -r and -x are mutually exclusive"
fi
if [ -n "$RAW" ]; then
  OUTPUT_FLAGS=("-r")
elif [ -n "$EXPANDED" ]; then
  OUTPUT_FLAGS=("-x")
fi

if [ "$#" -gt 1 ]; then
  fatal -s "$EXIT_UNEXPECTED_ARG" "db-query accepts at most one SQL argument; received: $*"
fi

SQL_ARG=()
if [ "$#" -eq 1 ]; then
  SQL_ARG=("$1")
fi

"$PROJECT_ROOT/bin/db-run" "${DB_FLAGS[@]}" "${OUTPUT_FLAGS[@]}" ro "${SQL_ARG[@]}"
