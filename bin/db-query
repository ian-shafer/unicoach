#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
db-query [sql] [options]

Arguments:
  sql: Optional SQL statement

Options:
  -d <db>: Override the target database
  -h:      Help
EOF
  exit "$exit_code"
}

DB_FLAGS=()

# Parse only the leading -d/-h options. The first unrecognized option (e.g. a
# psql flag such as -tA or -x) ends option parsing and begins the verbatim
# passthrough to db-run, exactly as the prior `*) break` did. On that unknown
# option, leave OPTIND pointing at it so it survives the shift below: getopts
# already points there mid-cluster (-tA), but advances past a standalone
# single-letter unknown (-x), so step OPTIND back in that case.
while getopts ":d:h" opt; do
  case "$opt" in
  d) DB_FLAGS=("-d" "$OPTARG") ;;
  h) help ;;
  \?)
    if [ "$OPTIND" -gt 1 ]; then
      eval "prevarg=\${$((OPTIND-1))}"
      [ "$prevarg" = "-$OPTARG" ] && OPTIND=$((OPTIND-1))
    fi
    break
    ;;
  :)  help "option -$OPTARG requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ ${#DB_FLAGS[@]} -eq 0 ]; then
  exec "$PROJECT_ROOT/bin/db-run" ro "$@"
else
  exec "$PROJECT_ROOT/bin/db-run" "${DB_FLAGS[@]}" ro "$@"
fi
