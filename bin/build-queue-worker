#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
build-queue-worker [options]

Produces a self-contained installDist distribution for :queue-worker via
Gradle. The resulting launch script is located at:
  queue-worker/build/install/queue-worker/bin/queue-worker

Options:
  -h: Help
EOF
  exit 0
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -gt 0 ]; then
  fatal -s "$EXIT_UNEXPECTED_ARG" "build-queue-worker does not accept positional arguments: $*"
fi

"$PROJECT_ROOT/gradlew" :queue-worker:installDist
