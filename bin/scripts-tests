#!/usr/bin/env bash
export ENV_FILE="$(dirname "$0")/../.env.test"
source "$(dirname "$0")/common"
source "$(dirname "$0")/tests-common"

trap 'bin/rest-server-stop -d >/dev/null 2>&1 || true; bin/queue-worker-stop -d >/dev/null 2>&1 || true; bin/postgres-stop -d >/dev/null 2>&1 || true; docker network rm unicoach-network >/dev/null 2>&1 || true' EXIT INT TERM

echo "Harness up"
echo ""



cleanPostgresData() {
  rm -rf "$POSTGRES_DATA_DIR" || true
}

# Wait gracefully for the database initialization scripts fully resolve internally
wait_for_postgres() {
  local container_id="$1"
  for i in {1..15}; do
    if docker exec "$container_id" psql -U postgres -d "$POSTGRES_DB" -c '\q' >/dev/null 2>&1; then return 0; fi
    sleep 1
  done
  echo "Fail: Timed out waiting for database '$POSTGRES_DB' runtime to become queryable organically."
  exit 1
}

TEST_LOCK="$PROJECT_ROOT/var/run/test.lock"
mkdir -p "$PROJECT_ROOT/var/run"

echo "==== Testing file-lock ===="
rm -rf "$TEST_LOCK" || true
rm -rf "${TEST_LOCK}.stale."* || true

bin/file-lock -o op-a "$TEST_LOCK" 60
if [ ! -d "$TEST_LOCK" ]; then echo "Fail: Failed to create lock"; exit 1; fi
pass_test "File lock created successfully"

bin/file-lock -o op-a "$TEST_LOCK" 60 || STATUS=$?
if [ "${STATUS:-0}" -ne 10 ]; then echo "Fail: Failed to fast-fail on matching op"; exit 1; fi
pass_test "File lock fast-failed on matching op"

rm -rf "$TEST_LOCK" || true
mkdir "$TEST_LOCK"
echo "op-a" > "$TEST_LOCK/op"
echo "10" > "$TEST_LOCK/expires-at"
if ! bin/file-lock -o op-a "$TEST_LOCK" 60; then
  echo "Fail: Failed to organically break a stale lock because the OP happened to loosely match."
  exit 1
fi
pass_test "File lock cleanly broke stale lock on loose match"

if bin/file-lock -t 1s -o op-b "$TEST_LOCK" 60 2>/dev/null; then echo "Fail: Failed to block conflicting op"; exit 1; fi
pass_test "File lock blocked conflicting op"

echo "$(( $(date +%s) - 10 ))" > "$TEST_LOCK/expires-at"
bin/file-lock -o op-c "$TEST_LOCK" 60
if [ "$(cat "$TEST_LOCK/op")" != "op-c" ]; then echo "Fail: Failed to recover stale lock"; exit 1; fi
pass_test "File lock recovered stale lock"

rm -rf "$TEST_LOCK" || true
rm -rf "${TEST_LOCK}.stale."* || true

test_daemon_wrapper() {
  local WRAPPER="$1"
  local ARG2="${2:-}"
  local SUFFIX=""
  if [ -n "$ARG2" ]; then
    SUFFIX=" $ARG2"
  fi
  local START_CMD="bin/$WRAPPER-start"
  local STOP_CMD="bin/$WRAPPER-stop"
  local RESTART_CMD="bin/$WRAPPER-restart"
  local CHECK_CMD="bin/$WRAPPER-check"

  echo ""
  echo "==== Testing Wrapper: $WRAPPER ===="

  # 1. Simple Start & Stop & 4. Idempotent Stop
  $STOP_CMD -d $SUFFIX >/dev/null || true
  if $CHECK_CMD $SUFFIX >/dev/null 2>&1; then echo "Fail: $WRAPPER claimed success despite stripped service."; exit 1; fi
  $START_CMD $SUFFIX >/dev/null
  if ! $CHECK_CMD $SUFFIX >/dev/null; then echo "Fail: $WRAPPER did not actually boot or reach a healthy state."; exit 1; fi
  pass_test "$WRAPPER Simple Start & Stop & Idempotent Stop"
  
  # 2. Idempotent Start
  if ! $START_CMD $SUFFIX >/dev/null; then echo "Fail: Redundant start was not idempotent for $WRAPPER."; exit 1; fi
  pass_test "$WRAPPER Idempotent Start"

  # 6. Restart Lifecycle
  if ! $RESTART_CMD $SUFFIX >/dev/null; then echo "Fail: Restart failed natively for $WRAPPER."; exit 1; fi
  if ! $CHECK_CMD $SUFFIX >/dev/null; then echo "Fail: Restart did not leave $WRAPPER securely running."; exit 1; fi
  pass_test "$WRAPPER Restart Lifecycle"

  # 3. Concurrent Start (After stopping first)
  $STOP_CMD $SUFFIX >/dev/null
  $START_CMD $SUFFIX >/dev/null & PID1=$!
  $START_CMD $SUFFIX >/dev/null & PID2=$!
  wait $PID1; if [ $? -ne 0 ]; then echo "Fail: Process 1 failed to boot daemon $WRAPPER"; exit 1; fi
  wait $PID2; if [ $? -ne 0 ]; then echo "Fail: Process 2 failed lock concurrency coordination $WRAPPER"; exit 1; fi
  if ! $CHECK_CMD $SUFFIX >/dev/null; then echo "Fail: $WRAPPER concurrent start didn't end up healthy."; exit 1; fi
  pass_test "$WRAPPER Concurrent Start"

  # 5. Concurrent Stop
  $STOP_CMD $SUFFIX >/dev/null & PID3=$!
  $STOP_CMD $SUFFIX >/dev/null & PID4=$!
  wait $PID3; if [ $? -ne 0 ]; then echo "Fail: Process 3 failed concurrent stop for $WRAPPER"; exit 1; fi
  wait $PID4; if [ $? -ne 0 ]; then echo "Fail: Process 4 failed concurrent stop coordination for $WRAPPER"; exit 1; fi
  if $CHECK_CMD $SUFFIX >/dev/null 2>&1; then echo "Fail: Concurrent stop didn't actually stop $WRAPPER"; exit 1; fi
  pass_test "$WRAPPER Concurrent Stop"
  
  # Check invalid flag for check
  if ! $CHECK_CMD -h >/dev/null; then echo "Fail: Help flag did not natively exit 0 on check for $WRAPPER"; exit 1; fi
  pass_test "$WRAPPER Help flag returned 0"
}

test_daemon_wrapper "rest-server"
test_daemon_wrapper "queue-worker"
test_daemon_wrapper "postgres"

echo ""
echo "==== Testing docker-status ===="
if ! bin/docker-status -h >/dev/null; then echo "Fail: docker-status -h did not exit 0"; exit 1; fi
pass_test "docker-status help flag returned 0"

# postgres is still running after test_daemon_wrapper "postgres"
bin/postgres-start >/dev/null
docker_status_out="$(bin/docker-status)"
if ! echo "$docker_status_out" | grep "postgres" | grep "running" >/dev/null; then
  echo "Fail: docker-status did not report postgres as running"
  echo "$docker_status_out"
  exit 1
fi
if ! echo "$docker_status_out" | grep "rest-server" | grep "stopped" >/dev/null; then
  echo "Fail: docker-status did not report rest-server as stopped"
  echo "$docker_status_out"
  exit 1
fi
pass_test "docker-status output accuracy"

echo ""
echo "==== Testing Bespoke Capabilities: postgres ===="

bin/postgres-stop -d >/dev/null || true
cleanPostgresData
bin/postgres-start >/dev/null

postgres_container="$(bin/docker-compose -f docker/postgres-compose.yaml ps -q postgres)"
wait_for_postgres "$postgres_container"

if ! docker exec "$postgres_container" psql -U postgres -d "$POSTGRES_DB" -c "CREATE TABLE test_data (id INT); INSERT INTO test_data VALUES (42);" >/dev/null; then
  echo "Fail: Could not seed test data."
  exit 1
fi

bin/postgres-stop -d >/dev/null
bin/postgres-start >/dev/null

postgres_container="$(bin/docker-compose -f docker/postgres-compose.yaml ps -q postgres)"
wait_for_postgres "$postgres_container"

if ! docker exec "$postgres_container" psql -U postgres -d "$POSTGRES_DB" -c "SELECT * FROM test_data;" | grep "42" >/dev/null; then
  echo "Fail: Data persistence failed across -d teardown."
  exit 1
fi
pass_test "postgres Data Persistence"

cleanPostgresData


echo "==== Testing Environment Validation ===="
bin/postgres-stop -d >/dev/null
POSTGRES_USER="" bin/postgres-start >/dev/null 2>&1 || STATUS=$?
if [ -z "${STATUS:-}" ] || [ "$STATUS" -eq 0 ]; then
  echo "Fail: Postgres started despite missing POSTGRES_USER."
  exit 1
fi
pass_test "postgres Missing Environment Validation"

echo ""
echo "==== Testing Bash Utilities ===="
test_validate_duration_valid() {
  if ! validate_duration 5s; then return 1; fi
  if ! validate_duration 10m; then return 1; fi
  if ! validate_duration 2h; then return 1; fi
  if ! validate_duration 1d; then return 1; fi
  return 0
}
assert_success "validate_duration valid" test_validate_duration_valid

test_validate_duration_invalid() {
  if validate_duration 5x; then return 1; fi
  if validate_duration s; then return 1; fi
  if validate_duration ""; then return 1; fi
  return 0
}
assert_success "validate_duration invalid" test_validate_duration_invalid

test_transform_duration_to_postgres_valid() {
  if [ "$(transform_duration_to_postgres 5s)" != "5 seconds" ]; then return 1; fi
  if [ "$(transform_duration_to_postgres 10m)" != "10 minutes" ]; then return 1; fi
  if [ "$(transform_duration_to_postgres 2h)" != "2 hours" ]; then return 1; fi
  if [ "$(transform_duration_to_postgres 1d)" != "1 days" ]; then return 1; fi
  return 0
}
assert_success "transform_duration_to_postgres valid" test_transform_duration_to_postgres_valid

test_require_dangerous_confirmation_success() {
  echo "Yes, I really want to do this" | require_dangerous_confirmation "test" >/dev/null 2>&1
}
assert_success "require_dangerous_confirmation success" test_require_dangerous_confirmation_success

test_require_dangerous_confirmation_empty() {
  (echo "" | require_dangerous_confirmation "test" >/dev/null 2>&1)
}
assert_success "require_dangerous_confirmation empty" test_require_dangerous_confirmation_empty

# Validates the caller-side flag bypass pattern used by q-truncate and db-destroy:
# when --yes-i-really-want-to-do-this is present, the prompt is never invoked.
test_require_dangerous_confirmation_flag() {
  skip_prompt=false
  for arg in --yes-i-really-want-to-do-this; do
    case "$arg" in
      --yes-i-really-want-to-do-this) skip_prompt=true ;;
    esac
  done
  if [ "$skip_prompt" = false ]; then
    require_dangerous_confirmation "test" >/dev/null 2>&1
  fi
}
assert_success "require_dangerous_confirmation flag bypass" test_require_dangerous_confirmation_flag

end_tests
