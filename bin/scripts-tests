#!/usr/bin/env bash
export ENV_FILE="$(dirname "$0")/../.env.test"
# Make fatal/log-* available before the PORT guard. `functions` only defines
# functions — it sources no `.env` — so it does not disturb the bootstrap
# ordering (`common`/`.env.test` is still sourced afterward and re-defines these
# idempotently). PORT must still be picked before `common` so .env.test's
# PORT="${PORT:-8081}" and its SERVER_PORT=$PORT alias both resolve to it, and
# every service this suite boots (rest-server) binds a port that cannot collide
# with a developer's daemons running across worktrees. Tests never hardcode a
# port; only .env (prod/dev) does.
source "$(dirname "$0")/functions"
export PORT="$("$(dirname "$0")/find-free-port")"
# This runs before `common` activates `set -euo pipefail`, so a find-free-port
# failure would otherwise leave PORT="" and .env.test's `${PORT:-8081}` would
# silently fall back to the collision-prone 8081. Guard it explicitly via fatal.
if [ -z "$PORT" ]; then
  fatal "find-free-port returned no free port; refusing to fall back to a hardcoded port."
fi
source "$(dirname "$0")/common"
source "$(dirname "$0")/tests-common"

# Bounded-poll knobs, named once (50 x 0.1s = ~5s ceiling).
PORT_POLL_ATTEMPTS=50
PORT_POLL_INTERVAL=0.1
# Outer guard for the bounded-probe regression test: comfortably above
# daemon-http-check's HEALTH_CONNECT_TIMEOUT(2) + HEALTH_MAX_TIME(3); a hang
# would trip this and surface as exit 124 instead of wedging the suite.
BOUNDED_PROBE_GUARD_SECS=8

# Poll until <port> is free (check-port reports not-in-use), bounded. Returns 0
# once free, 1 on timeout. Replaces the inline `for i in {1..50}` free-polls.
wait_for_port_free() {
  local port="$1" i
  for ((i = 0; i < PORT_POLL_ATTEMPTS; i++)); do
    bin/check-port "$port" >/dev/null 2>&1 || return 0
    sleep "$PORT_POLL_INTERVAL"
  done
  return 1
}

# Every foreign listener this harness spawns records its PID here so the EXIT
# trap can reap any that a test forgot or that a mid-run abort skipped — a leaked
# listen socket would block a later run's curl / probe on the same port.
FOREIGN_LISTENER_PIDS=()

reap_foreign_listeners() {
  local pid
  for pid in "${FOREIGN_LISTENER_PIDS[@]:-}"; do
    [ -n "$pid" ] && kill -9 "$pid" 2>/dev/null || true
  done
}

# Tear down only the daemons this harness starts. The PostgreSQL cluster is
# shared across worktrees (see SPEC.md §II Shared Cluster) — never stop it.
trap 'bin/rest-server-down >/dev/null 2>&1 || true; bin/queue-worker-down >/dev/null 2>&1 || true; bin/daemon-down idem-test >/dev/null 2>&1 || true; bin/daemon-down collision-test >/dev/null 2>&1 || true; reap_foreign_listeners' EXIT INT TERM

echo "Harness up"
echo ""

TEST_LOCK="$PROJECT_ROOT/var/run/test.lock"
mkdir -p "$PROJECT_ROOT/var/run"

echo "==== Testing file-lock ===="
rm -rf "$TEST_LOCK" || true
rm -rf "${TEST_LOCK}.stale."* || true

bin/file-lock -o op-a "$TEST_LOCK" 60
if [ ! -d "$TEST_LOCK" ]; then echo "Fail: Failed to create lock"; exit 1; fi
pass_test "File lock created successfully"

bin/file-lock -o op-a "$TEST_LOCK" 60 || STATUS=$?
if [ "${STATUS:-0}" -ne 10 ]; then echo "Fail: Failed to fast-fail on matching op"; exit 1; fi
pass_test "File lock fast-failed on matching op"

rm -rf "$TEST_LOCK" || true
mkdir "$TEST_LOCK"
echo "op-a" > "$TEST_LOCK/op"
echo "10" > "$TEST_LOCK/expires-at"
if ! bin/file-lock -o op-a "$TEST_LOCK" 60; then
  echo "Fail: Failed to organically break a stale lock because the OP happened to loosely match."
  exit 1
fi
pass_test "File lock cleanly broke stale lock on loose match"

if bin/file-lock -t 1s -o op-b "$TEST_LOCK" 60 2>/dev/null; then echo "Fail: Failed to block conflicting op"; exit 1; fi
pass_test "File lock blocked conflicting op"

echo "$(( $(date +%s) - 10 ))" > "$TEST_LOCK/expires-at"
bin/file-lock -o op-c "$TEST_LOCK" 60
if [ "$(cat "$TEST_LOCK/op")" != "op-c" ]; then echo "Fail: Failed to recover stale lock"; exit 1; fi
pass_test "File lock recovered stale lock"

rm -rf "$TEST_LOCK" || true
rm -rf "${TEST_LOCK}.stale."* || true

# Foreign-listener helpers. Each spawns bin/test-tcp-listener (a real, lintable
# python3 file — bash cannot listen(), and the dev shell ships no nc/socat) to
# occupy 127.0.0.1:<port> with a PID NOT recorded in any var/run/*.pid file: the
# cross-worktree / foreign-occupant case. _spawn_test_listener sets the global
# FOREIGN_LISTENER_PID (NOT echoed — a $(...) subshell would lose the PID from
# the EXIT-trap tracking array) and blocks until the port is actually bound, so
# the probe never races. Pair each with stop_foreign_listener to bracket the
# assertion.
FOREIGN_LISTENER_PID=""

_spawn_test_listener() {
  local port="$1" mode="$2"
  "$PROJECT_ROOT/bin/test-tcp-listener" "$port" "$mode" >/dev/null 2>&1 &
  local listener_pid=$!
  FOREIGN_LISTENER_PIDS+=("$listener_pid")
  local i
  for ((i = 0; i < PORT_POLL_ATTEMPTS; i++)); do
    if bin/check-port "$port" >/dev/null 2>&1; then
      FOREIGN_LISTENER_PID="$listener_pid"
      return 0
    fi
    sleep "$PORT_POLL_INTERVAL"
  done
  kill -9 "$listener_pid" 2>/dev/null || true
  FOREIGN_LISTENER_PID=""
  return 1
}

# accept + immediately close: a fast empty reply, as a non-HTTP occupant gives.
start_foreign_listener() { _spawn_test_listener "$1" close; }

# accept + hold open, never replying: the "wedged server" case. An unbounded
# curl against this blocks forever, so it proves daemon-http-check's bounded
# probe gives up instead of hanging.
start_stalled_listener() { _spawn_test_listener "$1" hold; }

stop_foreign_listener() {
  local listener_pid="$1"
  [ -n "$listener_pid" ] && kill -9 "$listener_pid" 2>/dev/null || true
  wait "$listener_pid" 2>/dev/null || true
}

# Ensures postgres is up and the test database exists before starting any JVM daemon.
ensure_postgres_for_jvm() {
  bin/postgres-up >/dev/null
  for i in {1..15}; do
    if psql -U postgres -d "$POSTGRES_DB" -c '\q' >/dev/null 2>&1; then break; fi
    sleep 1
  done
  psql -U postgres -d postgres -tA \
    -c "SELECT 1 FROM pg_database WHERE datname = '$POSTGRES_DB'" \
    | grep -q 1 || psql -U postgres -d postgres -c "CREATE DATABASE \"$POSTGRES_DB\";" >/dev/null
}

test_daemon_wrapper() {
  local WRAPPER="$1"
  local UP_CMD="bin/$WRAPPER-up"
  local DOWN_CMD="bin/$WRAPPER-down"
  local BOUNCE_CMD="bin/$WRAPPER-bounce"
  local CHECK_CMD="bin/$WRAPPER-check"

  echo ""
  echo "==== Testing Wrapper: $WRAPPER ===="

  # 1. Simple Up & Down & 4. Idempotent Down
  $DOWN_CMD >/dev/null || true
  if $CHECK_CMD >/dev/null 2>&1; then echo "Fail: $WRAPPER claimed success despite stripped service."; exit 1; fi
  ensure_postgres_for_jvm
  $UP_CMD >/dev/null
  if ! $CHECK_CMD >/dev/null; then echo "Fail: $WRAPPER did not actually boot or reach a healthy state."; exit 1; fi
  pass_test "$WRAPPER Simple Up & Down & Idempotent Down"

  # 2. Idempotent Up
  if ! $UP_CMD >/dev/null; then echo "Fail: Redundant up was not idempotent for $WRAPPER."; exit 1; fi
  pass_test "$WRAPPER Idempotent Up"

  # 6. Restart Lifecycle
  if ! $BOUNCE_CMD >/dev/null; then echo "Fail: Bounce failed natively for $WRAPPER."; exit 1; fi
  if ! $CHECK_CMD >/dev/null; then echo "Fail: Restart did not leave $WRAPPER securely running."; exit 1; fi
  pass_test "$WRAPPER Restart Lifecycle"

  # Assert PID file exists and contains a running process after up
  PID_FILE="$PROJECT_ROOT/var/run/${WRAPPER}.pid"
  if [ ! -f "$PID_FILE" ]; then echo "Fail: PID file not found for $WRAPPER after up."; exit 1; fi
  running_pid="$(cat "$PID_FILE")"
  if ! bin/check-pid "$running_pid" >/dev/null 2>&1; then echo "Fail: PID in PID file is not alive for $WRAPPER."; exit 1; fi
  pass_test "$WRAPPER PID file created and process is alive"

  # Assert log file exists after up
  LOG_FILE="$PROJECT_ROOT/var/log/${WRAPPER}.log"
  if [ ! -f "$LOG_FILE" ]; then echo "Fail: Log file not found for $WRAPPER."; exit 1; fi
  pass_test "$WRAPPER log file created"

  # 3. Concurrent Up (After stopping first)
  $DOWN_CMD >/dev/null
  ensure_postgres_for_jvm
  $UP_CMD >/dev/null & PID1=$!
  $UP_CMD >/dev/null & PID2=$!
  wait $PID1; if [ $? -ne 0 ]; then echo "Fail: Process 1 failed to boot daemon $WRAPPER"; exit 1; fi
  wait $PID2; if [ $? -ne 0 ]; then echo "Fail: Process 2 failed lock concurrency coordination $WRAPPER"; exit 1; fi
  if ! $CHECK_CMD >/dev/null; then echo "Fail: $WRAPPER concurrent up didn't end up healthy."; exit 1; fi
  pass_test "$WRAPPER Concurrent Up"

  # 5. Concurrent Down
  $DOWN_CMD >/dev/null & PID3=$!
  $DOWN_CMD >/dev/null & PID4=$!
  wait $PID3; if [ $? -ne 0 ]; then echo "Fail: Process 3 failed concurrent down for $WRAPPER"; exit 1; fi
  wait $PID4; if [ $? -ne 0 ]; then echo "Fail: Process 4 failed concurrent down coordination for $WRAPPER"; exit 1; fi
  if $CHECK_CMD >/dev/null 2>&1; then echo "Fail: Concurrent down didn't actually stop $WRAPPER"; exit 1; fi
  pass_test "$WRAPPER Concurrent Down"

  # Assert PID file is removed after down
  if [ -f "$PID_FILE" ]; then echo "Fail: PID file still exists for $WRAPPER after down."; exit 1; fi
  pass_test "$WRAPPER PID file removed after down"

  # Assert stale PID file (process exited externally) is handled gracefully by down
  ensure_postgres_for_jvm
  $UP_CMD >/dev/null
  stale_pid="$(cat "$PID_FILE")"
  kill -KILL "$stale_pid" 2>/dev/null || true
  sleep 1
  if ! $DOWN_CMD >/dev/null; then echo "Fail: $WRAPPER down did not handle stale PID gracefully."; exit 1; fi
  if [ -f "$PID_FILE" ]; then echo "Fail: Stale PID file not cleaned up by down for $WRAPPER."; exit 1; fi
  pass_test "$WRAPPER stale PID file handled gracefully by down"

  # Assert daemon-up idempotency: second invocation while service is running exits 0 without duplicate
  ensure_postgres_for_jvm
  $UP_CMD >/dev/null
  first_pid="$(cat "$PID_FILE")"
  $UP_CMD >/dev/null
  second_pid="$(cat "$PID_FILE")"
  if [ "$first_pid" != "$second_pid" ]; then
    echo "Fail: daemon-up spawned a duplicate process for $WRAPPER (PIDs: $first_pid vs $second_pid)"
    exit 1
  fi
  pass_test "$WRAPPER idempotent up does not spawn duplicate process"

  # Check help flag for check
  if ! $CHECK_CMD -h >/dev/null; then echo "Fail: Help flag did not natively exit 0 on check for $WRAPPER"; exit 1; fi
  pass_test "$WRAPPER Help flag returned 0"
}

test_daemon_wrapper "rest-server"
test_daemon_wrapper "queue-worker"

# Ensure all services are stopped before the standalone section tests.
bin/rest-server-down >/dev/null 2>&1 || true
bin/queue-worker-down >/dev/null 2>&1 || true

echo ""
echo "==== Testing daemon-status ===="
if ! bin/daemon-status -h >/dev/null; then echo "Fail: daemon-status -h did not exit 0"; exit 1; fi
pass_test "daemon-status help flag returned 0"

# daemon-status now threads $PORT into the rest-server check, so the stopped
# assertion only holds when that port is actually free. Confirm it defensively
# (mirrors the foreign-listener teardown discipline) before asserting stopped.
if ! wait_for_port_free "${PORT:-8080}"; then
  echo "Fail: precondition — rest-server port ${PORT:-8080} must be free for the stopped assertion"
  exit 1
fi
daemon_status_out="$(bin/daemon-status)"
if ! echo "$daemon_status_out" | grep "rest-server" | grep "stopped" >/dev/null; then
  echo "Fail: daemon-status did not report rest-server as stopped"
  echo "$daemon_status_out"
  exit 1
fi
pass_test "daemon-status output accuracy"

# daemon-status conflict tri-state: a foreign listener on rest-server's port
# while its PID file is absent ⇒ a printed "conflict" line, not "stopped".
start_foreign_listener "${PORT:-8080}" || { echo "Fail: could not bind foreign listener on ${PORT:-8080}"; exit 1; }
ds_listener="$FOREIGN_LISTENER_PID"
daemon_status_conflict="$(bin/daemon-status)"
if ! echo "$daemon_status_conflict" | grep "rest-server" | grep "conflict" >/dev/null; then
  echo "Fail: daemon-status did not report rest-server as conflict when its port is foreign-held"
  echo "$daemon_status_conflict"
  stop_foreign_listener "$ds_listener"
  exit 1
fi
stop_foreign_listener "$ds_listener"
pass_test "daemon-status reports conflict when rest-server port is foreign-held"

echo ""
echo "==== Testing check-pid ===="
if ! bin/check-pid $$ >/dev/null; then echo "Fail: check-pid did not exit 0 for live PID"; exit 1; fi
pass_test "check-pid exits 0 when PID is alive"

if bin/check-pid 999999 >/dev/null 2>&1; then echo "Fail: check-pid did not exit 1 for nonexistent PID"; exit 1; fi
pass_test "check-pid exits 1 when PID does not exist"

echo ""
echo "==== Testing SIGKILL escalation ===="
mkdir -p "$PROJECT_ROOT/var/run" "$PROJECT_ROOT/var/log"
( trap '' TERM; while true; do sleep 1; done ) >/dev/null 2>&1 &
STUBBORN_PID=$!
echo "$STUBBORN_PID" > "$PROJECT_ROOT/var/run/sigkill-test.pid"
if ! bin/daemon-down sigkill-test >/dev/null; then echo "Fail: daemon-down failed on SIGKILL escalation test"; exit 1; fi
if bin/check-pid "$STUBBORN_PID" 2>/dev/null; then echo "Fail: Stubborn process still alive after SIGKILL"; exit 1; fi
pass_test "daemon-down escalates to SIGKILL when process ignores SIGTERM"

echo ""
echo "==== Testing Bash Utilities ===="
test_validate_duration_valid() {
  if ! validate_duration 5s; then return 1; fi
  if ! validate_duration 10m; then return 1; fi
  if ! validate_duration 2h; then return 1; fi
  if ! validate_duration 1d; then return 1; fi
  return 0
}
assert_success "validate_duration valid" test_validate_duration_valid

test_validate_duration_invalid() {
  if validate_duration 5x; then return 1; fi
  if validate_duration s; then return 1; fi
  if validate_duration ""; then return 1; fi
  return 0
}
assert_success "validate_duration invalid" test_validate_duration_invalid

test_transform_duration_to_postgres_valid() {
  if [ "$(transform_duration_to_postgres 5s)" != "5 seconds" ]; then return 1; fi
  if [ "$(transform_duration_to_postgres 10m)" != "10 minutes" ]; then return 1; fi
  if [ "$(transform_duration_to_postgres 2h)" != "2 hours" ]; then return 1; fi
  if [ "$(transform_duration_to_postgres 1d)" != "1 days" ]; then return 1; fi
  return 0
}
assert_success "transform_duration_to_postgres valid" test_transform_duration_to_postgres_valid

test_require_dangerous_confirmation_success() {
  echo "Yes, I really want to do this" | require_dangerous_confirmation "test" >/dev/null 2>&1
}
assert_success "require_dangerous_confirmation success" test_require_dangerous_confirmation_success

test_require_dangerous_confirmation_empty() {
  (echo "" | require_dangerous_confirmation "test" >/dev/null 2>&1)
}
assert_success "require_dangerous_confirmation empty" test_require_dangerous_confirmation_empty

# Validates the caller-side flag bypass pattern used by q-truncate and db-drop:
# when --yes-i-really-want-to-do-this is present, the prompt is never invoked.
test_require_dangerous_confirmation_flag() {
  skip_prompt=false
  for arg in --yes-i-really-want-to-do-this; do
    case "$arg" in
      --yes-i-really-want-to-do-this) skip_prompt=true ;;
    esac
  done
  if [ "$skip_prompt" = false ]; then
    require_dangerous_confirmation "test" >/dev/null 2>&1
  fi
}
assert_success "require_dangerous_confirmation flag bypass" test_require_dangerous_confirmation_flag

echo ""
echo "==== Testing deploy bundle completeness ===="
# The on-instance migration path (db-create-role -> db-create -> db-migrate)
# transitively sources/execs exactly this script set; every entry must ship in
# the deploy bundle or the migration fails on the instance. Guards against a
# future regression re-dropping postgres-check (or any migration-path script).
test_deploy_bundle_includes_migration_path() {
  local deploy="$PROJECT_ROOT/bin/deploy"
  # Extract the REPO_PATHS array body: the lines between "REPO_PATHS=(" and ")".
  local bundle
  bundle="$(awk '/^REPO_PATHS=\(/{f=1; next} f&&/^\)/{f=0} f' "$deploy")"
  local required=(
    "bin/common"
    "bin/functions"
    "bin/db-create-role"
    "bin/db-create"
    "bin/db-migrate"
    "bin/db-status"
    "bin/db-run"
    "bin/db-write"
    "bin/db-query"
    "bin/postgres-check"
  )
  local script
  for script in "${required[@]}"; do
    if ! echo "$bundle" | grep -q "\"$script\""; then
      fail_test "deploy bundle is missing migration-path script [$script]"
      return 1
    fi
  done
  return 0
}
assert_success "deploy bundle includes the full migration-path script set" test_deploy_bundle_includes_migration_path

# Three distinct free test ports, found at run time via bin/find-free-port (which
# uses check-port). Starting the scan at 18000 keeps them well above the harness
# PORT=8081 so a foreign listener here never collides with a real rest-server. If
# none is free, find-free-port fails and the suite aborts rather than guessing.
PORT_FREE="$(bin/find-free-port 18000)"
PORT_IDEM="$(bin/find-free-port $((PORT_FREE + 1)))"
PORT_HTTP="$(bin/find-free-port $((PORT_IDEM + 1)))"

echo ""
echo "==== Testing check-port ===="
# check-port: free
if bin/check-port "$PORT_FREE" >/dev/null 2>&1; then echo "Fail: check-port did not exit 1 for a free port"; exit 1; fi
pass_test "check-port exits 1 when port is free"

# check-port: in use, then free again after kill
start_foreign_listener "$PORT_FREE" || { echo "Fail: could not bind foreign listener on $PORT_FREE"; exit 1; }
cp_listener="$FOREIGN_LISTENER_PID"
if ! bin/check-port "$PORT_FREE" >/dev/null 2>&1; then echo "Fail: check-port did not exit 0 for a bound port"; stop_foreign_listener "$cp_listener"; exit 1; fi
pass_test "check-port exits 0 when port is in use"
stop_foreign_listener "$cp_listener"
# Wait for the kernel to release the socket, bounded.
if ! wait_for_port_free "$PORT_FREE"; then echo "Fail: check-port did not exit 1 after listener killed"; exit 1; fi
pass_test "check-port exits 1 again after listener is killed"

# check-port: invalid args
cp_status=0; bin/check-port >/dev/null 2>&1 || cp_status=$?
if [ "$cp_status" -ne 2 ]; then echo "Fail: check-port (no arg) did not exit 2 (got $cp_status)"; exit 1; fi
cp_status=0; bin/check-port notaport >/dev/null 2>&1 || cp_status=$?
if [ "$cp_status" -ne 2 ]; then echo "Fail: check-port notaport did not exit 2 (got $cp_status)"; exit 1; fi
pass_test "check-port exits 2 on missing / non-numeric argument"

echo ""
echo "==== Testing daemon-up port preflight ===="
# Cross-process collision regression (the reported bug; also covers the
# PID-file-lost / orphaned-alive edge case — indistinguishable from here).
rm -f "$PROJECT_ROOT/var/run/collision-test.pid"
rm -rf "$PROJECT_ROOT/var/run/collision-test.daemon.lock"
start_foreign_listener "$PORT_FREE" || { echo "Fail: could not bind foreign listener on $PORT_FREE"; exit 1; }
coll_listener="$FOREIGN_LISTENER_PID"
up_status=0
# Unique sentinel arg so this daemon command cannot be confused with the
# other `sleep 60` daemons elsewhere in the suite.
bin/daemon-up --port "$PORT_FREE" collision-test -- sleep 987654 >/dev/null 2>&1 || up_status=$?
if [ "$up_status" -ne 3 ]; then echo "Fail: daemon-up on a held port did not exit 3 (got $up_status)"; pkill -f 'sleep 987654' 2>/dev/null; stop_foreign_listener "$coll_listener"; exit 1; fi
if [ -f "$PROJECT_ROOT/var/run/collision-test.pid" ]; then echo "Fail: daemon-up wrote a PID file despite the collision"; pkill -f 'sleep 987654' 2>/dev/null; stop_foreign_listener "$coll_listener"; exit 1; fi
if [ -d "$PROJECT_ROOT/var/run/collision-test.daemon.lock" ]; then echo "Fail: daemon-up left the lock directory after a collision"; pkill -f 'sleep 987654' 2>/dev/null; stop_foreign_listener "$coll_listener"; exit 1; fi
if pgrep -f 'sleep 987654' >/dev/null 2>&1; then echo "Fail: daemon-up spawned a child despite the collision"; pkill -f 'sleep 987654' 2>/dev/null; stop_foreign_listener "$coll_listener"; exit 1; fi
# Defensive reap: if a future regression DID spawn, do not leak it.
pkill -f 'sleep 987654' 2>/dev/null || true
stop_foreign_listener "$coll_listener"
pass_test "daemon-up fatals (exit 3) on cross-process port collision without spawning or writing a PID"

# Idempotency preserved with --port (free port).
rm -f "$PROJECT_ROOT/var/run/idem-test.pid"
rm -rf "$PROJECT_ROOT/var/run/idem-test.daemon.lock"
bin/daemon-up --port "$PORT_IDEM" idem-test -- sleep 60 >/dev/null 2>&1
if [ ! -f "$PROJECT_ROOT/var/run/idem-test.pid" ]; then echo "Fail: daemon-up did not write a PID on a free port"; exit 1; fi
idem_first="$(cat "$PROJECT_ROOT/var/run/idem-test.pid")"
if ! bin/check-pid "$idem_first" >/dev/null 2>&1; then echo "Fail: idem-test PID is not alive after up"; exit 1; fi
bin/daemon-up --port "$PORT_IDEM" idem-test -- sleep 60 >/dev/null 2>&1
idem_second="$(cat "$PROJECT_ROOT/var/run/idem-test.pid")"
if [ "$idem_first" != "$idem_second" ]; then echo "Fail: idempotent up spawned a duplicate (PIDs $idem_first vs $idem_second)"; bin/daemon-down idem-test >/dev/null 2>&1; exit 1; fi
pass_test "daemon-up --port idempotent: second up reuses the same live PID"

# Concurrent-up exit-0 contract with --port: two racers, exactly one process.
bin/daemon-down idem-test >/dev/null 2>&1 || true
rm -f "$PROJECT_ROOT/var/run/idem-test.pid"
rm -rf "$PROJECT_ROOT/var/run/idem-test.daemon.lock"
bin/daemon-up --port "$PORT_IDEM" idem-test -- sleep 60 >/dev/null 2>&1 & cu1=$!
bin/daemon-up --port "$PORT_IDEM" idem-test -- sleep 60 >/dev/null 2>&1 & cu2=$!
cu1_status=0; wait $cu1 || cu1_status=$?
cu2_status=0; wait $cu2 || cu2_status=$?
if [ "$cu1_status" -ne 0 ] || [ "$cu2_status" -ne 0 ]; then echo "Fail: concurrent --port up did not both exit 0 ($cu1_status / $cu2_status)"; bin/daemon-down idem-test >/dev/null 2>&1; exit 1; fi
conc_pid="$(cat "$PROJECT_ROOT/var/run/idem-test.pid")"
if ! bin/check-pid "$conc_pid" >/dev/null 2>&1; then echo "Fail: concurrent --port up did not leave a live process"; exit 1; fi
pass_test "daemon-up --port concurrent up: both exit 0, exactly one process"

echo ""
echo "==== Testing daemon-check tri-state ===="
# Running (our PID is alive) ⇒ 0.
dc_status=0; bin/daemon-check --port "$PORT_IDEM" idem-test >/dev/null 2>&1 || dc_status=$?
if [ "$dc_status" -ne 0 ]; then echo "Fail: daemon-check on a running service did not exit 0 (got $dc_status)"; bin/daemon-down idem-test >/dev/null 2>&1; exit 1; fi
pass_test "daemon-check --port exits 0 when our PID is alive"

bin/daemon-down idem-test >/dev/null 2>&1 || true
rm -f "$PROJECT_ROOT/var/run/idem-test.pid"
# Stopped + port free ⇒ 1.
if bin/check-port "$PORT_IDEM" >/dev/null 2>&1; then echo "Fail: precondition — $PORT_IDEM must be free after down"; exit 1; fi
dc_status=0; bin/daemon-check --port "$PORT_IDEM" idem-test >/dev/null 2>&1 || dc_status=$?
if [ "$dc_status" -ne 1 ]; then echo "Fail: daemon-check stopped+free did not exit 1 (got $dc_status)"; exit 1; fi
pass_test "daemon-check --port exits 1 when stopped and port is free"

# Stopped + foreign listener ⇒ 2.
start_foreign_listener "$PORT_IDEM" || { echo "Fail: could not bind foreign listener on $PORT_IDEM"; exit 1; }
dc_listener="$FOREIGN_LISTENER_PID"
dc_status=0; bin/daemon-check --port "$PORT_IDEM" idem-test >/dev/null 2>&1 || dc_status=$?
if [ "$dc_status" -ne 2 ]; then echo "Fail: daemon-check stopped+held did not exit 2 (got $dc_status)"; stop_foreign_listener "$dc_listener"; exit 1; fi
pass_test "daemon-check --port exits 2 (conflict) when stopped and port is foreign-held"

# --port-less backward compatibility: stopped+held ⇒ still 1, never 2.
dc_status=0; bin/daemon-check idem-test >/dev/null 2>&1 || dc_status=$?
if [ "$dc_status" -ne 1 ]; then echo "Fail: daemon-check without --port did not exit 1 on a held port (got $dc_status)"; stop_foreign_listener "$dc_listener"; exit 1; fi
pass_test "daemon-check without --port exits 1 even when port is held (backward compatible)"
stop_foreign_listener "$dc_listener"

echo ""
echo "==== Testing --port intake validation (no silent portless degrade) ===="
# An empty --port value must be a usage error, never a silent fall-through to the
# unsafe portless path. daemon-check and daemon-up both reject it at the parse site.
dc_status=0; bin/daemon-check --port "" idem-test >/dev/null 2>&1 || dc_status=$?
if [ "$dc_status" -ne 1 ]; then echo "Fail: daemon-check --port '' did not reject empty value (got $dc_status)"; exit 1; fi
pass_test "daemon-check rejects an empty --port value"

du_status=0; bin/daemon-up --port "" idem-test -- sleep 60 >/dev/null 2>&1 || du_status=$?
if [ "$du_status" -ne 1 ]; then echo "Fail: daemon-up --port '' did not reject empty value (got $du_status)"; exit 1; fi
if [ -f "$PROJECT_ROOT/var/run/idem-test.pid" ]; then echo "Fail: daemon-up --port '' wrote a PID file"; bin/daemon-down idem-test >/dev/null 2>&1; exit 1; fi
pass_test "daemon-up rejects an empty --port value without spawning"

# A non-numeric / out-of-range --port must be rejected before any port check, in
# daemon-check too (matching daemon-up's existing validation).
dc_status=0; bin/daemon-check --port notaport idem-test >/dev/null 2>&1 || dc_status=$?
if [ "$dc_status" -ne 1 ]; then echo "Fail: daemon-check --port notaport did not reject non-numeric value (got $dc_status)"; exit 1; fi
dc_status=0; bin/daemon-check --port 99999 idem-test >/dev/null 2>&1 || dc_status=$?
if [ "$dc_status" -ne 1 ]; then echo "Fail: daemon-check --port 99999 did not reject out-of-range value (got $dc_status)"; exit 1; fi
pass_test "daemon-check rejects a non-numeric / out-of-range --port value"

echo ""
echo "==== Testing daemon-http-check ===="
# Not running: nothing bound, curl fails, port free ⇒ exit 1.
dh_status=0; bin/daemon-http-check svc "$PORT_HTTP" "http://localhost:$PORT_HTTP/healthz" >/dev/null 2>&1 || dh_status=$?
if [ "$dh_status" -ne 1 ]; then echo "Fail: daemon-http-check on a free port did not exit 1 (got $dh_status)"; exit 1; fi
pass_test "daemon-http-check exits 1 when nothing is bound (not running)"

# Port held / unhealthy: a raw foreign listener ⇒ curl -sf fails, port in use ⇒ exit 2.
start_foreign_listener "$PORT_HTTP" || { echo "Fail: could not bind foreign listener on $PORT_HTTP"; exit 1; }
dh_listener="$FOREIGN_LISTENER_PID"
dh_status=0; dh_out="$(bin/daemon-http-check svc "$PORT_HTTP" "http://localhost:$PORT_HTTP/healthz" 2>&1)" || dh_status=$?
if [ "$dh_status" -ne 2 ]; then echo "Fail: daemon-http-check with a foreign-held port did not exit 2 (got $dh_status)"; stop_foreign_listener "$dh_listener"; exit 1; fi
if ! echo "$dh_out" | grep -qF "bound but not responding as [svc]"; then echo "Fail: daemon-http-check did not log the 'bound but not responding as [svc]' message"; echo "$dh_out"; stop_foreign_listener "$dh_listener"; exit 1; fi
pass_test "daemon-http-check exits 2 and reports 'bound but not responding as [svc]' when foreign-held"
stop_foreign_listener "$dh_listener"

# Invalid args: too few arguments, and a non-numeric port ⇒ exit 3 (distinct from 2).
dh_status=0; bin/daemon-http-check svc >/dev/null 2>&1 || dh_status=$?
if [ "$dh_status" -ne 3 ]; then echo "Fail: daemon-http-check with too few args did not exit 3 (got $dh_status)"; exit 1; fi
dh_status=0; bin/daemon-http-check svc notaport http://localhost/healthz >/dev/null 2>&1 || dh_status=$?
if [ "$dh_status" -ne 3 ]; then echo "Fail: daemon-http-check with a non-numeric port did not exit 3 (got $dh_status)"; exit 1; fi
pass_test "daemon-http-check exits 3 on invalid args (distinct from the 2 conflict state)"

# Bounded probe (regression): a listener that accepts but never replies must NOT
# hang the probe. Without curl's --max-time the probe blocks forever; `timeout`
# guards the whole call so a regression FAILS loudly (exit 124) instead of
# wedging the suite. The bounded probe gives up (~3s) and check-port then reports
# the port in use ⇒ exit 2, well within the timeout guard.
start_stalled_listener "$PORT_HTTP" || { echo "Fail: could not bind stalled listener on $PORT_HTTP"; exit 1; }
dh_listener="$FOREIGN_LISTENER_PID"
dh_status=0; timeout "$BOUNDED_PROBE_GUARD_SECS" bin/daemon-http-check svc "$PORT_HTTP" "http://localhost:$PORT_HTTP/healthz" >/dev/null 2>&1 || dh_status=$?
stop_foreign_listener "$dh_listener"
if [ "$dh_status" -eq 124 ]; then echo "Fail: daemon-http-check hung on an accept-but-never-reply listener (probe is not bounded)"; exit 1; fi
if [ "$dh_status" -ne 2 ]; then echo "Fail: daemon-http-check on a stalled listener did not exit 2 (got $dh_status)"; exit 1; fi
pass_test "daemon-http-check returns (exit 2) within the bound against an accept-but-never-reply listener"

echo ""
echo "==== Testing rest-server-check failure-path hardening ===="
# Precondition: rest-server is down (PID file absent).
bin/rest-server-down >/dev/null 2>&1 || true
if [ -f "$PROJECT_ROOT/var/run/rest-server.pid" ]; then echo "Fail: precondition — rest-server PID file must be absent"; exit 1; fi
REST_PORT="${PORT:-8080}"
# Nothing on the port ⇒ exit 1.
if ! wait_for_port_free "$REST_PORT"; then echo "Fail: precondition — rest-server port $REST_PORT must be free"; exit 1; fi
rc_status=0; bin/rest-server-check >/dev/null 2>&1 || rc_status=$?
if [ "$rc_status" -ne 1 ]; then echo "Fail: rest-server-check with a free port did not exit 1 (got $rc_status)"; exit 1; fi
pass_test "rest-server-check exits 1 when its port is free and the daemon is down"

# Foreign listener on its port ⇒ exit 2 with the held-by-another-process message.
start_foreign_listener "$REST_PORT" || { echo "Fail: could not bind foreign listener on $REST_PORT"; exit 1; }
rc_listener="$FOREIGN_LISTENER_PID"
rc_status=0; rc_out="$(bin/rest-server-check 2>&1)" || rc_status=$?
if [ "$rc_status" -ne 2 ]; then echo "Fail: rest-server-check with a foreign-held port did not exit 2 (got $rc_status)"; stop_foreign_listener "$rc_listener"; exit 1; fi
if ! echo "$rc_out" | grep -qF "bound but not responding as [rest-server]"; then echo "Fail: rest-server-check did not log the truthful 'bound but not responding' message"; echo "$rc_out"; stop_foreign_listener "$rc_listener"; exit 1; fi
if ! echo "$rc_out" | grep -q "held by another process or an unhealthy instance"; then echo "Fail: rest-server-check did not log the 'held by another process or an unhealthy instance' qualifier"; echo "$rc_out"; stop_foreign_listener "$rc_listener"; exit 1; fi
pass_test "rest-server-check exits 2 and reports the port is bound but not responding when foreign-held"
stop_foreign_listener "$rc_listener"

end_tests
