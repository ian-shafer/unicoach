#!/usr/bin/env bash
source "$(dirname "$0")/common"
trap 'bin/docker-daemon-stop -d dummy-service || true; bin/docker-daemon-stop -d dummy-service-failing || true' EXIT INT TERM

echo "Harness up"

TEST_LOCK="$PROJECT_ROOT/var/run/test.lock"
mkdir -p "$PROJECT_ROOT/var/run"

echo "==== Testing file-lock ===="
rm -rf "$TEST_LOCK" || true
rm -rf "${TEST_LOCK}.stale."* || true

bin/file-lock -o op-a "$TEST_LOCK" 60
if [ ! -d "$TEST_LOCK" ]; then echo "Failed to create lock"; exit 1; fi

# Test matching op immediate fast-fail code 10
bin/file-lock -o op-a "$TEST_LOCK" 60 || STATUS=$?
if [ "${STATUS:-0}" -ne 10 ]; then echo "Failed to fast-fail on matching op"; exit 1; fi

# Test breaking a stale lock that has a matching OP
rm -rf "$TEST_LOCK" || true
mkdir "$TEST_LOCK"
echo "op-a" > "$TEST_LOCK/op"
echo "10" > "$TEST_LOCK/expires-at"
if ! bin/file-lock -o op-a "$TEST_LOCK" 60; then
  echo "Fail: Failed to organically break a stale lock because the OP happened to loosely match."
  exit 1
fi

# Test conflicting op failure
if bin/file-lock -t 1s -o op-b "$TEST_LOCK" 60 2>/dev/null; then echo "Failed to block conflicting op"; exit 1; fi

# Test stale lock recovery
echo "$(( $(date +%s) - 10 ))" > "$TEST_LOCK/expires-at"
bin/file-lock -o op-c "$TEST_LOCK" 60
if [ "$(cat "$TEST_LOCK/op")" != "op-c" ]; then echo "Failed to recover stale lock"; exit 1; fi

rm -rf "$TEST_LOCK" || true
rm -rf "${TEST_LOCK}.stale."* || true

echo "file-lock assertions passed"

echo "==== Testing docker-daemon-check ===="

if bin/docker-daemon-check dummy-service 2>/dev/null; then
  echo "Fail: Daemon check claimed success despite service not running."
  exit 1
fi

if ! bin/docker-daemon-check -h >/dev/null; then
  echo "Fail: Help flag did not natively exit 0."
  exit 1
fi

echo "docker-daemon-check assertions passed"

echo "==== Testing docker-daemon-start ===="

rm -rf "$PROJECT_ROOT/var/run/dummy-service.daemon.lock" || true
rm -rf "$PROJECT_ROOT/var/run/dummy-service-failing.daemon.lock" || true

# Invalid Service
if bin/docker-daemon-start non-existent-service 2>/dev/null; then
  echo "Fail: Invalid service did not fail natively."
  exit 1
fi

# Concurrency & Standard Start
# Two concurrent requests using backgrounding. Both should succeed (one boots, one bails early or idles).
bin/docker-daemon-start dummy-service >/dev/null &
PID1=$!
bin/docker-daemon-start dummy-service >/dev/null &
PID2=$!

wait $PID1
if [ $? -ne 0 ]; then echo "Fail: Process 1 failed to boot daemon"; exit 1; fi
wait $PID2
if [ $? -ne 0 ]; then echo "Fail: Process 2 failed lock concurrency coordination"; exit 1; fi

if ! bin/docker-daemon-check dummy-service; then
  echo "Fail: dummy-service did not actually boot or reach a healthy state."
  exit 1
fi

# Start Idempotency
if ! bin/docker-daemon-start dummy-service >/dev/null; then
  echo "Fail: Redundant start was not idempotent."
  exit 1
fi

# Start Failure Path
if bin/docker-daemon-start dummy-service-failing >/dev/null 2>&1; then
  echo "Fail: dummy-service-failing erroneously reported success."
  exit 1
fi

# Assert lock and container teardown
if [ -d "$PROJECT_ROOT/var/run/dummy-service-failing.daemon.lock" ]; then
  echo "Fail: Failing service did not release lock."
  exit 1
fi

if bin/docker-daemon-check dummy-service-failing >/dev/null 2>&1; then
  echo "Fail: Failing service left residual containers running."
  exit 1
fi

echo "docker-daemon-start assertions passed"

echo "==== Testing docker-daemon-stop ===="

# Stop Idempotency
bin/docker-daemon-stop dummy-service >/dev/null
if bin/docker-daemon-check dummy-service; then
  echo "Fail: Stop failed to natively kill service."
  exit 1
fi
if ! bin/docker-daemon-stop dummy-service >/dev/null; then
  echo "Fail: Redundant stop was not idempotent."
  exit 1
fi

echo "docker-daemon-stop assertions passed"

echo "==== Testing docker-daemon-restart ===="

# Restart Behavior
bin/docker-daemon-start dummy-service >/dev/null
if ! bin/docker-daemon-restart dummy-service >/dev/null; then
  echo "Fail: Restart failed natively."
  exit 1
fi
if ! bin/docker-daemon-check dummy-service; then
  echo "Fail: Restart did not leave service securely running."
  exit 1
fi

# Wipe Data Integrity
if ! bin/docker-daemon-stop dummy-service --wipe-data >/dev/null; then
  echo "Fail: docker-daemon-stop --wipe-data failed execution."
  exit 1
fi

echo "docker-daemon-restart assertions passed"
