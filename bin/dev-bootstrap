#!/usr/bin/env bash

source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
dev-bootstrap [options]

Empty placeholder for future host environment setup.

Options:
  -h, --help: Help
EOF
  exit "$exit_code"
}

while [[ "${1:-}" == -* ]]; do
  case "$1" in
  -h|--help) help ;;
  *)
      help "Unknown option: $1"
      ;;
  esac
done

if [ "$#" -ne 0 ]; then
  help "Error: dev-bootstrap accepts no positional arguments."
fi
