#!/usr/bin/env bash
set -euo pipefail

source "$(dirname "$0")/common"

help() {
  if [ -n "${1:-}" ]; then
    log-info "$1"
  fi
  cat << 'EOF'
Usage: bin/dev-bootstrap [OPTIONS]

Empty placeholder for future host environment setup.

Options:
  -h, --help    Show this help message and exit
EOF
  exit 1
}

while [[ "${1:-}" == -* ]]; do
  case "$1" in
    -h|--help)
      help
      ;;
    *)
      help "Unknown option: $1"
      ;;
  esac
done

if [ "$#" -ne 0 ]; then
  help "Error: dev-bootstrap accepts no positional arguments."
fi
