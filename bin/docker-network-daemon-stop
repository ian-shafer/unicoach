#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
docker-network-daemon-stop <network-name> [options]

Safely terminates an explicit native docker network bridging layer natively.

Options:
  -h, --help: Help
EOF
  exit "$exit_code"
}

NETWORK_NAME=""

while [[ $# -gt 0 ]]; do
  case "$1" in
  -h|--help) help ;;
  -d|--docker-down) shift ;;
  --wipe-data) shift ;;
  -*) fatal "Unknown option: $1" ;;
  *) break ;;
  esac
done

if [ "$#" -lt 1 ]; then
  help "Missing required <network-name> argument."
fi
NETWORK_NAME="$1"
shift

if [ "$#" -gt 0 ]; then
  fatal "Unexpected arguments: $*"
fi

LOCK_DIR="$PROJECT_ROOT/var/run/${NETWORK_NAME}.network-daemon.lock"

if ! "$PROJECT_ROOT/bin/file-lock" -o stop -t 16 "$LOCK_DIR" 60; then
  fatal "Failed to acquire lock for $NETWORK_NAME."
fi

trap 'rm -rf "$LOCK_DIR"' EXIT INT TERM

if ! "$PROJECT_ROOT/bin/docker-network-daemon-check" "$NETWORK_NAME"; then
  log-info "Network $NETWORK_NAME is already completely destroyed."
  exit 0
fi

if ! docker network rm "$NETWORK_NAME" >/dev/null 2>&1; then
  fatal "Failed to natively remove docker network bridge for $NETWORK_NAME."
fi

exit 0
