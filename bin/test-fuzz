#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
test-fuzz

Boot the rest-server natively and execute blackbox Schemathesis contract
validation against it. Requires schemathesis to be installed via pip using
the python binary provided by mise.

Options:
  -h, --help: Help
EOF
  exit "$exit_code"
}

while [[ "${1:-}" == -* ]]; do
  case "${1:-}" in
  -h|--help) help ;;
  *)
      help "Unknown option: ${1:-}"
      ;;
  esac
done

if [ "$#" -gt 0 ]; then
  help "test-fuzz does not accept positional arguments: $*"
fi

trap '"$PROJECT_ROOT/bin/rest-server-down" >/dev/null 2>&1 || true; "$PROJECT_ROOT/bin/postgres-down" >/dev/null 2>&1 || true' EXIT INT TERM

log-info "Ensuring postgres is online..."
"$PROJECT_ROOT/bin/postgres-up"

log-info "Booting rest-server..."
"$PROJECT_ROOT/bin/rest-server-up"

log-info "Commencing blackbox Schemathesis strike..."
exec schemathesis run \
  "http://localhost:${PORT:-8080}/api-spec/openapi.json" \
  --checks all \
  --validate-schema true
