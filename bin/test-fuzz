#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
test-fuzz

Boot the target rest-server within the compose environment and execute blackbox Schemathesis contract validation against it.

Options:
  -h, --help: Help
EOF
  exit "$exit_code"
}

while [[ "${1:-}" == -* ]]; do
  case "${1:-}" in
  -h|--help) help ;;
  *)
      help "Unknown option: ${1:-}"
      ;;
  esac
done

trap '"$PROJECT_ROOT/bin/rest-server-stop" --docker-down >/dev/null 2>&1 || true; "$PROJECT_ROOT/bin/postgres-stop" --docker-down >/dev/null 2>&1 || true; docker network rm "$UNICOACH_NETWORK" >/dev/null 2>&1 || true' EXIT INT TERM

log-info "Ensuring postgres is online..."
"$PROJECT_ROOT/bin/postgres-start"

log-info "Building and booting rest-server dynamically..."
"$PROJECT_ROOT/bin/rest-server-restart" --docker-down

log-info "Waiting for Ktor to finish Gradle boot and open connections on port ${PORT:-8080}..."
if ! "$PROJECT_ROOT/bin/wait-for" 90s curl -s -f "http://127.0.0.1:${PORT:-8080}/hello" > /dev/null; then
  log-info "Dumping docker logs:"
  "$PROJECT_ROOT/bin/docker-compose" -f "$PROJECT_ROOT/docker/rest-server-compose.yaml" logs
  fatal "Ktor server failed to boot within 90 seconds."
fi

log-info "Solid connection established! Commencing blackbox Schemathesis strike..."
"$PROJECT_ROOT/bin/docker-compose" -f "$PROJECT_ROOT/docker/test-fuzz-compose.yaml" run --rm fuzzer
