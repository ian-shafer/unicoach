#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
db-destroy [options]

Destroys the database and completely purges all underlying volume data.

Options:
  -y, --yes: Disable confirmation prompt
  -h, --help: Help
EOF
  exit "$exit_code"
}

FORCE=false

while [[ $# -gt 0 ]]; do
  case "$1" in
  -y|--yes) FORCE=true; shift ;;
  -h|--help) help ;;
  *) break ;;
  esac
done

if [ "$#" -gt 0 ]; then
  help "db-destroy does not accept positional arguments: $*"
fi

if [ "$FORCE" = false ]; then
  read -p "Are you sure you want to completely destroy the database and all its data? (y/N) " confirm
  case "$confirm" in
    [yY][eE][sS]|[yY]) ;;
    *)
      log-info "Database destruction aborted."
      exit 0
      ;;
  esac
fi

log-info "Destroying database [$POSTGRES_DB]..."
"$PROJECT_ROOT/bin/postgres-start" >/dev/null
echo "DROP DATABASE IF EXISTS \"$POSTGRES_DB\" WITH (FORCE);" | "$PROJECT_ROOT/bin/db-update" -d "${POSTGRES_ADMIN_DB:-postgres}"
log-info "Database [$POSTGRES_DB] successfully destroyed."
