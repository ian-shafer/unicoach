#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
docker-network-daemon-check <network-name> [options]

Verifies whether the requested native docker network bridging actively exists.

Options:
  -h, --help: Help
EOF
  exit "$exit_code"
}

NETWORK_NAME=""

while [[ $# -gt 0 ]]; do
  case "$1" in
  -h|--help) help ;;
  -*) fatal "Unknown option: $1" ;;
  *) break ;;
  esac
done

if [ "$#" -lt 1 ]; then
  help "Missing required <network-name> argument."
fi
NETWORK_NAME="$1"
shift

if [ "$#" -gt 0 ]; then
  fatal "Unexpected arguments: $*"
fi

if docker network inspect "$NETWORK_NAME" >/dev/null 2>&1; then
  exit 0
else
  exit 1
fi
