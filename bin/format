#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
format [options]

Formats Kotlin and Markdown source code across the project.
Runs ktlint --format (Kotlin) and deno fmt (Markdown) concurrently using
the native tool binaries provided by nix.

Options:
  -h, --help: Help
EOF
  exit "$exit_code"
}

while [[ "${1:-}" == -* ]]; do
  case "$1" in
  -h|--help) help ;;
  *)
      help "Unknown option: $1"
      ;;
  esac
done

if [ "$#" -ne 0 ]; then
  help "Error: format accepts no positional arguments."
fi

log-info "Formatting Kotlin and Markdown code concurrently..."

# Run Kotlin formatting in background
ktlint --format "**/*.kt" "**/*.kts" &
KOTLIN_PID=$!

deno fmt "**/*.md" &
MARKDOWN_PID=$!

# Safely capture exit codes without un-setting set -e
KOTLIN_STATUS=0
MARKDOWN_STATUS=0
wait $KOTLIN_PID || KOTLIN_STATUS=$?
wait $MARKDOWN_PID || MARKDOWN_STATUS=$?

FAILED=0

if [ "$KOTLIN_STATUS" -ne 0 ]; then
  log-error "Kotlin formatter failed (Status: $KOTLIN_STATUS)"
  FAILED=1
fi

if [ "$MARKDOWN_STATUS" -ne 0 ]; then
  log-error "Markdown formatter failed (Status: $MARKDOWN_STATUS)"
  FAILED=1
fi

if [ "$FAILED" -ne 0 ]; then
  log-info "Formatting encountered errors."
  exit 2
fi

log-info "Formatting complete."
