#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
postgres-check [options]

Exits 0 if PostgreSQL is accepting connections at PGHOST (default localhost) on
POSTGRES_PORT. Exits 1 if it is not reachable or not ready.

Options:
  -h: Help
EOF
  exit "$exit_code"
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) fatal "unknown option [-$OPTARG]" ;;
  :)  fatal "option -$OPTARG requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if pg_isready -q -h "${PGHOST:-localhost}" -p "$POSTGRES_PORT" -U "$POSTGRES_USER"; then
  log-info "postgres is running"
else
  log-info "postgres is NOT running"
  exit 1
fi
