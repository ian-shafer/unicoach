#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
docker-network-daemon-restart <network-name> [options]

Sequentially invokes stop then start for a seamless native network restart.

Options:
  -h, --help: Help
EOF
  exit "$exit_code"
}

NETWORK_NAME=""

while [[ $# -gt 0 ]]; do
  case "$1" in
  -h|--help) help ;;
  -d|--docker-down) shift ;;
  --wipe-data) shift ;;
  -*) fatal "Unknown option: $1" ;;
  *) break ;;
  esac
done

if [ "$#" -lt 1 ]; then
  help "Missing required <network-name> argument."
fi
NETWORK_NAME="$1"
shift

if [ "$#" -gt 0 ]; then
  fatal "Unexpected arguments: $*"
fi

"$PROJECT_ROOT/bin/docker-network-daemon-stop" "$NETWORK_NAME"
"$PROJECT_ROOT/bin/docker-network-daemon-start" "$NETWORK_NAME"
