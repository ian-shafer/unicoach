#!/usr/bin/env bash

source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
pre-commit [options]

Native validation script run before committing. Runs two gates concurrently:
the Gradle test suite (bin/test check) and the format/lint check (bin/format -c,
the repo's single ktlint + deno fmt avenue).

Options:
  -h: Help
EOF
  exit 0
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -ne 0 ]; then
  fatal -s "$EXIT_UNEXPECTED_ARG" "Error: pre-commit accepts no positional arguments."
fi

# The gate below needs deno, the JVM, and Postgres — all dev-shell tools. Refuse
# early with a clear message rather than failing deep in the gate with
# "deno: command not found" / "Unable to locate a Java Runtime". This is the
# is-nix guard the iOS scripts use, in the opposite direction: they refuse inside
# the dev shell, pre-commit refuses outside it.
if ! "$PROJECT_ROOT/bin/is-nix" -q; then
  fatal "pre-commit must run inside the Nix dev shell. Commit via 'nix develop -c git commit ...' or from a 'nix develop' shell."
fi

log-info "Running pre-commit checks concurrently..."

# Two concurrent gates: the test suite, and the format/lint check. ktlint lives
# only in bin/format (no Gradle ktlint plugin), so `bin/format -c` is the single
# Kotlin+Markdown lint gate; `bin/test check` runs the Gradle tests.
"$PROJECT_ROOT/bin/test" check &
TEST_PID=$!

"$PROJECT_ROOT/bin/format" -c &
LINT_PID=$!

TEST_STATUS=0
LINT_STATUS=0
wait $TEST_PID || TEST_STATUS=$?
wait $LINT_PID || LINT_STATUS=$?

FAILED=0

if [ "$TEST_STATUS" -ne 0 ]; then
  log-info "Test suite failed (Status: $TEST_STATUS)"
  FAILED=1
fi

if [ "$LINT_STATUS" -ne 0 ]; then
  log-info "Format/lint check failed (Status: $LINT_STATUS)"
  FAILED=1
fi

if [ "$FAILED" -ne 0 ]; then
  log-info "Pre-commit checks failed."
  exit 2
fi

# Fuzz the committed REST contract only when this commit changes it. test-fuzz
# boots a freshly-built rest-server and runs Schemathesis against
# api-specs/openapi.yaml — too heavy to run on every commit, so it is gated on
# the spec being staged. It runs sequentially, after the concurrent checks pass,
# so a commit already destined to fail does not pay the multi-minute fuzz cost
# and so two gradle builds (bin/test check, build-rest-server) never contend.
SPEC_REL_PATH="api-specs/openapi.yaml"
if git -C "$PROJECT_ROOT" diff --cached --name-only --diff-filter=ACMR -- "$SPEC_REL_PATH" | grep -q .; then
  log-info "[$SPEC_REL_PATH] is staged; running bin/test-fuzz against the REST contract..."
  if ! "$PROJECT_ROOT/bin/test-fuzz"; then
    log-info "Contract fuzzing failed. Pre-commit checks failed."
    exit 2
  fi
else
  log-info "[$SPEC_REL_PATH] unchanged; skipping contract fuzzing."
fi

log-info "Pre-commit checks passed."
