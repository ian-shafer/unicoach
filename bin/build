#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
build [options]

Full project build. Delegates to per-module build scripts in dependency order:
  common -> db -> service -> queue -> net -> rest-server -> queue-worker -> admin-web -> public-web

Exits immediately with the failing script's exit code if any per-module
build fails.

Options:
  -h: Help
EOF
  exit 0
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -gt 0 ]; then
  fatal -s "$EXIT_UNEXPECTED_ARG" "build does not accept positional arguments: $*"
fi

MODULES=(
  build-common
  build-db
  build-service
  build-queue
  build-net
  build-rest-server
  build-queue-worker
  build-admin-web
  build-public-web
)

for module in "${MODULES[@]}"; do
  log-info "Building [$module]..."
  "$PROJECT_ROOT/bin/$module"
done

log-info "Build complete."
