#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
build [options]

Full project build. Delegates to per-module build scripts in dependency order:
  common -> db -> service -> queue -> net -> rest-server -> queue-worker -> admin-server -> public-web

Exits immediately with the failing script's exit code if any per-module
build fails.

Options:
  -h: Help
EOF
  exit "$exit_code"
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) fatal "unknown option [-$OPTARG]" ;;
  :)  fatal "option -$OPTARG requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -gt 0 ]; then
  help "build does not accept positional arguments: $*"
fi

MODULES=(
  build-common
  build-db
  build-service
  build-queue
  build-net
  build-rest-server
  build-queue-worker
  build-admin-server
  build-public-web
)

for module in "${MODULES[@]}"; do
  log-info "Building [$module]..."
  "$PROJECT_ROOT/bin/$module"
done

log-info "Build complete."
