#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
db-create [options]

Creates and provisions the application database (POSTGRES_DB). Idempotent.
Assumes a running cluster reachable at PGHOST:PGPORT and that the application
role already exists; crashes hard otherwise. Performs:

  1. Creates the database (POSTGRES_DB) if it does not exist.
  2. Grants the application role CONNECT on the database and full access to the
     public schema, including default privileges for future objects.
  3. Creates the schema_migrations table if it does not exist.

It does not apply migrations — run db-migrate for that (or db-reset for a clean,
migrated database).

Options:
  -h, --help: Help
EOF
  exit "$exit_code"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
  -h|--help) help ;;
  *) break ;;
  esac
done

if [ "$#" -gt 0 ]; then
  help "db-create does not accept positional arguments: $*"
fi

# ── 1. Create application database if it does not exist ────────────────────────
if ! echo "SELECT 1 FROM pg_database WHERE datname = '$POSTGRES_DB'" \
    | "$PROJECT_ROOT/bin/db-query" -d "${POSTGRES_ADMIN_DB:-postgres}" -tA \
    | grep -q 1; then
  log-info "Creating database [$POSTGRES_DB]..."
  printf "CREATE DATABASE \"%s\";" "$POSTGRES_DB" \
    | "$PROJECT_ROOT/bin/db-write" -d "${POSTGRES_ADMIN_DB:-postgres}"
else
  log-info "Database [$POSTGRES_DB] already exists."
fi

# ── 2. Grant database-level connect privilege (admin DB context) ──────────────
printf "GRANT CONNECT ON DATABASE \"%s\" TO \"%s\";" \
  "$POSTGRES_DB" "$DATABASE_USER" \
  | "$PROJECT_ROOT/bin/db-write" -d "${POSTGRES_ADMIN_DB:-postgres}"

# ── 3. Grant schema access and default object privileges (target DB) ──────────
# ALTER DEFAULT PRIVILEGES covers all future tables/sequences created by the
# admin role (POSTGRES_USER) in the public schema.
cat << SQL | "$PROJECT_ROOT/bin/db-write"
GRANT ALL ON SCHEMA public TO "$DATABASE_USER";
ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT ALL ON TABLES     TO "$DATABASE_USER";
ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT ALL ON SEQUENCES  TO "$DATABASE_USER";
SQL

# ── 4. Create schema_migrations and grant access ──────────────────────────────
log-info "Ensuring schema_migrations table exists..."
cat << SQL | "$PROJECT_ROOT/bin/db-write"
CREATE TABLE IF NOT EXISTS schema_migrations (
  version_id VARCHAR(4)    PRIMARY KEY,
  filename   VARCHAR(255)  NOT NULL,
  applied_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
);
SQL

log-info "Database [$POSTGRES_DB] provisioned."
