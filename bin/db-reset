#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
db-reset [options]

Returns POSTGRES_DB to a clean, fully-migrated state by dropping and recreating
it. This is the frequent per-run operation (e.g. bin/test); it does no cluster or
role work, so it assumes db-bootstrap was already run once by hand. Performs:

  1. db-drop   — DROP DATABASE IF EXISTS (idempotent)
  2. db-create — recreate the database, grants, and schema_migrations
  3. db-migrate — apply all pending migrations

Options:
  -h: Help
EOF
  exit "$exit_code"
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) help "unknown option [-$OPTARG]" ;;
  :)  help "option -$OPTARG requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -gt 0 ]; then
  help "db-reset does not accept positional arguments: $*"
fi

"$PROJECT_ROOT/bin/db-drop" -y
"$PROJECT_ROOT/bin/db-create"
"$PROJECT_ROOT/bin/db-migrate"

log-info "db-reset complete: [$POSTGRES_DB] is clean and migrated."
