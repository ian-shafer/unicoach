#!/usr/bin/env bash

source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
docker-compose [options] COMMAND...

Universal docker-compose wrapper that dynamically exports user identity and projects root context natively into docker networking.

Options:
  -h, --help: Help
EOF
  exit "$exit_code"
}

# Only gracefully intercept help flags if they are clearly the first argument.
# We avoid deep parsing to prevent crashing legitimate docker compose flags like -f or --profile.
if [[ "${1:-}" == "-h" ]] || [[ "${1:-}" == "--help" ]]; then
  help
fi

# Dynamically pass host identity and project root tightly scoped to the docker compose command.
# Every variable required by any compose yaml file must be securely and explicitly routed inline
# here to systematically prevent invisible 'magic' evaluation across varying environments.
HOST_UID="$(id -u)" \
HOST_GID="$(id -g)" \
PORT="${PORT:-8080}" \
HEALTH_NONCE="${HEALTH_NONCE:-}" \
COMPOSE_IGNORE_ORPHANS=true \
POSTGRES_DATA_DIR="${POSTGRES_DATA_DIR:-./var/postgres}" \
POSTGRES_USER="${POSTGRES_USER:-postgres}" \
POSTGRES_DB="${POSTGRES_DB:-unicoach}" \
POSTGRES_HOST_AUTH_METHOD="${POSTGRES_HOST_AUTH_METHOD:-trust}" \
docker compose --env-file /dev/null --project-directory "$PROJECT_ROOT" "$@"
