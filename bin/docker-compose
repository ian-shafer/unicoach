#!/usr/bin/env bash

source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
docker-compose [options] COMMAND...

Universal docker-compose wrapper that dynamically exports user identity and projects root context natively into docker networking.

Options:
  -h, --help: Help
EOF
  exit "$exit_code"
}

# Only gracefully intercept help flags if they are clearly the first argument.
# We avoid deep parsing to prevent crashing legitimate docker compose flags like -f or --profile.
if [[ "${1:-}" == "-h" ]] || [[ "${1:-}" == "--help" ]]; then
  help
fi

# Dynamically pass host identity and project root tightly scoped to the docker compose command
HOST_UID="$(id -u)" HOST_GID="$(id -g)" PROJECT_ROOT="$PROJECT_ROOT" docker compose --project-directory "$PROJECT_ROOT" "$@"
