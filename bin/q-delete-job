#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
q-delete-job <job-id>

Deletes a single job and its attempt history by UUID.
EOF
}

while getopts ":h" opt; do
  case "$opt" in
  h) help; exit 0 ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -lt 1 ]; then
  fatal -s "$EXIT_MISSING_REQUIRED_ARG" "q-delete-job requires a <job-id> argument"
fi
if [ "$#" -gt 1 ]; then
  fatal -s "$EXIT_UNEXPECTED_ARG" "q-delete-job accepts exactly one <job-id>; received: $*"
fi

job_id="$1"
query="WITH deleted AS (DELETE FROM jobs WHERE id = '$job_id' RETURNING id) SELECT count(*) FROM deleted;"

# The CTE deletes, so it must run read-write. db-query is the read-only wrapper
# (default_transaction_read_only=on) and would reject it; db-run rw both mutates
# and returns the deleted-row count via -r (raw/tuples-only).
res=$(echo "$query" | "$PROJECT_ROOT/bin/db-run" -r rw) || exit 2

if [ "$res" = "0" ]; then
  fatal "Job [$job_id] not found"
fi
