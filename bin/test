#!/usr/bin/env bash

export ENV_FILE="$(dirname $0)/../.env.test"
source "$(dirname "$0")/common"

# Add new Gradle modules here, in sync with settings.gradle.kts.
MODULES=(common db net auth queue queue-worker rest-server service email chat admin-web public-web college)

help() {
  cat << 'EOF'
test [options] [check] [module ...]

Runs Gradle tests on the nix-provided host JVM. Resets this worktree's test
database first (postgres-up -> db-reset -> db-tests), then runs the selected
modules' test tasks. With no modules, runs every module.

The optional leading `check` keyword runs each selected module's Gradle `check`
task instead of bare `test`. The pre-commit hook invokes this form for the test
gate. (Kotlin lint/format is not here — it lives in bin/format, the repo's single
ktlint avenue; the hook runs `bin/format -c` alongside this.)

Modules:
  common db net auth queue queue-worker rest-server service email chat admin-web public-web college

Options:
  -t GLOB   Gradle test filter (requires exactly one module)
  -f        Force re-run, bypass the build cache (--rerun-tasks)
  -v        Verbose Gradle output (--info)
  -c        Run all selected test tasks, report every failure
  -h        Help
EOF
  exit 0
}

# Returns 0 if $1 is a member of MODULES.
is-module() {
  local candidate="$1" module
  for module in "${MODULES[@]}"; do
    [ "$module" = "$candidate" ] && return 0
  done
  return 1
}

SELECTED=()
TASK="test"
TESTS_GLOB=""
HAS_TESTS=false
FORCE=false
VERBOSE=false
CONTINUE=false

# Options and positionals (the `check` keyword and module names) may be
# intermixed in any order. getopts alone stops at the first non-option, so wrap
# it in an outer loop that consumes one non-option per round, resetting OPTIND=1
# before each inner getopts run (OPTIND is not auto-reset within one shell).
while [ "$#" -gt 0 ]; do
  OPTIND=1
  while getopts ":ht:fvc" opt; do
    case "$opt" in
    h) help ;;
    t) TESTS_GLOB="$OPTARG"; HAS_TESTS=true ;;
    f) FORCE=true ;;
    v) VERBOSE=true ;;
    c) CONTINUE=true ;;
    \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
    :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" -- "--tests requires a GLOB" ;;
    esac
  done
  shift $((OPTIND-1))
  if [ "$#" -gt 0 ]; then
    case "$1" in
    check) TASK="check" ;;
    *)
      if is-module "$1"; then
        # De-duplicate repeated modules.
        if ! printf '%s\n' "${SELECTED[@]}" | grep -qxF "$1"; then
          SELECTED+=("$1")
        fi
      else
        fatal -s "$EXIT_INVALID_ARG_VALUE" "unknown module [$1]"
      fi
      ;;
    esac
    shift
  fi
done

# --tests filters a single test task; it is meaningless across multiple tasks.
if [ "$HAS_TESTS" = true ] && [ "${#SELECTED[@]}" -ne 1 ]; then
  fatal -s "$EXIT_MISSING_REQUIRED_ARG" -- "--tests requires exactly one module"
fi

# Core invariant: emit at least one :module:<task> task (test, or check when the
# `check` keyword is given). No modules named => all.
if [ "${#SELECTED[@]}" -eq 0 ]; then
  SELECTED=("${MODULES[@]}")
fi

GRADLE_ARGS=()
for module in "${SELECTED[@]}"; do
  GRADLE_ARGS+=(":$module:$TASK")
done
[ "$FORCE" = true ] && GRADLE_ARGS+=("--rerun-tasks")
[ "$VERBOSE" = true ] && GRADLE_ARGS+=("--info")
[ "$CONTINUE" = true ] && GRADLE_ARGS+=("--continue")
[ "$HAS_TESTS" = true ] && GRADLE_ARGS+=("--tests" "$TESTS_GLOB")

# Assumes db-bootstrap was already run once by hand (shared cluster + role).
# Reset only this worktree's test DB to a clean, fully-migrated state; never
# touch the shared cluster itself.
"$PROJECT_ROOT/bin/postgres-up"
"$PROJECT_ROOT/bin/db-reset"

# Run the shell DB schema harnesses against the freshly migrated DB, sequentially
# (never backgrounded) and before the terminal exec. Under set -e a non-zero exit
# aborts the run; Postgres stays up so the subsequent Gradle suite sees the same DB.
"$PROJECT_ROOT/bin/db-tests"

"$PROJECT_ROOT/gradlew" "${GRADLE_ARGS[@]}"
