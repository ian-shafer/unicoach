#!/usr/bin/env bash

export ENV_FILE="$(dirname $0)/../.env.test"
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
test [options] [args...]

Executes gradle tests inside a sibling docker-compose orchestration cleanly.

Options:
  -h, --help: Help
EOF
  exit "$exit_code"
}

while [[ "${1:-}" == -* ]]; do
  case "$1" in
  -h|--help) help ;;
  *)
      # Pass through gracefully to gradle runtime
      break
      ;;
  esac
done

# Ensure the shared postgres daemon is genuinely online without forcibly crashing or re-creating it 
# (which avoids mutating the service arguments identically required by docker-compose)
"$PROJECT_ROOT/bin/postgres-start"
"$PROJECT_ROOT/bin/db-destroy" --yes-i-really-want-to-do-this
"$PROJECT_ROOT/bin/db-init"
"$PROJECT_ROOT/bin/db-migrate"

# Default to 'test' if no arguments are provided, otherwise execute exactly what is passed
GRADLE_ARGS=("${@:-test}")

# gradle-runner automatically connects to `postgres:5432` internally via `unicoach-network`
"$PROJECT_ROOT/bin/docker-compose" -f "$PROJECT_ROOT/docker/test-compose.yaml" run --rm gradle-runner ./gradlew "${GRADLE_ARGS[@]}"
EXIT_CODE=$?

# We specifically DO NOT `down` the network because the PostgreSQL daemon is physically shared with development scopes!
exit $EXIT_CODE
