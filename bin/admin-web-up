#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
admin-web-up [options]

Boots the admin-web daemon from a pre-built installDist binary and waits
for it to respond to HTTP requests.

The binary MUST be pre-built via `bin/build-admin-web` before invoking
this script. If the binary is absent, this script exits non-zero immediately
without invoking Gradle.

Options:
  -h: Help
EOF
  exit 0
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -gt 0 ]; then
  fatal -s "$EXIT_UNEXPECTED_ARG" "admin-web-up does not accept positional arguments: [$*]"
fi

BINARY="$PROJECT_ROOT/admin-web/build/install/admin-web/bin/admin-web"

if [ ! -x "$BINARY" ]; then
  fatal "admin-web binary not found at [$BINARY]. Run 'bin/build-admin-web' first."
fi

"$PROJECT_ROOT/bin/daemon-up" -p "${ADMIN_WEB_PORT:-8081}" admin-web -- "$BINARY"

"$PROJECT_ROOT/bin/admin-web-wait-for-health"
