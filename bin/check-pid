#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
check-pid <pid>

Exits 0 if the process identified by <pid> is alive, 1 if it is not.

Arguments:
  pid: The process ID to check.

Options:
  -h: Help
EOF
  exit 0
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -lt 1 ]; then
  fatal -s "$EXIT_MISSING_REQUIRED_ARG" "Missing required <pid> argument."
fi
if [ "$#" -gt 1 ]; then
  fatal -s "$EXIT_UNEXPECTED_ARG" "check-pid accepts exactly one <pid>; received: $*"
fi

PID="$1"
shift

# kill -0 sends no signal; it only tests whether the process exists and is
# reachable by the calling user. Redirect stderr to suppress "No such process".
if kill -0 "$PID" 2>/dev/null; then
  exit 0
else
  exit 1
fi
