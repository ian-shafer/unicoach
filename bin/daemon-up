#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
daemon-up [options] <service-name> -- <command...>

Boots a native background daemon for <service-name>, routing stdout and
stderr to var/log/<service-name>.log and tracking the PID in
var/run/<service-name>.pid.

Uses bin/file-lock to serialize concurrent invocations. A second concurrent
"up" call exits 0 immediately. The service is NOT re-spawned if the existing
PID is still alive.

Arguments:
  service-name: Logical service identifier (e.g. postgres, rest-server).
  --:           Argument separator. Everything after this is the command to run.
  command...:   The native command to execute in the background.

Options:
  -h, --help: Help
EOF
  exit "$exit_code"
}

SERVICE_NAME=""

while [[ $# -gt 0 ]]; do
  case "$1" in
  -h|--help) help ;;
  -*) fatal "Unknown option: $1" ;;
  *) break ;;
  esac
done

if [ "$#" -lt 1 ]; then
  help "Missing required <service-name> argument."
fi
SERVICE_NAME="$1"
shift

# Consume the mandatory -- separator
if [ "${1:-}" != "--" ]; then
  help "Expected '--' separator after <service-name>, got: ${1:-}"
fi
shift

if [ "$#" -lt 1 ]; then
  help "Missing required <command...> after '--'."
fi

COMMAND=("$@")

PID_FILE="$PROJECT_ROOT/var/run/${SERVICE_NAME}.pid"
LOG_FILE="$PROJECT_ROOT/var/log/${SERVICE_NAME}.log"
LOCK_DIR="$PROJECT_ROOT/var/run/${SERVICE_NAME}.daemon.lock"

LOCK_STATUS=0
"$PROJECT_ROOT/bin/file-lock" -o up -t 16 "$LOCK_DIR" 60 || LOCK_STATUS=$?

if [ "$LOCK_STATUS" -eq 10 ]; then
  log-info "Another up instance is actively establishing [$SERVICE_NAME]. Exiting gracefully."
  exit 0
fi

if [ "$LOCK_STATUS" -ne 0 ]; then
  fatal "Failed to acquire lock for [$SERVICE_NAME]. Lock may be held by a conflicting operation."
fi

trap 'rm -rf "$LOCK_DIR"' EXIT INT TERM

# If a PID file exists, check whether the recorded process is still alive.
if [ -f "$PID_FILE" ]; then
  existing_pid="$(cat "$PID_FILE" 2>/dev/null || true)"
  if [ -n "$existing_pid" ] && "$PROJECT_ROOT/bin/check-pid" "$existing_pid" 2>/dev/null; then
    log-info "Service [$SERVICE_NAME] is already running (PID $existing_pid)."
    exit 0
  fi
  # Stale PID file — process is gone; clean it up before re-launching.
  rm -f "$PID_FILE"
fi

mkdir -p "$PROJECT_ROOT/var/run"
mkdir -p "$PROJECT_ROOT/var/log"

log-info "Starting [$SERVICE_NAME]..."
nohup "${COMMAND[@]}" >> "$LOG_FILE" 2>&1 &
DAEMON_PID=$!

echo "$DAEMON_PID" > "$PID_FILE"
log-info "Service [$SERVICE_NAME] started with PID $DAEMON_PID"
log-info "Log: $LOG_FILE"
