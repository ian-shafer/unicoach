#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
daemon-up [options] <service-name> -- <command...>

Boots a native background daemon for <service-name>, routing stdout and
stderr to var/log/<service-name>.log and tracking the PID in
var/run/<service-name>.pid.

Uses bin/file-lock to serialize concurrent invocations. A second concurrent
"up" call exits 0 immediately. The service is NOT re-spawned if the existing
PID is still alive.

When -p is supplied, a pre-launch preflight runs once we conclude we are
not already running: if 127.0.0.1:<port> is already bound (by any process,
including a daemon from another worktree), the boot is refused rather than
spawning a doomed process. When -p is absent the preflight is skipped.

Arguments:
  service-name: Logical service identifier (e.g. postgres, rest-server).
  --:           Argument separator. Everything after this is the command to run.
  command...:   The native command to execute in the background.

Options:
  -h:        Help
  -p <port>: TCP port the daemon binds; preflighted before spawn.

Exit codes:
  0: Service started, or already running (idempotent), or a concurrent up won.
  1: Lock acquisition failed, or a usage error.
  3: Port collision — <port> is already bound; the service was NOT spawned.
EOF
  exit 0
}

SERVICE_NAME=""
PORT=""
PORT_SET=false

# getopts parses only the LEADING options and halts at the first non-option
# (<service-name>), which always precedes the mandatory --, so it never consumes
# the -- separator or the verbatim command. Both error arms route to fatal -s
# with their band code: an unknown option -> EXIT_UNKNOWN_OPTION, a missing -p
# value -> EXIT_OPTION_REQUIRES_VALUE.
while getopts ":hp:" opt; do
  case "$opt" in
  h) help ;;
  p) PORT="$OPTARG"; PORT_SET=true ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

# An explicit -p with an empty value is a usage error (never a silent portless
# degrade); -p must carry a valid 1..65535 port.
if [ "$PORT_SET" = true ] && ! validate_port "$PORT"; then
  fatal -s "$EXIT_INVALID_ARG_VALUE" "Invalid -p value [$PORT]. Expected an integer in 1..65535."
fi

if [ "$#" -lt 1 ]; then
  fatal -s "$EXIT_MISSING_REQUIRED_ARG" "Missing required <service-name> argument."
fi
SERVICE_NAME="$1"
shift

# Consume the mandatory -- separator
if [ "${1:-}" != "--" ]; then
  fatal -s "$EXIT_MISSING_REQUIRED_ARG" "Expected '--' separator after <service-name>, got: ${1:-}"
fi
shift

if [ "$#" -lt 1 ]; then
  fatal -s "$EXIT_MISSING_REQUIRED_ARG" "Missing required <command...> after '--'."
fi

COMMAND=("$@")

PID_FILE="$PROJECT_ROOT/var/run/${SERVICE_NAME}.pid"
LOG_FILE="$PROJECT_ROOT/var/log/${SERVICE_NAME}.log"
LOCK_DIR="$PROJECT_ROOT/var/run/${SERVICE_NAME}.daemon.lock"

LOCK_STATUS=0
"$PROJECT_ROOT/bin/file-lock" -o up -t 16 "$LOCK_DIR" 60 || LOCK_STATUS=$?

if [ "$LOCK_STATUS" -eq 3 ]; then
  log-info "Another up instance is actively establishing [$SERVICE_NAME]. Exiting gracefully."
  exit 0
fi

if [ "$LOCK_STATUS" -ne 0 ]; then
  fatal "Failed to acquire lock for [$SERVICE_NAME]. Lock may be held by a conflicting operation."
fi

trap 'rm -rf "$LOCK_DIR"' EXIT INT TERM

# If a PID file exists, check whether the recorded process is still alive.
if [ -f "$PID_FILE" ]; then
  existing_pid="$(cat "$PID_FILE" 2>/dev/null || true)"
  if [ -n "$existing_pid" ] && "$PROJECT_ROOT/bin/check-pid" "$existing_pid" 2>/dev/null; then
    log-info "Service [$SERVICE_NAME] is already running (PID $existing_pid)."
    exit 0
  fi
  # Stale PID file — process is gone; clean it up before re-launching.
  rm -f "$PID_FILE"
fi

# Port preflight: we have concluded we are not running (our PID file is absent
# or stale). If -p was supplied and the port is already bound — by a foreign
# process, another worktree's daemon, or our own orphaned-alive process whose
# PID file we lost — refuse rather than spawn a doomed JVM that will die with a
# BindException while we write a dead PID and report false success. The trap
# removes the lock directory on this exit.
if [ -n "$PORT" ] && "$PROJECT_ROOT/bin/check-port" "$PORT"; then
  fatal -s 3 "Cannot start [$SERVICE_NAME]: port [127.0.0.1:$PORT] is already held by another process."
fi

mkdir -p "$PROJECT_ROOT/var/run"
mkdir -p "$PROJECT_ROOT/var/log"

log-info "Starting [$SERVICE_NAME]..."
nohup "${COMMAND[@]}" >> "$LOG_FILE" 2>&1 &
DAEMON_PID=$!

echo "$DAEMON_PID" > "$PID_FILE"
log-info "Service [$SERVICE_NAME] started with PID $DAEMON_PID"
log-info "Log: $LOG_FILE"
