#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
q-enqueue <job-type> <payload-json> [options]

Enqueues a job from the command line.

Options:
  -m <n>: Override max attempts.
  -d <duration>: Delay before the job becomes eligible.
EOF
}

# Options strictly trail the two required positionals, so a leading -h short-
# circuit answers help before the positional-count check.
if [ "${1:-}" = "-h" ]; then
  help
  exit 0
fi

if [ $# -lt 2 ]; then
  help
  exit 1
fi

job_type=$1
payload=$2
shift 2

max_attempts="NULL"
delay=""

while getopts ":m:d:" opt; do
  case "$opt" in
    m) max_attempts="$OPTARG" ;;
    d) delay="$OPTARG" ;;
    \?) fatal "Unknown option [-$OPTARG]" ;;
    :)  fatal "option -$OPTARG requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -gt 0 ]; then
  fatal "Unknown option [$1]"
fi

sql_scheduled_at="NOW()"
if [ -n "$delay" ]; then
  interval=$(transform_duration_to_postgres "$delay") || fatal "Invalid delay duration: [$delay]"
  sql_scheduled_at="NOW() + INTERVAL '$interval'"
fi

payload_escaped=$(echo "$payload" | sed "s/'/''/g")
query="INSERT INTO jobs (job_type, payload, scheduled_at, max_attempts) VALUES ('$job_type', '$payload_escaped', $sql_scheduled_at, COALESCE($max_attempts, 3));"

echo "$query" | "$PROJECT_ROOT/bin/db-write" || exit 2
