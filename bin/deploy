#!/usr/bin/env bash
# deploy: the single operator entry point for shipping a release. Contains no AWS
# resource definitions (those are OpenTofu's). Sequence:
#   1. bin/build           — produce both installDist distributions locally.
#   2. assemble a bundle   — tarball preserving repo-relative paths.
#   3. upload to S3        — the artifacts bucket (OpenTofu output).
#   4. SSM Run Command     — execute deploy-on-instance on the host (output id).
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
deploy <env> [options]

Builds, bundles, uploads, and triggers an on-instance deploy via SSM Run Command
for one environment (<env>, e.g. prod). Requires an active AWS session and a
completed `bin/infra-apply <env>` (reads the artifacts bucket and instance id
from that env's OpenTofu outputs).

Options:
  -h: Help
EOF
  exit 0
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

UNICOACH_ENV="${1:-}"
if [ -n "$UNICOACH_ENV" ]; then
  shift
fi
if [ "$#" -gt 0 ]; then
  fatal -s "$EXIT_UNEXPECTED_ARG" "deploy accepts only an environment argument: $*"
fi

# Select and validate the environment, then point this run's tofu output reads at
# its disjoint state (TF_DATA_DIR) and supply the partial backend's state key.
# `unicoach_env_file` fatals on a missing/absent env before any AWS or build work.
ENV_FILE="$(unicoach_env_file "$UNICOACH_ENV")"
set -a
# shellcheck source=/dev/null
source "$ENV_FILE"
set +a
require_env_vars ENVIRONMENT

# Fail-fast: refuse to ship to the wrong AWS account. deploy sources the selected
# env's delta above; assert the active credentials resolve to the account it
# declares (its AWS_ACCOUNT_ID) before any tofu output read, build, upload, or SSM
# call, so a stray ambient AWS profile fails loudly instead of shipping a release
# to the wrong account.
assert_aws_account "${AWS_ACCOUNT_ID:-}"

export TF_DATA_DIR="$PROJECT_ROOT/infra/.terraform-$UNICOACH_ENV"
tofu -chdir="$PROJECT_ROOT/infra" init \
  -backend-config="key=unicoach/$UNICOACH_ENV/terraform.tfstate"

# Region for the S3 upload and SSM call. Override with AWS_REGION (or the standard
# AWS_DEFAULT_REGION); the .env.<env> REGION if set, else the infra region default.
AWS_REGION="${AWS_REGION:-${AWS_DEFAULT_REGION:-${REGION:-us-east-1}}}"

# ── 1. Build both distributions ───────────────────────────────────────────────
"$PROJECT_ROOT/bin/build"

REST_DIST="rest-server/build/install/rest-server"
WORKER_DIST="queue-worker/build/install/queue-worker"

for dist in "$REST_DIST" "$WORKER_DIST"; do
  [ -d "$PROJECT_ROOT/$dist" ] || fatal "Missing distribution [$dist]; did bin/build succeed?"
done

# ── 2. Assemble the bundle ────────────────────────────────────────────────────
# The two installDist trees are tarred from their build/install parent so they
# enter the bundle as bare rest-server/ and queue-worker/ — the paths the systemd
# units expect at current/<svc>/bin/<svc>, decoupled from the Gradle build layout.
# The on-instance migration scripts source bin/common -> bin/functions and shell
# out to the bin/db-* family; bin/db-status and bin/db-create both invoke
# bin/db-query for their existence checks, so it must be included. Every db-run
# gates on bin/postgres-check, so it is bundled too. These repo files keep their
# repo-relative paths under $PROJECT_ROOT.
BUNDLE_ID="$(date -u +%Y%m%d%H%M%S)"
BUNDLE_PATH="$(mktemp -t unicoach-deploy.XXXXXX).tar.gz"
trap 'rm -f "$BUNDLE_PATH"' EXIT

REPO_PATHS=(
  "db/schema"
  "bin/common"
  "bin/functions"
  "bin/db-create-role"
  "bin/db-create"
  "bin/db-migrate"
  "bin/db-status"
  "bin/db-write"
  "bin/db-query"
  "bin/db-run"
  "bin/postgres-check"
)

for path in "${REPO_PATHS[@]}"; do
  [ -e "$PROJECT_ROOT/$path" ] || fatal "Bundle path missing [$path]."
done

log-info "Assembling deploy bundle [$BUNDLE_ID]..."
tar -czf "$BUNDLE_PATH" \
  -C "$(dirname "$PROJECT_ROOT/$REST_DIST")" "$(basename "$REST_DIST")" \
  -C "$(dirname "$PROJECT_ROOT/$WORKER_DIST")" "$(basename "$WORKER_DIST")" \
  -C "$PROJECT_ROOT" "${REPO_PATHS[@]}"

# ── 3. Upload to the artifacts bucket ─────────────────────────────────────────
ARTIFACTS_BUCKET="$(tofu -chdir="$PROJECT_ROOT/infra" output -raw artifacts_bucket)"
[ -n "$ARTIFACTS_BUCKET" ] || fatal "Could not read artifacts_bucket from OpenTofu outputs."

BUNDLE_KEY="releases/unicoach-$BUNDLE_ID.tar.gz"
BUNDLE_S3_URI="s3://$ARTIFACTS_BUCKET/$BUNDLE_KEY"

log-info "Uploading bundle to [$BUNDLE_S3_URI]..."
aws s3 cp --region "$AWS_REGION" "$BUNDLE_PATH" "$BUNDLE_S3_URI"

# ── 4. Trigger the on-instance deploy via SSM Run Command ─────────────────────
INSTANCE_ID="$(tofu -chdir="$PROJECT_ROOT/infra" output -raw instance_id)"
[ -n "$INSTANCE_ID" ] || fatal "Could not read instance_id from OpenTofu outputs."

log-info "Issuing SSM Run Command to [$INSTANCE_ID]..."
COMMAND_ID="$(aws ssm send-command \
  --region "$AWS_REGION" \
  --instance-ids "$INSTANCE_ID" \
  --document-name "AWS-RunShellScript" \
  --comment "unicoach deploy $BUNDLE_ID" \
  --parameters "commands=[\"/opt/unicoach/bin/deploy-on-instance $BUNDLE_S3_URI\"]" \
  --query "Command.CommandId" \
  --output text)"

log-info "SSM command [$COMMAND_ID] dispatched. Tail with:"
log-info "  aws ssm get-command-invocation --region $AWS_REGION --command-id $COMMAND_ID --instance-id $INSTANCE_ID"
