#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
db-write [-d <db>] [sql]

Arguments:
  sql: Optional SQL statement; when omitted, psql reads stdin

Options:
  -d <db>: Override the target database
  -h:      Help
EOF
  exit 0
}

DB_FLAGS=()

while getopts ":d:h" opt; do
  case "$opt" in
  d) DB_FLAGS=("-d" "$OPTARG") ;;
  h) help ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -gt 1 ]; then
  fatal -s "$EXIT_UNEXPECTED_ARG" "db-write accepts at most one SQL argument; received: $*"
fi

SQL_ARG=()
if [ "$#" -eq 1 ]; then
  SQL_ARG=("$1")
fi

"$PROJECT_ROOT/bin/db-run" "${DB_FLAGS[@]}" rw "${SQL_ARG[@]}"
