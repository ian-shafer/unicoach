#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
daemon-bounce [options] <service-name> -- <command...>

Sequentially invokes daemon-down then daemon-up for a clean bounce.
Passes <service-name> and <command...> through to daemon-up unchanged.

Arguments:
  service-name: Logical service identifier (e.g. postgres, rest-server).
  --:           Argument separator. Everything after this is passed to daemon-up.
  command...:   The native command to execute in the background.

Options:
  -h: Help
EOF
  exit 0
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -lt 1 ]; then
  fatal -s "$EXIT_MISSING_REQUIRED_ARG" "Missing required <service-name> argument."
fi

SERVICE_NAME="$1"
shift

# Consume the mandatory -- separator
if [ "${1:-}" != "--" ]; then
  fatal -s "$EXIT_MISSING_REQUIRED_ARG" "Expected '--' separator after <service-name>, got: ${1:-}"
fi
# Keep -- in place; daemon-up expects it
COMMAND_WITH_SEP=("$@")

"$PROJECT_ROOT/bin/daemon-down" "$SERVICE_NAME"
"$PROJECT_ROOT/bin/daemon-up" "$SERVICE_NAME" "${COMMAND_WITH_SEP[@]}"
