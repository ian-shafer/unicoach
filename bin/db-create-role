#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  local exit_code=0
  if [ "$#" -gt 0 ]; then
    log-info "$1"
    exit_code=1
  fi
  cat << 'EOF'
db-create-role [options]

Creates the application login role (DATABASE_USER with DATABASE_PASSWORD) against
whatever cluster PGHOST points at. Idempotent and race-tolerant: a duplicate role
is swallowed, so concurrent runs (and re-runs) are safe.

Unlike db-bootstrap, this performs no initdb, so it is safe against a managed
cluster (e.g. RDS) where initdb is impossible. It connects as the master role
(POSTGRES_USER) against the admin database (POSTGRES_ADMIN_DB, default postgres).

Options:
  -h, --help: Help
EOF
  exit "$exit_code"
}

while [[ "${1:-}" == -* ]]; do
  case "$1" in
  -h|--help) help ;;
  -*) fatal "Unknown option: $1" ;;
  *) break ;;
  esac
done

if [ "$#" -gt 0 ]; then
  help "db-create-role does not accept positional arguments: $*"
fi

# A plain SELECT-then-CREATE has a TOCTOU race when two callers create the role on
# a shared cluster at once. Creating inside a DO block that swallows the duplicate
# makes concurrent runs (and re-runs) safe.
log-info "Ensuring role [$DATABASE_USER] exists..."
cat << SQL | "$PROJECT_ROOT/bin/db-write" -d "${POSTGRES_ADMIN_DB:-postgres}"
DO \$\$
BEGIN
  CREATE ROLE "$DATABASE_USER" WITH LOGIN PASSWORD '$DATABASE_PASSWORD';
EXCEPTION WHEN duplicate_object OR unique_violation THEN
  RAISE NOTICE 'role "%" already exists, skipping', '$DATABASE_USER';
END
\$\$;
SQL

log-info "Role [$DATABASE_USER] ensured."
