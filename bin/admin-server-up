#!/usr/bin/env bash
source "$(dirname "$0")/common"

help() {
  cat << 'EOF'
admin-server-up [options]

Boots the admin-server daemon from a pre-built installDist binary and waits
for it to respond to HTTP requests.

The binary MUST be pre-built via `bin/build-admin-server` before invoking
this script. If the binary is absent, this script exits non-zero immediately
without invoking Gradle.

Options:
  -h: Help
EOF
  exit 0
}

while getopts ":h" opt; do
  case "$opt" in
  h) help ;;
  \?) fatal -s "$EXIT_UNKNOWN_OPTION" "unknown option [-$OPTARG]" ;;
  :)  fatal -s "$EXIT_OPTION_REQUIRES_VALUE" "option [-$OPTARG] requires an argument" ;;
  esac
done
shift $((OPTIND-1))

if [ "$#" -gt 0 ]; then
  fatal -s "$EXIT_UNEXPECTED_ARG" "admin-server-up does not accept positional arguments: $*"
fi

BINARY="$PROJECT_ROOT/admin-server/build/install/admin-server/bin/admin-server"

if [ ! -x "$BINARY" ]; then
  fatal "admin-server binary not found at [$BINARY]. Run 'bin/build-admin-server' first."
fi

"$PROJECT_ROOT/bin/daemon-up" -p "${ADMIN_SERVER_PORT:-8081}" admin-server -- "$BINARY"

"$PROJECT_ROOT/bin/admin-server-wait-for-health"
